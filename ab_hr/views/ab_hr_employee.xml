<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="ab_hr_employee_view_kanban" model="ir.ui.view">
            <field name="name">ab_hr_employee_kanban</field>
            <field name="model">ab_hr_employee</field>
            <field name="priority">10</field>
            <field name="arch" type="xml">
               <kanban class="o_ab_hr_employee_kanban">
    <field name="name"/>
    <field name="job_id"/>
    <field name="department_id"/>
    <field name="parent_id"/>
    <field name="accid"/>
    <field name="work_phone"/>
    <field name="work_email"/>
    <field name="address_text"/>
    <field name="hiring_date"/>
    <field name="issue_date"/>
    <field name="termination_date"/>
    <field name="is_working"/>
    <field name="supervision_type"/>
    <templates>
        <t t-name="card">
            <style>
                .ab_emp_card {
                    padding: 0 !important;
                    border-radius: 12px !important;
                    border: 1px solid #e9ecef;
                    overflow: hidden;
                    transition: box-shadow 0.2s ease, transform 0.2s ease;
                }
                .ab_emp_card:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 8px 24px rgba(0,0,0,0.09) !important;
                }
                .ab_emp_avatar {
                    width: 48px; height: 48px;
                    border-radius: 50%;
                    background: #EEEDFE;
                    color: #3C3489;
                    display: flex; align-items: center; justify-content: center;
                    font-size: 15px; font-weight: 500;
                    flex-shrink: 0;
                }
                .ab_emp_pill {
                    display: inline-flex; align-items: center; gap: 5px;
                    font-size: 11px; font-weight: 500;
                    padding: 3px 10px; border-radius: 999px;
                }
                .ab_emp_pill .ab_dot {
                    width: 6px; height: 6px;
                    border-radius: 50%; background: currentColor;
                }
                .ab_emp_pill.active  { color: #0F6E56; background: #E1F5EE; }
                .ab_emp_pill.inactive { color: #993C1D; background: #FAECE7; }
                .ab_sup_badge {
                    font-size: 11px; font-weight: 500;
                    padding: 3px 9px; border-radius: 999px;
                }
                .ab_sup_direct   { color: #185FA5; background: #E6F1FB; }
                .ab_sup_indirect { color: #3B6D11; background: #EAF3DE; }
                .ab_sup_myself   { color: #993556; background: #FBEAF0; }
                .ab_sup_other    { color: #633806; background: #FAEEDA; }
                .ab_contact_row {
                    display: flex; align-items: center; gap: 8px;
                    font-size: 12px; color: #6b7280;
                    overflow: hidden;
                }
                .ab_contact_row span { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
                .ab_contact_row svg { flex-shrink: 0; }
            </style>

            <div class="oe_kanban_global_click ab_emp_card d-flex flex-column h-100">

                <!-- Top bar: status + employee code -->
                <div class="d-flex justify-content-between align-items-center px-3 py-2" style="border-bottom: 0.5px solid rgba(0,0,0,0.08);">
                    <t t-if="record.is_working.raw_value">
                        <span class="ab_emp_pill active"><span class="ab_dot"/>Active</span>
                    </t>
                    <t t-else="">
                        <span class="ab_emp_pill inactive"><span class="ab_dot"/>Inactive</span>
                    </t>
                    <span class="text-muted fw-medium" style="font-size:11px; letter-spacing:0.04em;">
                        <field name="accid"/>
                    </span>
                </div>

                <!-- Avatar + Name / Job / Dept -->
                <div class="d-flex align-items-center gap-3 px-3 py-3" style="border-bottom: 0.5px solid rgba(0,0,0,0.08);">
                    <div class="ab_emp_avatar">
                        <i class="fa fa-user"/>
                    </div>
                    <div style="min-width:0;">
                        <div class="fw-medium text-truncate" style="font-size:15px; color: var(--color-text-primary, #111);">
                            <field name="name"/>
                        </div>
                        <div class="text-truncate mt-1" style="font-size:12px; color:#6b7280;">
                            <field name="job_id"/>
                        </div>
                        <div class="text-truncate" style="font-size:12px; color:#9ca3af;">
                            <field name="department_id"/>
                        </div>
                    </div>
                </div>

                <!-- Contact info -->
                <div class="d-flex flex-column gap-2 px-3 py-2" style="border-bottom: 0.5px solid rgba(0,0,0,0.08);">
                    <t t-if="record.work_email.raw_value">
                        <div class="ab_contact_row">
                            <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
                                <rect x="2" y="3" width="12" height="10" rx="2" stroke="#9ca3af" stroke-width="1.4"/>
                                <path d="M2 6l6 4 6-4" stroke="#9ca3af" stroke-width="1.4"/>
                            </svg>
                            <span><field name="work_email"/></span>
                        </div>
                    </t>
                    <t t-if="record.work_phone.raw_value">
                        <div class="ab_contact_row">
                            <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
                                <path d="M3 3.5A1.5 1.5 0 014.5 2h.879a1 1 0 01.949.684l.674 2.02a1 1 0 01-.23 1.02L5.5 6.5s1 2 4 4l1.276-1.276a1 1 0 011.02-.23l2.02.674A1 1 0 0114 10.62V11.5A1.5 1.5 0 0112.5 13C6.701 13 3 9.299 3 3.5z" stroke="#9ca3af" stroke-width="1.4"/>
                            </svg>
                            <span><field name="work_phone"/></span>
                        </div>
                    </t>
                    <div class="ab_contact_row">
                        <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
                            <circle cx="8" cy="6" r="3" stroke="#9ca3af" stroke-width="1.4"/>
                            <path d="M2.5 14c0-3.038 2.462-5 5.5-5s5.5 1.962 5.5 5" stroke="#9ca3af" stroke-width="1.4" stroke-linecap="round"/>
                        </svg>
                        <t t-if="record.parent_id.raw_value">
                            <span><field name="parent_id"/></span>
                        </t>
                        <t t-else="">
                            <span style="font-style:italic; color:#c0c0c0;">No manager</span>
                        </t>
                    </div>
                </div>

                <!-- Footer: dates + supervision badge -->
                <div class="d-flex justify-content-between align-items-center px-3 py-2 mt-auto" style="background: rgba(0,0,0,0.02);">
                    <div style="font-size:11px; color:#9ca3af;">
                        <div class="fw-medium" style="color:#6b7280; margin-bottom:1px;">Hired</div>
                        <field name="hiring_date"/>
                    </div>
                    <div style="font-size:11px; color:#9ca3af; text-align:center;">
                        <div class="fw-medium" style="color:#6b7280; margin-bottom:1px;">Issued</div>
                        <field name="issue_date"/>
                    </div>
                    <div>
                        <t t-if="record.supervision_type.raw_value == 'direct'">
                            <span class="ab_sup_badge ab_sup_direct">Direct</span>
                        </t>
                        <t t-elif="record.supervision_type.raw_value == 'indirect'">
                            <span class="ab_sup_badge ab_sup_indirect">Indirect</span>
                        </t>
                        <t t-elif="record.supervision_type.raw_value == 'myself'">
                            <span class="ab_sup_badge ab_sup_myself">Myself</span>
                        </t>
                        <t t-elif="record.supervision_type.raw_value">
                            <span class="ab_sup_badge ab_sup_other"><field name="supervision_type"/></span>
                        </t>
                    </div>
                </div>

            </div>
        </t>
    </templates>
</kanban>
            </field>
        </record>


        <record id="ab_hr_employee_view_tree" model="ir.ui.view">
            <field name="name">ab_hr_employee_view_tree</field>
            <field name="model">ab_hr_employee</field>
            <field name="arch" type="xml">
                <list string="ab_hr_employee_tree">
                    <field name="name" optional="show"/>
                    <field name="costcenter_id" optional="show"/>
                    <field name="mobile_phone" optional="show"/>
                    <field name="work_email" optional="show"/>
                    <field name="user_id" optional="show"/>
                    <field name="work_phone" optional="show"/>
                    <field name="cc_id" optional="show"/>
                    <field name="accid" optional="show"/>
                    <field name="barcode" optional="show"/>
                    <field name="bc_id" optional="show"/>
                    <field name="english_name" optional="show"/>
                    <field name="religion" optional="show"/>
                    <field name="gender" optional="show"/>
                    <field name="identification_id" optional="show"/>
                    <field name="birthday" optional="show"/>
                    <field name="job_id" optional="show"/>
                    <field name="department_id" optional="show"/>
                    <field name="parent_department_id" optional="show"/>
                    <field name="parent_id" optional="show"/>
                    <field name="supervision_type" widget="badge" optional="show"/>
                    <field name="is_working" optional="show"/>
                    <field name="address_text" optional="show"/>
                    <field name="active" optional="show"/>
                    <field name="internal_working_employee" optional="show"/>


                </list>
            </field>
        </record>


        <record id="ab_hr_employee_view_form" model="ir.ui.view">
            <field name="name">ab_hr_employee_view_form</field>
            <field name="model">ab_hr_employee</field>
            <field name="arch" type="xml">
                <form string="Employee">
                    <sheet>
                        <field name="active" invisible="1"/>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                                invisible="active == True"/>
                        <div>
                            <field name="accid" class="h1 text-muted" nolabel="1"/>
                        </div>

                        <div class="oe_title">
                            <field name="user_id" invisible="1"/>
                            <h1 class="d-flex">
                                <field name="name" default_focus="1" placeholder="Employee's Name" required="True"/>
                                <a title="Chat" icon="fa-comments" href="#" class="ml8 o_employee_chat_btn"
                                   invisible="not context.get('chat_icon') or user_id == False" role="button"><i
                                        class="fa fa-comments"/></a>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="mobile_phone" widget="phone"/>
                                <field name="work_phone" widget="phone"/>
                                <field name="work_email" widget="email"/>
                            </group>
                            <group>
                                <field name="job_id"/>
                                <field name="department_id"/>
                                <field name="manual_manager"
                                       groups="ab_hr.group_ab_hr_co"
                                       widget="boolean_toggle"/>
                                <field name="parent_id"/>
                                <field name="supervision_type" widget="badge" readonly="1"/>
                                <field name="parent_department_id" optional="show"/>

                            </group>
                        </group>
                        <notebook>
                            <page string="Main Data">
                                <group>
                                    <group string="Private Info">
                                        <field name="costcenter_id"/>
                                        <field name="english_name"/>
                                        <field name="identification_id"/>
                                        <field name="birthday"/>
                                        <field name="religion"/>
                                        <field name="gender"/>
                                        <field name="address_text"/>
                                        <field name="graduate"/>
                                    </group>
                                    <group string="Accounting Info">
                                        <field name="khazna_subscription"/>
                                        <field name="user_line_owner"/>
                                        <field name="payment_name"/>
                                        <field name="payment_no"/>
                                    </group>
                                    <group string="Account Settings">
                                        <field name="user_id"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Jobs Occupied" name="job_occupied">
                                <field name="job_occupied_ids"
                                       context="{'allow_edit': '1'}"
                                       mode="kanban" readonly="1"/>
                            </page>
                        </notebook>

                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>


        <record id="ab_hr.view_employee_form_spec" model="ir.ui.view">
            <field name="name">ab_hr.view_employee_form_spec</field>
            <field name="model">ab_hr_employee</field>
            <field name="inherit_id" ref="ab_hr.ab_hr_employee_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='job_occupied']" position="after">
                    <page string="Documents"
                          groups="ab_hr.group_ab_hr_personnel_spec,ab_hr.group_ab_hr_co,ab_hr.group_ab_hr_payroll_specialist">
                        <group>
                            <div class="text-right">
                                <label for="is_docs_complete" string="Is Documents Complete"/>
                                <field name="is_docs_complete"/>
                            </div>
                        </group>
                        <group>
                            <field name="emp_doc_status_ids"
                                   context="{'allow_edit': '1'}"
                                   nolabel="1" readonly="1"/>
                        </group>
                    </page>
                    <page string="Insurance Info"
                          groups="ab_hr.group_ab_hr_personnel_spec,ab_hr.group_ab_hr_co,ab_hr.group_ab_hr_payroll_specialist">
                        <field name="insurance_info_ids"/>
                    </page>
                </xpath>

            </field>
        </record>


        <!-- Add to Employee_Form (History) Page-->
        <record id="ab_hr.view_employee_form_history" model="ir.ui.view">
            <field name="name">ab_hr.view_employee_form_history</field>
            <field name="model">ab_hr_employee</field>
            <field name="inherit_id" ref="ab_hr.ab_hr_employee_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='job_occupied']" position="after">
                    <page string="History" groups="ab_hr.group_ab_hr_co,ab_hr.group_ab_hr_payroll_specialist">
                        <field name="emp_history_ids">
                            <list>
                                <field name="job_id" optional="show"/>
                                <field name="old_job_title" optional="show"/>
                                <field name="old_workplace" optional="show"/>
                                <field name="territory" optional="show"/>
                                <field name="action_type" optional="show"/>
                                <field name="action_date" optional="show"/>
                                <field name="issue_date" optional="hide"/>
                                <field name="termination_date" optional="show"/>
                                <field name="notes" optional="hide"/>
                                <field name="alt_job_id" optional="show"/>
                                <field name="new_job_title" optional="show"/>
                                <field name="new_workplace" optional="show"/>
                                <field name="workplace_region" optional="show"/>

                            </list>
                        </field>
                    </page>
                </xpath>

            </field>
        </record>


        <record id="ab_hr_employee_view_search" model="ir.ui.view">
            <field name="name">ab_hr_employee_view_search</field>
            <field name="model">ab_hr_employee</field>
            <field name="arch" type="xml">
                <search string="ab_hr_employee_search">
                    <field name="name" string="Employee"
                           filter_domain="['|', '|',
                           ('name', 'ilike', self),
                           ('mod_name', 'ilike', self),
                           ('costcenter_id.code', '=ilike', self),
                           ]"/>
                    <field name="name" string="Any Employee Data"
                           filter_domain="['|', '|','|',
                           ('work_email', 'ilike', self),
                           ('name', 'ilike', self),
                           ('mod_name', 'ilike', self),
                           ('costcenter_id.code', '=ilike', self),
                           ]"/>
                    <field name="department_id"/>
                    <field name="job_id" string="Job Title"/>
                    <field name="parent_id"/>

                    <filter name="active_employees_only" string="Active Employees"
                            domain="[('is_working','!=',False)]"/>
                    <separator/>

                    <filter name="supervision_type_direct" string="Direct Supervision"
                            domain="[('supervision_type','=','direct')]"/>

                    <filter name="supervision_type_indirect" string="Indirect Supervision"
                            domain="[('supervision_type','=','indirect')]"/>

                    <filter name="supervision_type_indirect_to_subordinate" string="Indirect To Subordinate"
                            domain="[('supervision_type','=','indirect_to_subordinate')]"/>

                    <filter name="supervision_type_myself" string="Myself"
                            domain="[('supervision_type','=','myself')]"/>

                    <searchpanel>
                        <field name="department_id" icon="fa-users" select="multi"/>
                    </searchpanel>
                </search>
            </field>
        </record>
        <record id="ab_hr_employee_view_pivot" model="ir.ui.view">
            <field name="name">ab_hr_employee_view_pivot</field>
            <field name="model">ab_hr_employee</field>
            <field name="arch" type="xml">
                <pivot string="ab_hr_employee_pivot">
                </pivot>
            </field>
        </record>


        <record id="ab_hr_employee_action" model="ir.actions.act_window">
            <field name="name">Employees</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">ab_hr_employee</field>
            <field name="view_mode">kanban,list,form,pivot</field>
        </record>

        <menuitem id="ab_hr_employee_menu"
                  name="Employees"
                  parent="ab_hr_employee_sub_menu"
                  action="ab_hr_employee_action"
                  sequence="10"/>


    </data>
</odoo>
