<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="manpower_view_tree" model="ir.ui.view">
            <field name="name">manpower_view_tree</field>
            <field name="model">ab_hr_manpower</field>
            <field name="arch" type="xml">
                <list string="manpower_tree">
                    <field name="workplace"/>
                    <field name="workplace_region" optional="hide"/>
                    <field name="job_title"/>
                    <field name="territory"/>
                    <field name="op_manpower"/>
                </list>
            </field>
        </record>
        <record id="manpower_view_form" model="ir.ui.view">
            <field name="name">manpower_view_form</field>
            <field name="model">ab_hr_manpower</field>
            <field name="arch" type="xml">
                <form string="manpower_form">
                    <sheet>
                        <group>
                            <field name="workplace"/>
                            <field name="workplace_region"/>
                            <field name="job_title"/>
                            <field name="territory"/>
                            <field name="op_manpower"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="ab_hr_manpower_view_search" model="ir.ui.view">
            <field name="name">ab_hr_manpower_view_search</field>
            <field name="model">ab_hr_manpower</field>
            <field name="arch" type="xml">
                <search string="ab_hr_manpower_search">
                    <field name="workplace"/>
                    <field name="workplace_region"/>
                    <field name="job_title"/>
                    <field name="territory"/>
                    <field name="op_manpower"/>
                </search>
            </field>
        </record>


        <record id="ab_hr_manpower_operation_action" model="ir.actions.act_window">
            <field name="name">ab_hr_manpower.action</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">ab_hr_manpower</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem name="Manpower"
                  parent="manpower_root_menu"
                  id="ab_hr_manpower_operation_menu"
                  action="ab_hr_manpower_operation_action"
                  sequence="39"/>


        <record id="manpower_need_view_tree" model="ir.ui.view">
            <field name="name">manpower_need_view_tree</field>
            <field name="model">ab_hr_manpower_need</field>
            <field name="arch" type="xml">
                <list string="manpower_need_tree">
                    <field name="workplace"/>
                    <field name="workplace_region" optional="hide"/>
                    <field name="job_title"/>
                    <field name="territory"/>
                    <field name="act_manpower" class="text-center"/>
                    <field name="op_manpower" class="text-center"/>
                    <field name="urgent" class="h6 text-danger"/>
                    <field name="need_manpower"
                           class="text-center h4"
                           decoration-danger="need_manpower&lt;0"
                           decoration-info="need_manpower&gt;0"
                    />
                    <field name="can_access_history" invisible="1"/>
                    <button name="btn_history_detail"
                            invisible="can_access_history == False"
                            groups="ab_hr.group_ab_hr_recruiter"
                            type="object" string="History"/>
                </list>
            </field>
        </record>

        <!--  ab_hr_job_occupied_graph -->
        <record model="ir.ui.view" id="ab_hr_manpower_need_graph">
            <field name="name">ab_hr_manpower_need.graph</field>
            <field name="model">ab_hr_manpower_need</field>
            <field name="arch" type="xml">
                <graph string="manpower_need Need Graph">
                    <field name="job_title" type="row"/>
                    <field name="need_manpower" type="measure"/>
                </graph>
            </field>
        </record>

        <!--  ab_hr_manpower -->
        <record model="ir.ui.view" id="ab_hr_manpower">
            <field name="name">ab_hr_manpower_need.pivot</field>
            <field name="model">ab_hr_manpower_need</field>
            <field name="arch" type="xml">
                <pivot string="manpower_need Need pivot">
                    <field name="job_title" type="row"/>
                    <field name="workplace" type="row"/>
                    <field name="territory" type="row"/>
                    <field name="need_manpower" type="measure"/>
                </pivot>
            </field>
        </record>


        <record id="manpower_need_search" model="ir.ui.view">
            <field name="name">manpower_need_search</field>
            <field name="model">ab_hr_manpower_need</field>
            <field name="arch" type="xml">
                <search string="Manpower Need">
                    <field name="workplace"/>
                    <field name="job_title"/>
                    <field name="territory"/>
                    <field name="act_manpower"/>
                    <field name="op_manpower"/>
                    <field name="need_manpower"/>
                    <field name="workplace_region"/>
                    <filter name="filter_req_manpower" string="Required Manpower"
                            domain="[('need_manpower', '!=', 0)]"/>
                    <separator/>
                    <filter name="filter_urgent_manpower" string="Urgent"
                            domain="[('urgent', '!=', False)]"/>

                </search>
            </field>
        </record>

        <record id="ab_hr_manpower_need_action" model="ir.actions.act_window">
            <field name="name">Manpower Need</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">ab_hr_manpower_need</field>
            <field name="view_mode">list,pivot,graph</field>
            <field name="context">
                {"search_default_filter_req_manpower": 1}
            </field>
        </record>
        <menuitem name="Manpower Need"
                  parent="manpower_root_menu"
                  id="ab_hr_manpower_need_menu"
                  action="ab_hr_manpower_need_action"
                  sequence="30"/>

        <record id="manpower_hour_need_view_list" model="ir.ui.view">
            <field name="name">manpower_hour_need_view_list</field>
            <field name="model">ab_hr_manpower_hour_need</field>
            <field name="arch" type="xml">
                <list string="Manpower Need Per Hour" class="o_ab_manpower_hour_list">
                    <field name="workplace"/>
                    <field name="workplace_region" optional="hide"/>
                    <field name="job_title"/>
                    <field name="required_operating_hours" sum="Required Hours"/>
                    <field name="actual_available_hours" sum="Actual Hours"/>
                    <field name="shortage_hours"
                           sum="Shortage Hours"
                           decoration-danger="shortage_hours &gt; 0"/>
                </list>
            </field>
        </record>

        <record id="manpower_hour_need_view_form" model="ir.ui.view">
            <field name="name">manpower_hour_need_view_form</field>
            <field name="model">ab_hr_manpower_hour_need</field>
            <field name="arch" type="xml">
                <form string="Manpower Need Per Hour">
                    <header>
                        <button name="action_fetch_employees"
                                type="object"
                                string="Fetch Employees"
                                class="btn-primary"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="Planning Scope">
                                <field name="workplace"/>
                                <field name="workplace_region"/>
                                <field name="job_title"/>
                            </group>
                            <group string="Manual Planning">
                                <field name="required_operating_hours"/>
                                <field name="default_actual_daily_hours"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Hours Summary">
                                <group>
                                    <group>
                                        <field name="required_operating_hours"/>
                                        <field name="actual_available_hours"/>
                                        <field name="shortage_hours"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Employees">
                                <field name="employee_line_ids" readonly="1">
                                    <list string="Employees">
                                        <field name="employee_id"/>
                                        <field name="user_id"/>
                                        <field name="job_title"/>
                                        <field name="department_id"/>
                                        <field name="actual_hours" sum="Actual Hours"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="manpower_hour_need_view_kanban" model="ir.ui.view">
            <field name="name">manpower_hour_need_view_kanban</field>
            <field name="model">ab_hr_manpower_hour_need</field>
            <field name="arch" type="xml">
                <kanban string="Manpower Need Per Hour" default_group_by="workplace" class="o_ab_manpower_hour_kanban">
                    <field name="workplace"/>
                    <field name="job_title"/>
                    <field name="required_operating_hours"/>
                    <field name="actual_available_hours"/>
                    <field name="shortage_hours"/>
                    <field name="required_hours_label"/>
                    <field name="actual_hours_label"/>
                    <field name="shortage_hours_label"/>
                    <templates>
                        <t t-name="card">
                            <div class="p-2">
                                <div class="d-flex justify-content-between gap-2">
                                    <strong class="text-truncate">
                                        <field name="job_title"/>
                                    </strong>
                                    <span t-att-class="record.shortage_hours.raw_value ? 'badge text-bg-danger' : 'badge text-bg-success'">
                                        <field name="shortage_hours"/>
                                    </span>
                                </div>
                                <div class="text-muted small mt-1">
                                    <field name="workplace"/>
                                </div>
                                <div class="d-grid gap-1 mt-3">
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted">
                                            <field name="required_hours_label"/>
                                        </span>
                                        <strong><field name="required_operating_hours"/></strong>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted">
                                            <field name="actual_hours_label"/>
                                        </span>
                                        <strong><field name="actual_available_hours"/></strong>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted">
                                            <field name="shortage_hours_label"/>
                                        </span>
                                        <strong t-att-class="record.shortage_hours.raw_value ? 'text-danger' : 'text-success'">
                                            <field name="shortage_hours"/>
                                        </strong>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="manpower_hour_need_view_pivot" model="ir.ui.view">
            <field name="name">manpower_hour_need_view_pivot</field>
            <field name="model">ab_hr_manpower_hour_need</field>
            <field name="arch" type="xml">
                <pivot string="Manpower Need Per Hour">
                    <field name="workplace" type="row"/>
                    <field name="job_title" type="row"/>
                    <field name="required_operating_hours" type="measure"/>
                    <field name="actual_available_hours" type="measure"/>
                    <field name="shortage_hours" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="manpower_hour_need_view_graph" model="ir.ui.view">
            <field name="name">manpower_hour_need_view_graph</field>
            <field name="model">ab_hr_manpower_hour_need</field>
            <field name="arch" type="xml">
                <graph string="Manpower Need Per Hour">
                    <field name="workplace" type="row"/>
                    <field name="job_title" type="col"/>
                    <field name="shortage_hours" type="measure"/>
                </graph>
            </field>
        </record>

        <record id="manpower_hour_need_search" model="ir.ui.view">
            <field name="name">manpower_hour_need_search</field>
            <field name="model">ab_hr_manpower_hour_need</field>
            <field name="arch" type="xml">
                <search string="Manpower Need Per Hour">
                    <field name="workplace"/>
                    <field name="workplace_region"/>
                    <field name="job_title"/>
                    <filter name="filter_shortage" string="Shortage" domain="[('shortage_hours', '&gt;', 0)]"/>
                    <separator/>
                    <filter name="group_workplace" string="Branch" context="{'group_by': 'workplace'}"/>
                    <filter name="group_job_title" string="Job Title" context="{'group_by': 'job_title'}"/>
                    <filter name="group_region" string="Region" context="{'group_by': 'workplace_region'}"/>
                </search>
            </field>
        </record>

        <record id="ab_hr_manpower_hour_need_action" model="ir.actions.act_window">
            <field name="name">Manpower Need Per Hour</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">ab_hr_manpower_hour_need</field>
            <field name="view_mode">kanban,list,pivot,graph,form</field>
            <field name="context">{'search_default_group_workplace': 1}</field>
        </record>

        <menuitem name="Manpower Need Per Hour"
                  parent="manpower_root_menu"
                  id="ab_hr_manpower_hour_need_menu"
                  action="ab_hr_manpower_hour_need_action"
                  sequence="35"/>

        <delete model="ir.ui.menu"
                search="[('name', '=', 'Manpower Hour Dashboard'), ('parent_id', '=', ref('manpower_root_menu'))]"/>
        <delete model="ir.actions.client"
                search="[('tag', '=', 'ab_hr_manpower_hour_need_dashboard')]"/>

    </data>
</odoo>
