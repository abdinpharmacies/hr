#. module: ab_hr
#: model_terms:ir.ui.view,arch_db:ab_hr.view_ab_hr_payroll_sheet_upload_wizard_form
msgid ""
"<strong>File format:</strong>\n"
"                            Upload PDF or XLSX files named like\n"
"                            <code>Employee_Full_Name_1234_Department.pdf</code>.\n"
"                            ZIP files are accepted for bulk upload and should contain PDF/XLSX files with the same naming format.\n"
"                            The employee HR code can appear after the employee full name.\n"
"                            Duplicate validation is applied per payroll period and payroll type."
msgstr ""
"<strong>صيغة الملف:</strong>\n"
"                            ارفع ملفات PDF أو XLSX بأسماء مثل\n"
"                            <code>اسم_الموظف_الكامل_1234_الإدارة.pdf</code>.\n"
"                            يتم قبول ملفات ZIP للرفع المجمع ويجب أن تحتوي على ملفات PDF/XLSX بنفس صيغة التسمية.\n"
"                            يمكن أن يظهر كود الموظف لدى الموارد البشرية بعد اسم الموظف الكامل.\n"
"                            يتم تطبيق التحقق من التكرار حسب فترة الرواتب ونوع شيت الراتب."

