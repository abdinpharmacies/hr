<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
    1. name= must be like the name of Abtract Model that contains generate_xlsx_report

    class QueryXLS(models.AbstractModel):
        _name = 'report.ab_hr_salary_details_report_model'

    2. file= name of exported excel file

    4. model= the name of model or table which we call "action.report_action(self)" in
    -->
    <record id="ab_hr_salary_details_report" model="ir.actions.report">
        <field name="model">ab_hr_action_wizard</field>
        <field name="name">Salaries Report</field>
        <field name="report_name">ab_hr_salary_details_report_model</field>
        <field name="report_type">xlsx</field>
        <field name="binding_model_id" eval="False"/>
    </record>

</odoo>
