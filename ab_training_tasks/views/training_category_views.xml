<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_training_category_list" model="ir.ui.view">
            <field name="name">ab.training.task.category.list</field>
            <field name="model">ab.training.task.category</field>
            <field name="arch" type="xml">
                <list string="Material Categories" default_order="sequence, name">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="task_type_ids" widget="many2many_tags" optional="show"/>
                    <field name="active" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_training_category_form" model="ir.ui.view">
            <field name="name">ab.training.task.category.form</field>
            <field name="model">ab.training.task.category</field>
            <field name="arch" type="xml">
                <form string="Material Category" class="ab_training_core_form core_ui_form_modern">
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1><field name="name" placeholder="e.g. Training Manual"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="company_id" groups="base.group_multi_company"/>
                                <field name="sequence"/>
                                <field name="active" widget="boolean_toggle"/>
                            </group>
                        </group>
                        <group string="Allowed File Types" class="ab_training_upload_types">
                            <group>
                                <field name="allow_image_files" widget="boolean_toggle"/>
                                <field name="allow_pdf_files" widget="boolean_toggle"/>
                                <field name="allow_ppt_files" widget="boolean_toggle"/>
                            </group>
                            <group>
                                <field name="allow_video_files" widget="boolean_toggle"/>
                                <field name="allow_audio_files" widget="boolean_toggle"/>
                            </group>
                        </group>
                        <group string="Description" col="1" class="ab_training_wide_text_group">
                            <field name="description" nolabel="1" class="ab_training_textarea_wide"
                                   placeholder="Describe the material category..."/>
                        </group>
                        <notebook>
                            <page string="Task Types" name="task_types">
                                <field name="task_type_ids" context="{'default_category_id': id}">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="title"/>
                                        <field name="incentive_value" widget="monetary"/>
                                        <field name="currency_id" column_invisible="True"/>
                                        <field name="active" widget="boolean_toggle"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
