<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_training_task_type_list" model="ir.ui.view">
            <field name="name">ab.training.task.type.list</field>
            <field name="model">ab.training.task.type</field>
            <field name="arch" type="xml">
                <list string="Task Types" default_order="category_id, sequence, title">
                    <field name="sequence" widget="handle"/>
                    <field name="title"/>
                    <field name="category_id" string="Material Category"/>
                    <field name="incentive_value" widget="monetary" sum="Total Incentive"/>
                    <field name="currency_id" column_invisible="True"/>
                    <field name="company_id" groups="base.group_multi_company" optional="hide"/>
                    <field name="active" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_training_task_type_form" model="ir.ui.view">
            <field name="name">ab.training.task.type.form</field>
            <field name="model">ab.training.task.type</field>
            <field name="arch" type="xml">
                <form string="Task Type" class="ab_training_core_form core_ui_form_modern">
                    <sheet>
                        <div class="oe_title">
                            <label for="title"/>
                            <h1><field name="title" placeholder="e.g. Update product training slides"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="category_id"
                                       string="Material Category"
                                       options="{'no_create_edit': True}"/>
                                <field name="incentive_value" widget="monetary"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                            <group>
                                <field name="sequence"/>
                                <field name="active" widget="boolean_toggle"/>
                                <field name="company_id" groups="base.group_multi_company" readonly="1"/>
                            </group>
                        </group>
                        <group string="Guidance" col="1" class="ab_training_wide_text_group">
                            <field name="description" nolabel="1" class="ab_training_textarea_wide"
                                   placeholder="Explain when members should use this task type..."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
