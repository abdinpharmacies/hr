<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_training_task_reject_wizard_form" model="ir.ui.view">
            <field name="name">ab.training.task.reject.wizard.form</field>
            <field name="model">ab.training.task.reject.wizard</field>
            <field name="arch" type="xml">
                <form string="Reject Training Task" class="ab_training_core_form core_ui_form_modern">
                    <div class="core_ui_alert danger">
                        <i class="fa fa-ban" title="Reject"/>
                        <div class="core_ui_alert_content">
                            <div class="core_ui_alert_title">Rejection requires a reason</div>
                            The member will see this reason and can correct and resubmit the task.
                        </div>
                    </div>
                    <group>
                        <field name="task_id" readonly="1"/>
                    </group>
                    <group string="Rejection Reason" col="1" class="ab_training_wide_text_group">
                        <field name="reason" nolabel="1" class="ab_training_textarea_wide"
                               placeholder="Explain what must be corrected..."/>
                    </group>
                    <footer>
                        <button name="action_reject" type="object" string="Reject Task" icon="fa-ban"
                                class="core_ui_btn core_ui_btn_danger"/>
                        <button string="Cancel" special="cancel" icon="fa-times"
                                class="core_ui_btn core_ui_btn_secondary"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
