<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="category_training_tasks" model="ir.module.category">
            <field name="name">Training Tasks</field>
            <field name="sequence" eval="35"/>
        </record>

        <record id="privilege_training_tasks" model="res.groups.privilege">
            <field name="name">Training Tasks</field>
            <field name="category_id" ref="category_training_tasks"/>
            <field name="sequence" eval="35"/>
        </record>

        <record id="group_training_tasks_member" model="res.groups">
            <field name="name">Training Member</field>
            <field name="privilege_id" ref="privilege_training_tasks"/>
        </record>

        <record id="group_training_tasks_manager" model="res.groups">
            <field name="name">Training Manager</field>
            <field name="implied_ids" eval="[(4, ref('ab_training_tasks.group_training_tasks_member'))]"/>
            <field name="privilege_id" ref="privilege_training_tasks"/>
        </record>

        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('ab_training_tasks.group_training_tasks_manager'))]"/>
        </record>
    </data>
</odoo>
