<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="ab_product_source_view_tree" model="ir.ui.view">
            <field name="name">ab_product_source_view_tree</field>
            <field name="model">ab_product_source</field>
            <field name="arch" type="xml">
                <list string="ab_product_source_tree" multi_edit="1">
                    <field name="id" optional="show" class="text-muted"/>
                    <field name="product_code" optional="show"/>
                    <field name="product_id" optional="show"/>
                    <field name="uom_id" optional="show"/>
                    <field name="qty" optional="show"/>
                    <field name="purchase_price" optional="show"/>
                    <field name="taxes_ids" optional="show"/>
                    <field name="unit_cost" optional="show"/>
                    <field name="price" optional="show"/>
                    <field name="extra_discount_percentage" optional="show"/>
                    <field name="exp_date" optional="show"/>
                </list>
            </field>
        </record>

        <record id="ab_product_source_view_form" model="ir.ui.view">
            <field name="name">ab_product_source_view_form</field>
            <field name="model">ab_product_source</field>
            <field name="arch" type="xml">
                <form string="ab_product_source_form">
                    <sheet>
                        <group col="4">
                            <field name="product_code"/>
                            <field name="product_id"/>
                            <field name="uom_id"/>
                            <field name="qty"/>
                            <field name="purchase_price"/>
                            <field name="taxes_ids"/>
                            <field name="unit_cost"/>
                            <field name="price"/>
                            <field name="extra_discount_percentage"/>
                            <field name="exp_date"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="ab_product_source_view_search" model="ir.ui.view">
            <field name="name">ab_product_source_view_search</field>
            <field name="model">ab_product_source</field>
            <field name="arch" type="xml">
                <search string="ab_product_source_search">
                    <field name="product_id"/>
                    <field name="qty"/>
                    <field name="unit_cost"/>
                    <field name="price"/>
                    <field name="purchase_price"/>
                    <field name="exp_date"/>
                </search>
            </field>
        </record>
        <record id="ab_product_source_view_pivot" model="ir.ui.view">
            <field name="name">ab_product_source_view_pivot</field>
            <field name="model">ab_product_source</field>
            <field name="arch" type="xml">
                <pivot string="ab_product_source_pivot">
                </pivot>
            </field>
        </record>


        <record id="ab_product_source_action" model="ir.actions.act_window">
            <field name="name">Ab product source</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">ab_product_source</field>
            <field name="view_mode">list,form,pivot</field>
        </record>

        <!--
                <menuitem id="ab_product_source_menu"
                          name="Product Source"
                          parent="men"
                          action="ab_product_source_action"
                          sequence="100"/>
        -->


    </data>
</odoo>