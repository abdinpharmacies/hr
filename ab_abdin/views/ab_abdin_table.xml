<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

       <record id="ab_abdin_table_view_list" model="ir.ui.view">
           <field name="name">ab_abdin_table_view_list</field>
           <field name="model">ab_abdin_table</field>
           <field name="arch" type="xml">
               <list string="ab_abdin_table_list" multi_edit="1">
                   <field name="name" optional="show"/>
                   <field name="myint" optional="show"/>
                   <field name="value" optional="show"/>
               </list>
           </field>
       </record>

       <record id="ab_abdin_table_view_form" model="ir.ui.view">
           <field name="name">ab_abdin_table_view_form</field>
           <field name="model">ab_abdin_table</field>
           <field name="arch" type="xml">
               <form string="ab_abdin_table_form">
                   <sheet>
                       <group>
                           <field name="name"/>
                           <field name="myint"/>
                           <field name="value"/>
                       </group>
                   </sheet>
               </form>
           </field>
       </record>
       <record id="ab_abdin_table_view_search" model="ir.ui.view">
           <field name="name">ab_abdin_table_view_search</field>
           <field name="model">ab_abdin_table</field>
           <field name="arch" type="xml">
               <search string="ab_abdin_table_search">
                           <field name="name"/>
                           <field name="myint"/>
                           <field name="value"/>
               </search>
           </field>
       </record>
       <record id="ab_abdin_table_view_pivot" model="ir.ui.view">
           <field name="name">ab_abdin_table_view_pivot</field>
           <field name="model">ab_abdin_table</field>
           <field name="arch" type="xml">
               <pivot string="ab_abdin_table_pivot">
               </pivot>
           </field>
       </record>


       <record id="ab_abdin_table_action" model="ir.actions.act_window">
           <field name="name">Ab abdin table</field>
           <field name="type">ir.actions.act_window</field>
           <field name="res_model">ab_abdin_table</field>
           <field name="view_mode">list,form,pivot</field>
       </record>

       <menuitem id="ab_abdin_table_menu"
       name="Abdin Menu"
       parent="menu_root"
       action="ab_abdin_table_action"
       sequence="100"/>


    </data>
</odoo>