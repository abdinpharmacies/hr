<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="product_template_form_view_inherit_ab_product" model="ir.ui.view">
            <field name="name">product.template.form.ab.product</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="website_sale.product_template_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='extra_info']" position="inside">
                    <field name="ab_product_id" readonly="1"/>
                    <field name="eplus_stock_shown_qty_type"
                           groups="base.group_user"
                           invisible="not ab_product_id"/>
                    <field name="eplus_stock_shown_qty_value"
                           groups="base.group_user"
                           invisible="not ab_product_id"/>
                </xpath>
                <xpath expr="//page[@name='sales']" position="after">
                    <page string="Eplus Stock" name="eplus_stock" groups="base.group_user" invisible="not ab_product_id">
                        <group>
                            <group string="Snapshot Summary">
                                <field name="ab_product_id" readonly="1"/>
                                <field name="eplus_stock_item_count" readonly="1"/>
                                <field name="eplus_stock_total_qty" readonly="1"/>
                            </group>
                            <group string="Actions">
                                <button name="action_refresh_eplus_stock_items"
                                        type="object"
                                        string="Refresh Eplus Stock"
                                        groups="base.group_user"
                                        class="btn-primary"/>
                                <button name="action_open_eplus_stock_items"
                                        type="object"
                                        string="Open Eplus Stock"
                                        groups="base.group_user"
                                        class="btn-secondary"
                                        invisible="not eplus_stock_item_count"/>
                            </group>
                        </group>
                        <field name="eplus_stock_snapshot_ids" readonly="1" nolabel="1">
                            <list string="Eplus Stock" create="0" edit="0" delete="0">
                                <field name="itm_id"/>
                                <field name="itm_code"/>
                                <field name="itm_qty" sum="Total Quantity"/>
                                <field name="product_id"/>
                                <field name="matched_by"/>
                                <field name="last_sync_date"/>
                            </list>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
