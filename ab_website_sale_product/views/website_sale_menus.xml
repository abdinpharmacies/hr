<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_ab_products_ecommerce_sync" model="ir.actions.act_window">
            <field name="name">Abdin Products</field>
            <field name="res_model">ab_product</field>
            <field name="path">ecommerce-abdin-products</field>
            <field name="view_mode">list,form,pivot</field>
            <field name="domain">[('active', '=', True), ('allow_sale', '=', True)]</field>
            <field name="context">{
                'search_default_filter_website_sale_available': 1,
                'search_default_filter_website_not_synced': 1
            }</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No Abdin products to sync
                </p>
                <p>
                    Select products here, then use Action &gt; Sync to eCommerce.
                </p>
            </field>
        </record>

        <menuitem id="menu_catalog_abdin_products"
                  name="Abdin Products"
                  parent="website_sale.menu_catalog"
                  action="action_ab_products_ecommerce_sync"
                  sequence="2"/>
    </data>
</odoo>
