<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ab_product_tree_view_inherit_website_sale" model="ir.ui.view">
            <field name="name">ab.product.list.website.sale</field>
            <field name="model">ab_product</field>
            <field name="inherit_id" ref="ab_product.ab_product_view_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='code']" position="after">
                    <field name="website_sale_available" optional="hide"/>
                    <field name="website_product_synced" optional="hide"/>
                    <field name="website_product_tmpl_id" optional="hide"/>
                    <field name="website_product_is_published" optional="hide"/>
                </xpath>
            </field>
        </record>

        <record id="ab_product_search_view_inherit_website_sale" model="ir.ui.view">
            <field name="name">ab.product.search.website.sale</field>
            <field name="model">ab_product</field>
            <field name="inherit_id" ref="ab_product.ab_product_view_search"/>
            <field name="arch" type="xml">
                <xpath expr="//search" position="inside">
                    <field name="website_product_tmpl_id"/>
                    <filter name="filter_website_sale_available"
                            string="Website Available"
                            domain="[('website_sale_available', '=', True)]"/>
                    <filter name="filter_website_not_synced"
                            string="Not Synced"
                            domain="[('website_product_synced', '=', False)]"/>
                    <filter name="filter_website_synced"
                            string="Synced"
                            domain="[('website_product_synced', '=', True)]"/>
                    <filter name="filter_website_published"
                            string="Published"
                            domain="[('website_product_is_published', '=', True)]"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
