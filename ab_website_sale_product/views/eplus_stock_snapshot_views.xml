<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ab_eplus_stock_snapshot_view_list" model="ir.ui.view">
        <field name="name">ab.eplus.stock.snapshot.list</field>
        <field name="model">ab_eplus_stock_snapshot</field>
        <field name="arch" type="xml">
            <list string="Eplus Stock" create="0" edit="0" delete="0">
                <header>
                    <button name="action_refresh_from_eplus"
                            type="object"
                            string="Refresh from Eplus"
                            class="btn-primary"
                            display="always"/>
                </header>
                <field name="itm_id"/>
                <field name="itm_code"/>
                <field name="itm_qty" sum="Total Quantity"/>
                <field name="product_id"/>
                <field name="product_code" optional="hide"/>
                <field name="matched_by"/>
                <field name="last_sync_date"/>
            </list>
        </field>
    </record>

    <record id="ab_eplus_stock_snapshot_view_form" model="ir.ui.view">
        <field name="name">ab.eplus.stock.snapshot.form</field>
        <field name="model">ab_eplus_stock_snapshot</field>
        <field name="arch" type="xml">
            <form string="Eplus Stock" create="0" edit="0" delete="0">
                <header>
                    <button name="action_refresh_from_eplus"
                            type="object"
                            string="Refresh from Eplus"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="itm_id"/>
                            <field name="itm_code"/>
                            <field name="itm_qty"/>
                            <field name="last_sync_date"/>
                        </group>
                        <group>
                            <field name="product_id"/>
                            <field name="product_code"/>
                            <field name="product_name"/>
                            <field name="matched_by"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="ab_eplus_stock_snapshot_view_search" model="ir.ui.view">
        <field name="name">ab.eplus.stock.snapshot.search</field>
        <field name="model">ab_eplus_stock_snapshot</field>
        <field name="arch" type="xml">
            <search string="Eplus Stock">
                <field name="itm_id"/>
                <field name="itm_code"/>
                <field name="product_id"/>
                <filter name="filter_matched"
                        string="Matched"
                        domain="[('product_id', '!=', False)]"/>
                <filter name="filter_unmatched"
                        string="Unmatched"
                        domain="[('product_id', '=', False)]"/>
                <separator/>
                <filter name="group_matched_by"
                        string="Match Type"
                        context="{'group_by': 'matched_by'}"/>
            </search>
        </field>
    </record>

    <record id="action_ab_eplus_stock_snapshot" model="ir.actions.act_window">
        <field name="name">Eplus Stock</field>
        <field name="res_model">ab_eplus_stock_snapshot</field>
        <field name="path">ecommerce-eplus-stock</field>
        <field name="view_mode">list,form,pivot</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Eplus stock snapshot yet
            </p>
            <p>
                Use Refresh from Eplus to load the latest stock query results.
            </p>
        </field>
    </record>
</odoo>
