<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ab_product_kanban_abdin_ecommerce" model="ir.ui.view">
        <field name="name">ab.product.kanban.abdin.ecommerce</field>
        <field name="model">ab_product</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <kanban class="abdin_ecommerce_kanban_ecommerce">
                <header>
                    <button name="action_open_add_many_by_codes_wizard"
                            type="object"
                            string="Add Many By Codes"
                            class="btn-secondary"
                            display="always"/>
                </header>
                <field name="id"/>
                <field name="name"/>
                <field name="code"/>
                <field name="default_price"/>
                <field name="active"/>
                <field name="website_sale_available"/>
                <field name="website_product_synced"/>
                <field name="website_product_is_published"/>
                <field name="website_product_tmpl_id"/>
                <field name="website_product_image"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card abdin_ecommerce_card">
                            <div class="abdin_ecommerce_card_image_section">
                                <div class="abdin_ecommerce_image_wrapper">
                                    <t t-if="record.website_product_image.raw_value">
                                        <img t-att-src="'/web/image/ab_product/' + record.id.raw_value + '/website_product_image'"
                                             alt="Product" style="width:100%;height:100%;object-fit:cover;display:block;"/>
                                    </t>
                                    <t t-else="">
                                        <div class="abdin_ecommerce_icon_placeholder">
                                            <i class="fa fa-cube" title="Product"/>
                                        </div>
                                    </t>
                                </div>
                                <span class="abdin_ecommerce_ribbon abdin_ecommerce_ribbon_published"
                                      t-if="record.website_product_is_published.raw_value">
                                    Published
                                </span>
                                <span class="abdin_ecommerce_ribbon abdin_ecommerce_ribbon_synced"
                                      t-if="!record.website_product_is_published.raw_value and record.website_product_synced.raw_value">
                                    Synced
                                </span>
                                <span class="abdin_ecommerce_ribbon abdin_ecommerce_ribbon_new"
                                      t-if="!record.website_product_synced.raw_value and record.website_sale_available.raw_value">
                                    Ready
                                </span>
                                <div class="abdin_ecommerce_dropdown_container">
                                    <div class="o_dropdown_kanban dropdown">
                                        <span class="o_kanban_dropdown_arrow" role="button" tabindex="0" aria-label="Actions">
                                            <i class="fa fa-ellipsis-v" title="Actions"/>
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="abdin_ecommerce_card_body">
                                <div class="abdin_ecommerce_code_row">
                                    <span t-attf-class="abdin_ecommerce_code_badge #{record.active.raw_value ? 'abdin_ecommerce_active' : 'abdin_ecommerce_inactive'}">
                                        <field name="code"/>
                                    </span>
                                    <span t-attf-class="abdin_ecommerce_status_dot #{record.website_product_is_published.raw_value ? 'abdin_ecommerce_published' : (record.website_product_synced.raw_value ? 'abdin_ecommerce_synced' : 'abdin_ecommerce_pending')}" aria-hidden="true"/>
                                </div>
                                <div class="abdin_ecommerce_product_name">
                                    <field name="name"/>
                                </div>
                                <div class="abdin_ecommerce_price_row">
                                    <span class="abdin_ecommerce_price_currency">EGP</span>
                                    <span class="abdin_ecommerce_price_value">
                                        <field name="default_price"/>
                                    </span>
                                </div>
                                <div class="abdin_ecommerce_meta_row">
                                    <span t-attf-class="abdin_ecommerce_availability #{record.active.raw_value ? 'abdin_ecommerce_in_stock' : 'abdin_ecommerce_out_of_stock'}">
                                        <t t-if="record.active.raw_value">
                                            <i class="fa fa-check-circle" title="Active"/>
                                            Active
                                        </t>
                                        <t t-else="">
                                            <i class="fa fa-ban" title="Inactive"/>
                                            Inactive
                                        </t>
                                    </span>
                                    <span t-attf-class="abdin_ecommerce_sync_indicator #{record.website_product_synced.raw_value ? 'abdin_ecommerce_done' : 'abdin_ecommerce_idle'}">
                                        <i class="fa fa-cloud" title="Sync status"/>
                                        <t t-if="record.website_product_synced.raw_value">Synced</t>
                                        <t t-else="">Pending</t>
                                    </span>
                                </div>
                            </div>
                            <div class="abdin_ecommerce_card_footer">
                                <button name="action_sync_website_product" type="object"
                                        class="btn abdin_ecommerce_btn abdin_ecommerce_btn_sync"
                                        title="Sync to eCommerce"
                                        aria-label="Sync to eCommerce">
                                    <i class="fa fa-refresh" title="Sync"/>
                                    <span>Sync</span>
                                </button>
                                <button name="action_open_website_product" type="object"
                                        class="btn abdin_ecommerce_btn abdin_ecommerce_btn_edit"
                                        invisible="not website_product_tmpl_id"
                                        title="Edit eCommerce product"
                                        aria-label="Edit eCommerce product">
                                    <i class="fa fa-pencil" title="Edit"/>
                                    <span>Edit</span>
                                </button>
                                <button name="action_open_website_product_page" type="object"
                                        class="btn abdin_ecommerce_btn abdin_ecommerce_btn_view"
                                        invisible="not website_product_is_published"
                                        title="View on website"
                                        aria-label="View on website">
                                    <i class="fa fa-external-link" title="View"/>
                                    <span>View</span>
                                </button>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>
