<?xml version="1.0" encoding="UTF-8"?>

<templates>
    <t t-name="ab_website_sale_product.product_availability"
       t-inherit="website_sale_stock.product_availability"
       t-inherit-mode="extension">
        <xpath expr="//div[@id='threshold_message']" position="replace">
            <t/>
        </xpath>
        <xpath expr="//div[@id='product_stock_availability']/div[1]" position="before">
            <div
                t-if="free_qty gte 0 or free_qty lt 0"
                id="ab_product_stock_quantity_message"
                t-attf-class="availability_message_#{product_template} my-3 badge text-bg-warning"
            >
                <i class="fa fa-circle text-warning me-2" role="presentation"/>
                Units in Stock: <t t-out="formatQuantity(free_qty)"/>
                <span
                    id="already_in_cart_message"
                    t-if="!allow_out_of_stock_order and cart_qty"
                    t-attf-class="availability_message_#{product_template}"
                >
                    <t t-if="!free_qty">
                        You already added all the available product in your cart
                    </t>
                    <t t-else="">
                        (<t t-out="cart_qty" /> in your cart)
                    </t>
                </span>
            </div>
        </xpath>
    </t>
</templates>
