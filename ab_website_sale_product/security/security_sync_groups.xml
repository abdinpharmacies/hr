<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_category_ab_website_sale_product" model="ir.module.category">
            <field name="name">Abdin Website Sale Products</field>
            <field name="sequence">30</field>
        </record>

        <record id="privilege_ab_website_sale_product_sync" model="res.groups.privilege">
            <field name="name">eCommerce Product Sync</field>
            <field name="category_id" ref="module_category_ab_website_sale_product"/>
        </record>

        <record id="group_ab_website_sale_product_sync_many" model="res.groups">
            <field name="name">Sync Many Products</field>
            <field name="privilege_id" ref="privilege_ab_website_sale_product_sync"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>
