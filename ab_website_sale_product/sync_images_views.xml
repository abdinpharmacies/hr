<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_sync_images_wizard_form" model="ir.ui.view">
            <field name="name">ab.website.sale.sync.images.wizard.form</field>
            <field name="model">ab.website.sale.add.many.by.codes.wizard</field>
            <field name="arch" type="xml">
                <form string="Sync Images">
                    <sheet>
                        <group>
                            <field name="directory_path"
                                   required="1"
                                   placeholder="/opt/odoo19/product_images"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_sync_images" type="object" string="Sync Images" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="view_add_many_by_codes_wizard_form_require_codes" model="ir.ui.view">
            <field name="name">ab.website.sale.add.many.by.codes.wizard.require.codes</field>
            <field name="model">ab.website.sale.add.many.by.codes.wizard</field>
            <field name="inherit_id" ref="ab_website_sale_product.view_add_many_by_codes_wizard_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='codes_text']" position="attributes">
                    <attribute name="required">1</attribute>
                </xpath>
            </field>
        </record>

        <record id="ab_product_tree_view_sync_images" model="ir.ui.view">
            <field name="name">ab.product.list.sync.images</field>
            <field name="model">ab_product</field>
            <field name="inherit_id" ref="ab_website_sale_product.ab_product_tree_view_add_many_by_codes"/>
            <field name="arch" type="xml">
                <xpath expr="//header/button[@name='action_open_add_many_by_codes_wizard']" position="after">
                    <button name="action_open_sync_images_wizard"
                            type="object"
                            string="Sync Images"
                            class="btn-secondary"
                            display="always"/>
                </xpath>
            </field>
        </record>

        <record id="view_ab_product_kanban_sync_images" model="ir.ui.view">
            <field name="name">ab.product.kanban.sync.images</field>
            <field name="model">ab_product</field>
            <field name="inherit_id" ref="ab_website_sale_product.view_ab_product_kanban_abdin_ecommerce"/>
            <field name="arch" type="xml">
                <xpath expr="//kanban/header/button[@name='action_open_add_many_by_codes_wizard']" position="after">
                    <button name="action_open_sync_images_wizard"
                            type="object"
                            string="Sync Images"
                            class="btn-secondary"
                            display="always"/>
                </xpath>
            </field>
        </record>

        <record id="ab_product_form_view_sync_images" model="ir.ui.view">
            <field name="name">ab.product.form.sync.images</field>
            <field name="model">ab_product</field>
            <field name="inherit_id" ref="ab_website_sale_product.ab_product_form_view_professional"/>
            <field name="arch" type="xml">
                <xpath expr="//group[field[@name='website_product_tmpl_id']]/field[@name='website_product_tmpl_id']" position="after">
                    <field name="website_image_file_found"/>
                    <field name="website_image_file_path" invisible="not website_image_file_found"/>
                </xpath>
                <xpath expr="//div[contains(@class, 'abdin_ecommerce_page_actions')]/button[@name='action_open_website_product_page']" position="after">
                    <button name="action_check_website_product_image" type="object"
                            class="btn abdin_ecommerce_btn_outline btn-block"
                            title="Check Image File">
                        <i class="fa fa-image" title="Image"/>
                        Check Image File
                    </button>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
