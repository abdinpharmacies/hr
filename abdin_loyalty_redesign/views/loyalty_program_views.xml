<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         KANBAN VIEW — Premium campaign card deck
         ================================================================ -->
    <record id="abdin_loyalty_program_view_kanban" model="ir.ui.view">
        <field name="name">abdin.loyalty.program.view.kanban</field>
        <field name="model">loyalty.program</field>
        <field name="priority">200</field>
        <field name="arch" type="xml">
            <kanban class="abdin_loyalty_kanban" default_group_by="program_type">
                <field name="id"/>
                <field name="name"/>
                <field name="program_type"/>
                <field name="coupon_count_display"/>
                <field name="total_order_count"/>
                <field name="active"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="limit_usage"/>
                <field name="max_usage"/>
                <field name="ecommerce_ok"/>
                <field name="sale_ok"/>
                <templates>
                    <t t-name="card">
                        <div class="abdin_loyalty_card"
                             t-att-class="'abdin_loyalty_card abdin_loyalty_type_' + record.program_type.raw_value + (record.active.raw_value ? '' : ' abdin_loyalty_card_archived')">
                            <!-- Top accent bar -->
                            <div class="abdin_loyalty_card_accent"/>

                            <!-- Card header: icon + badge -->
                            <div class="abdin_loyalty_card_header">
                                <div class="abdin_loyalty_card_icon" t-attf-class="abdin_loyalty_card_icon abdin_loyalty_icon_{{ record.program_type.raw_value }}">
                                    <t t-if="record.program_type.raw_value === 'coupons'">
                                        <i class="fa fa-ticket" title="Coupons"/>
                                    </t>
                                    <t t-elif="record.program_type.raw_value === 'promo_code'">
                                        <i class="fa fa-percent" title="Promo Code"/>
                                    </t>
                                    <t t-elif="record.program_type.raw_value === 'promotion'">
                                        <i class="fa fa-star" title="Promotion"/>
                                    </t>
                                    <t t-elif="record.program_type.raw_value === 'buy_x_get_y'">
                                        <i class="fa fa-gift" title="BOGO"/>
                                    </t>
                                    <t t-elif="record.program_type.raw_value === 'loyalty'">
                                        <i class="fa fa-id-card" title="Loyalty"/>
                                    </t>
                                    <t t-elif="record.program_type.raw_value === 'gift_card'">
                                        <i class="fa fa-credit-card" title="Gift Card"/>
                                    </t>
                                    <t t-elif="record.program_type.raw_value === 'ewallet'">
                                        <i class="fa fa-wallet" title="eWallet"/>
                                    </t>
                                    <t t-else="">
                                        <i class="fa fa-tag" title="Program"/>
                                    </t>
                                </div>
                                <span class="abdin_loyalty_badge" t-attf-class="abdin_loyalty_badge abdin_loyalty_badge_{{ record.program_type.raw_value }}">
                                    <t t-esc="record.program_type.raw_value.replace('_', ' ').replace('buy x get y', 'BOGO')"/>
                                </span>
                            </div>

                            <!-- Card body -->
                            <div class="abdin_loyalty_card_body">
                                <div class="abdin_loyalty_card_name">
                                    <field name="name"/>
                                </div>

                                <!-- Status indicators row -->
                                <div class="abdin_loyalty_card_status_row">
                                    <span class="abdin_loyalty_status_dot"
                                          t-att-class="'abdin_loyalty_status_dot ' + (record.active.raw_value ? 'abdin_loyalty_status_active' : 'abdin_loyalty_status_inactive')"/>
                                    <span class="abdin_loyalty_status_text"
                                          t-if="record.active.raw_value">Active</span>
                                    <span class="abdin_loyalty_status_text"
                                          t-else="">Inactive</span>

                                    <span t-if="record.ecommerce_ok.raw_value"
                                          class="abdin_loyalty_pill abdin_loyalty_pill_website">
                                        <i class="fa fa-globe" title="Website"/> Website
                                    </span>
                                    <span t-if="record.sale_ok.raw_value"
                                          class="abdin_loyalty_pill abdin_loyalty_pill_sale">
                                        <i class="fa fa-shopping-cart" title="Sales"/> Sales
                                    </span>
                                </div>

                                <!-- Date range -->
                                <div class="abdin_loyalty_card_dates" t-if="record.date_from.raw_value">
<i class="fa fa-calendar" title="Date"/> 
                                    <t t-esc="record.date_from.raw_value"/>
                                    <t t-if="record.date_to.raw_value">
                                        &#160;&#8594;&#160;<t t-esc="record.date_to.raw_value"/>
                                    </t>
                                </div>

                                <!-- Usage stats -->
                                <div class="abdin_loyalty_card_stats">
                                    <div class="abdin_loyalty_stat">
                                        <span class="abdin_loyalty_stat_value">
                                            <field name="coupon_count_display"/>
                                        </span>
                                        <span class="abdin_loyalty_stat_label">Items</span>
                                    </div>
                                    <div class="abdin_loyalty_stat">
                                        <span class="abdin_loyalty_stat_value">
                                            <field name="total_order_count"/>
                                        </span>
                                        <span class="abdin_loyalty_stat_label">Orders</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Card footer: quick actions -->
                            <div class="abdin_loyalty_card_footer">
                                <button name="%(loyalty.loyalty_generate_wizard_action)d"
                                        type="action"
                                        class="abdin_loyalty_btn abdin_loyalty_btn_primary"
                                        invisible="program_type not in ('coupons', 'gift_card', 'ewallet')">
                                    <i class="fa fa-plus" title="Generate"/> Generate
                                </button>
                                <button name="action_program_share" type="object"
                                        class="abdin_loyalty_btn abdin_loyalty_btn_ghost"
                                        invisible="program_type != 'promo_code'">
                                    <i class="fa fa-share-alt" title="Share"/> Share
                                </button>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Add kanban view to Discount & Loyalty action -->
    <record id="action_loyalty_program_kanban_discount_loyalty" model="ir.actions.act_window.view">
        <field name="view_mode">kanban</field>
        <field name="sequence">0</field>
        <field name="view_id" ref="abdin_loyalty_program_view_kanban"/>
        <field name="act_window_id" ref="loyalty.loyalty_program_discount_loyalty_action"/>
    </record>

    <!-- Add kanban view to Gift Cards & eWallet action -->
    <record id="action_loyalty_program_kanban_gift_card_ewallet" model="ir.actions.act_window.view">
        <field name="view_mode">kanban</field>
        <field name="sequence">0</field>
        <field name="view_id" ref="abdin_loyalty_program_view_kanban"/>
        <field name="act_window_id" ref="loyalty.loyalty_program_gift_ewallet_action"/>
    </record>

    <!-- Set kanban as default view mode for Discount & Loyalty -->
    <record id="loyalty.loyalty_program_discount_loyalty_action" model="ir.actions.act_window">
        <field name="view_mode">kanban,list,form</field>
    </record>

    <!-- Set kanban as default view mode for Gift Cards & eWallet -->
    <record id="loyalty.loyalty_program_gift_ewallet_action" model="ir.actions.act_window">
        <field name="view_mode">kanban,list,form</field>
    </record>

    <!-- ================================================================
         LIST VIEW — Styled modern table (override)
         ================================================================ -->
    <record id="abdin_loyalty_program_view_tree_inherit" model="ir.ui.view">
        <field name="name">abdin.loyalty.program.view.list.inherit</field>
        <field name="model">loyalty.program</field>
        <field name="inherit_id" ref="loyalty.loyalty_program_view_tree"/>
        <field name="priority">200</field>
        <field name="arch" type="xml">
            <list position="attributes">
                <attribute name="class">abdin_loyalty_list_view</attribute>
            </list>
            <field name="program_type" position="attributes">
                <attribute name="widget">badge</attribute>
            </field>
        </field>
    </record>

    <!-- ================================================================
         FORM VIEW — Premium UI/UX redesign
         Priority 999 to apply after all other inheritances.
         ================================================================ -->
    <record id="abdin_loyalty_form_inherit" model="ir.ui.view">
        <field name="name">abdin.loyalty.program.form.inherit</field>
        <field name="model">loyalty.program</field>
        <field name="inherit_id" ref="loyalty.loyalty_program_view_form"/>
        <field name="priority">999</field>
        <field name="arch" type="xml">

            <!-- Form root class -->
            <form position="attributes">
                <attribute name="class">abdin_campaign_form</attribute>
            </form>

            <!-- Replace button box with premium stat bar -->
            <div name="button_box" position="replace">
                <div class="abdin_stat_bar" name="stat_bar">
                    <button class="abdin_stat_button" type="object" name="action_open_loyalty_cards">
                        <span class="abdin_stat_value"><field name="coupon_count"/></span>
                        <span class="abdin_stat_icon"><i class="fa fa-tags" title="Items"/></span>
                        <span class="abdin_stat_label" invisible="program_type not in ('coupons', 'next_order_coupons')">Coupons</span>
                        <span class="abdin_stat_label" invisible="program_type not in ('promotion', 'buy_x_get_y')">Promos</span>
                        <span class="abdin_stat_label" invisible="program_type != 'loyalty'">Cards</span>
                        <span class="abdin_stat_label" invisible="program_type != 'promo_code'">Discounts</span>
                        <span class="abdin_stat_label" invisible="program_type != 'gift_card'">Gift Cards</span>
                        <span class="abdin_stat_label" invisible="program_type != 'ewallet'">eWallets</span>
                    </button>
                    <span class="abdin_stat_spacer"/>
                    <span class="abdin_stat_total">
                        <span class="abdin_stat_value"><field name="total_order_count"/></span>
                        <span class="abdin_stat_label">Orders</span>
                    </span>
                </div>
            </div>

            <!-- Program type: custom visual selector widget -->
            <field name="program_type" position="attributes">
                <attribute name="widget">abdin_program_type</attribute>
            </field>

            <!-- Section header: Campaign Details (full-width) -->
            <field name="program_type" position="before">
                <div class="abdin_section_head" colspan="2">
                    <i class="fa fa-sliders-h" title="Settings"/>
                    <span>Campaign Details</span>
                </div>
            </field>

            <!-- Section header: Schedule & Limits (full-width) -->
            <field name="date_from" position="before">
                <div class="abdin_section_head" colspan="2">
                    <i class="fa fa-calendar" title="Schedule"/>
                    <span>Schedule &amp; Limits</span>
                </div>
            </field>

            <!-- KPI Dashboard — moved to top area under hero header -->
            <div class="oe_title" position="after">
                <div class="abdin_dashboard_top" name="dashboard_top">
                    <div class="abdin_kpi_card abdin_kpi_card--items">
                        <div class="abdin_kpi_card_top">
                            <span class="abdin_kpi_card_label">Items</span>
                            <span class="abdin_kpi_card_icon"><i class="fa fa-tags" title="Items"/></span>
                        </div>
                        <span class="abdin_kpi_card_value"><field name="coupon_count"/></span>
                    </div>
                    <div class="abdin_kpi_card abdin_kpi_card--orders">
                        <div class="abdin_kpi_card_top">
                            <span class="abdin_kpi_card_label">Orders</span>
                            <span class="abdin_kpi_card_icon"><i class="fa fa-shopping-cart" title="Orders"/></span>
                        </div>
                        <span class="abdin_kpi_card_value"><field name="total_order_count"/></span>
                    </div>
                    <div class="abdin_kpi_card abdin_kpi_card--usage" invisible="not limit_usage">
                        <div class="abdin_kpi_card_top">
                            <span class="abdin_kpi_card_label">Usage</span>
                            <span class="abdin_kpi_card_icon"><i class="fa fa-tachometer" title="Usage"/></span>
                        </div>
                        <span class="abdin_kpi_card_value"><field name="total_order_count"/> / <field name="max_usage"/></span>
                        <div class="abdin_kpi_progress"><div class="abdin_kpi_progress-bar" style="width: 65%"/></div>
                    </div>
                    <div class="abdin_kpi_card abdin_kpi_card--status">
                        <div class="abdin_kpi_card_top">
                            <span class="abdin_kpi_card_label">Status</span>
                            <span class="abdin_kpi_card_icon"><i class="fa fa-circle" title="Status"/></span>
                        </div>
                        <span class="abdin_kpi_card_detail">
                            <span invisible="not active"><span class="abdin_kpi_status_dot abdin_kpi_status_dot--active"/> Active</span>
                            <span invisible="active"><span class="abdin_kpi_status_dot abdin_kpi_status_dot--inactive"/> Inactive</span>
                        </span>
                        <span class="abdin_kpi_badge abdin_kpi_badge--coupons"><field name="program_type"/></span>
                    </div>
                </div>
            </div>

        </field>
    </record>

    <!-- ================================================================
         RULE FORM — Dialog styling + Header
         ================================================================ -->
    <record id="abdin_loyalty_rule_form_inherit" model="ir.ui.view">
        <field name="name">abdin.loyalty.rule.form.inherit</field>
        <field name="model">loyalty.rule</field>
        <field name="inherit_id" ref="loyalty.loyalty_rule_view_form"/>
        <field name="priority">999</field>
        <field name="arch" type="xml">
            <form position="attributes">
                <attribute name="class">abdin_rule_form</attribute>
            </form>
            <!-- Dialog header via xpath (first group in sheet) -->
            <xpath expr="//sheet/group[1]" position="before">
                <div class="abdin-dialog-head">
                    <div class="abdin-dialog-head__icon"><i class="fa fa-gavel" title="Rule"/></div>
                    <div class="abdin-dialog-head__content">
                        <span class="abdin-dialog-head__title">Conditional Rule</span>
                        <span class="abdin-dialog-head__sub">Define when and how this reward is triggered</span>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

    <!-- ================================================================
         REWARD FORM — Dialog styling + Header + Visual reward type
         ================================================================ -->
    <record id="abdin_loyalty_reward_form_inherit" model="ir.ui.view">
        <field name="name">abdin.loyalty.reward.form.inherit</field>
        <field name="model">loyalty.reward</field>
        <field name="inherit_id" ref="loyalty.loyalty_reward_view_form"/>
        <field name="priority">999</field>
        <field name="arch" type="xml">
            <form position="attributes">
                <attribute name="class">abdin_reward_form</attribute>
            </form>
            <!-- Dialog header -->
            <group name="reward_type_group" position="before">
                <div class="abdin-dialog-head">
                    <div class="abdin-dialog-head__icon"><i class="fa fa-trophy" title="Reward"/></div>
                    <div class="abdin-dialog-head__content">
                        <span class="abdin-dialog-head__title">Reward Configuration</span>
                        <span class="abdin-dialog-head__sub">Set up how customers are rewarded</span>
                    </div>
                </div>
            </group>
        </field>
    </record>

    <!-- ================================================================
         LOYALTY CARD FORM — Premium Wallet / Coupon Detail Panel
         ================================================================ -->
    <record id="abdin_loyalty_card_form_inherit" model="ir.ui.view">
        <field name="name">abdin.loyalty.card.form.inherit</field>
        <field name="model">loyalty.card</field>
        <field name="inherit_id" ref="loyalty.loyalty_card_view_form"/>
        <field name="priority">999</field>
        <field name="arch" type="xml">
            <form position="attributes">
                <attribute name="class">abdin_card_form</attribute>
            </form>

            <!-- Replace outer group with a wallet detail card grid -->
            <xpath expr="//sheet/group" position="replace">
                <div class="abdin_wallet_grid">
                    <!-- ── Code Card ── -->
                    <div class="abdin_wallet_card">
                        <div class="abdin_wallet_card_inner">
                            <div class="abdin_wallet_card_head">
                                <i class="fa fa-tag abdin_wallet_icon" title="Coupon code"/>
                                <span class="abdin_wallet_label">Code</span>
                            </div>
                            <div class="abdin_wallet_card_body">
                                <field name="code" readonly="1" widget="abdin_wallet_code"/>
                            </div>
                        </div>
                    </div>

                    <!-- ── Expiration Card ── -->
                    <div class="abdin_wallet_card">
                        <div class="abdin_wallet_card_inner">
                            <div class="abdin_wallet_card_head">
                                <i class="fa fa-calendar abdin_wallet_icon" title="Expiry date"/>
                                <span class="abdin_wallet_label">Expiration</span>
                            </div>
                            <div class="abdin_wallet_card_body">
                                <field name="expiration_date" nolabel="1" widget="abdin_wallet_expiry"/>
                            </div>
                        </div>
                    </div>

                    <!-- ── Partner Card ── -->
                    <div class="abdin_wallet_card">
                        <div class="abdin_wallet_card_inner">
                            <div class="abdin_wallet_card_head">
                                <i class="fa fa-user abdin_wallet_icon" title="Customer"/>
                                <span class="abdin_wallet_label">Customer</span>
                            </div>
                            <div class="abdin_wallet_card_body">
                                <field name="partner_id" nolabel="1" placeholder="No customer assigned" class="abdin_wallet_partner"/>
                            </div>
                        </div>
                    </div>

                    <!-- ── Balance KPI Card ── -->
                    <div class="abdin_wallet_card abdin_wallet_card_balance">
                        <div class="abdin_wallet_card_inner">
                            <div class="abdin_wallet_card_head">
                                <div class="abdin_wallet_card_head_left">
                                    <i class="fa fa-wallet abdin_wallet_icon" title="Points balance"/>
                                    <span class="abdin_wallet_label">Balance</span>
                                </div>
                                <button name="action_loyalty_update_balance" type="object" class="abdin_balance_topup btn">
                                    <i class="fa fa-plus-circle"/>
                                    <span>Top Up</span>
                                </button>
                            </div>
                            <div class="abdin_wallet_card_body">
                                <button name="action_loyalty_update_balance" type="object" class="abdin_balance_kpi">
                                    <field name="points_display" nolabel="1" widget="abdin_wallet_balance"/>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>

            <!-- Add class to notebook for premium styling -->
            <xpath expr="//notebook" position="attributes">
                <attribute name="class">abdin_wallet_notebook</attribute>
            </xpath>
        </field>
    </record>

</odoo>
