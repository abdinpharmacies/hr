<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_payroll_excel_type_config_tree" model="ir.ui.view">
        <field name="name">payroll.excel.type.config.tree</field>
        <field name="model">payroll.excel.type.config</field>
        <field name="arch" type="xml">
            <list string="Sheet Types (J70)" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="sheet_type"/>
                <field name="e72_zero"/>
                <field name="g70_daily_allowance"/>
            </list>
        </field>
    </record>
    <record id="action_payroll_excel_type_config" model="ir.actions.act_window">
        <field name="name">Sheet Type Config</field>
        <field name="res_model">payroll.excel.type.config</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
