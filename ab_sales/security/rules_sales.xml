<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="ab_sales_header_rule_crud_not_saved" model="ir.rule">
            <field name="name">Sales Header: CRUD not saved</field>
            <field name="model_id" ref="model_ab_sales_header"/>
            <field name="domain_force">[('status', 'not in', ['saved', 'pending'])]</field>
            <field name="groups" eval="[(4, ref('ab_sales.group_ab_sales_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="ab_sales_header_rule_ro_saved" model="ir.rule">
