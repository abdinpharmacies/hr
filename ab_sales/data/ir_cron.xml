<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_update_balance_per_pos" model="ir.cron">
            <field name="name">Inventory: Update Balance Per Store</field>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number" eval="4"/>
            <field name="interval_type">hours</field>
            <field name="model_id" ref="model_ab_sales_inventory"/>
            <field name="state">code</field>
            <field name="code">model.btn_update_balance_per_pos()</field>
        </record>
        <record id="ir_cron_sync_sales_status_from_store" model="ir.cron">
            <field name="name">Sales: Sync Pending Status From Store</field>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number" eval="5"/>
            <field name="interval_type">minutes</field>
            <field name="model_id" ref="model_ab_sales_header"/>
            <field name="state">code</field>
            <field name="code">model.cron_update_status_from_store()</field>
        </record>
        <record id="ir_cron_refresh_product_rank_cache" model="ir.cron">
            <field name="name">Sales: Refresh Product Rank Cache</field>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number" eval="6"/>
            <field name="interval_type">hours</field>
            <field name="model_id" ref="model_ab_product_rank"/>
            <field name="state">code</field>
            <field name="code">model.cron_refresh_rankings()</field>
        </record>
    </data>
</odoo>
