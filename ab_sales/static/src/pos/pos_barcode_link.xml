<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ab_sales.PosBarcodeLinkDialog">
        <Dialog title="'Link Barcode'" size="'md'">
            <div class="d-flex flex-column gap-3">
                <t t-if="props.allowEdit">
                    <div>
                        <label class="form-label">Barcode</label>
                        <input class="form-control"
                               t-ref="barcodeInput"
                               t-att-value="state.barcode"
                               t-on-input="onBarcodeInput"
                               placeholder="Scan or type barcode"/>
                    </div>
                </t>
                <t t-else="">
                    <div class="alert alert-warning mb-0">
                        <strong>Barcode not found:</strong>
                        <span t-esc="props.barcode"/>
                    </div>
                </t>
                <div>
                    <label class="form-label">Linked Products (Temp)</label>
                    <t t-if="state.loadingLinks">
                        <div class="small text-muted mb-1">Loading linked products...</div>
                    </t>
                    <ABMany2many
                            relation="'ab_product'"
                            value="state.selected"
                            onUpdate="onProductsUpdate"
                            placeholder="'Search product...'"
                            domain="() => []"
                            canCreate="false"
                            canCreateEdit="false"
                            canQuickCreate="false"
                            canOpen="false"
                            canWrite="true"
                            string="'Products'"
                    />
                </div>
                <div class="d-flex justify-content-end gap-2">
                    <button class="btn btn-outline-secondary" type="button" t-on-click="cancel">Skip</button>
                    <button class="btn btn-primary"
                            type="button"
                            t-att-disabled="!state.barcode or state.loadingLinks"
                            t-on-click="confirm">
                        Save Links
                    </button>
                </div>
            </div>
        </Dialog>
    </t>
</templates>
