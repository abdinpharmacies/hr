<odoo>
    <data>
        <!-- Wizard Form View -->
        <record id="view_ab_sales_unavailable_wizard_form" model="ir.ui.view">
            <field name="name">ab.sales.unavailable.wizard.form</field>
            <field name="model">ab_sales_unavailable_wizard</field>
            <field name="arch" type="xml">

                <form string="No Stock Warning">
                    <div>
                        <div>
                            Some products exceed available stock in this store.
                        </div>
                        <div>
                            Please choose a reason for each line you still want to sell.
                        </div>
                    </div>
                    <group>
                        <field name="header_id" readonly="1"/>
                    </group>

                    <group string="Lines exceeding available stock">
                        <field name="line_ids">
                            <list editable="bottom">
                                <field name="line_id" readonly="1"/>
                                <field name="product_id" readonly="1"/>
                                <field name="qty" readonly="1"/>
                                <field name="balance" readonly="1"/>

                                <!-- Reason per line -->
                                <field name="unavailable_reason"/>
                                <field name="unavailable_reason_other"
                                       invisible="unavailable_reason != 'other'"/>
                            </list>
                        </field>
                    </group>

                    <footer>
                        <button string="Confirm"
                                type="object"
                                name="action_confirm"
                                class="btn-primary"/>

                        <button string="Cancel"
                                special="cancel"
                                class="btn-secondary"/>
                    </footer>
                </form>

            </field>
        </record>

    </data>
</odoo>
