<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ab_printer_view_list" model="ir.ui.view">
            <field name="name">ab_printer_view_list</field>
            <field name="model">ab_printer</field>
            <field name="arch" type="xml">
                <list string="Printers" multi_edit="1">
                    <field name="name"/>
                    <field name="protocol"/>
                    <field name="paper_size"/>
                    <field name="ip" optional="hide"/>
                    <field name="port" optional="hide"/>
                    <field name="printer_name"/>
                    <field name="username" optional="hide"/>
                    <field name="is_default"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="ab_printer_view_search" model="ir.ui.view">
            <field name="name">ab_printer_view_search</field>
            <field name="model">ab_printer</field>
            <field name="arch" type="xml">
                <search string="Printers">
                    <field name="name"/>
                    <field name="protocol"/>
                    <field name="paper_size"/>
                    <field name="ip"/>
                    <field name="printer_name"/>
                    <filter name="filter_active" string="Active" domain="[('active', '=', True)]"/>
                    <filter name="filter_archived" string="Archived" domain="[('active', '=', False)]"/>
                    <filter name="filter_default" string="Default" domain="[('is_default', '=', True)]"/>
                </search>
            </field>
        </record>

        <record id="ab_printer_view_form" model="ir.ui.view">
            <field name="name">ab_printer_view_form</field>
            <field name="model">ab_printer</field>
            <field name="arch" type="xml">
                <form string="Printer Configuration">
                    <header>
                        <button name="action_test_print"
                                type="object"
                                string="Test Printer"
                                class="btn-primary"
                                groups="ab_store.see_stores_ips,base.group_system"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Printer Profile"/>
                            </h1>
                        </div>
                        <group col="4">
                            <field name="protocol"/>
                            <field name="paper_size"/>
                            <field name="printer_name"/>
                            <field name="port" invisible="protocol != 'network'"/>
                            <field name="ip" invisible="protocol == 'connected'"/>
                            <field name="username" invisible="protocol != 'shared'"/>
                            <field name="password" password="True" invisible="protocol != 'shared'"/>
                            <field name="is_default"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="notes" placeholder="Optional operational notes..."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="ab_printer_action" model="ir.actions.act_window">
            <field name="name">Printers</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">ab_printer</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="ab_printer_view_search"/>
            <field name="context">{'search_default_filter_active': 1}</field>
        </record>

        <menuitem id="ab_printer_menu"
                  name="Printers"
                  parent="config_sub_menu"
                  action="ab_printer_action"
                  sequence="420"
                  groups="ab_store.see_stores_ips,base.group_system"/>
    </data>
</odoo>
