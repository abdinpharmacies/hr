<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="bill_wizard_receipt_print_html_pos">
        <html>
            <head>
                <meta charset="utf-8"/>
                <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
                <title></title>
            </head>
            <body style="margin:0;padding:0;width:512px;font-family:'Courier New',monospace;font-size:18px;color:#000;line-height:1.2;direction:ltr;">
                <div style="width:500px;box-sizing:border-box;padding:4px 4px 2px 4px;">
                    <t t-if="receipt_header">
                        <div style="text-align:center;font-weight:700;font-size:18px;line-height:1.1;margin:0 0 4px 0;"
                             t-esc="receipt_header"/>
                    </t>

                    <table style="width:376px;table-layout:fixed;border-collapse:collapse;font-size:18px;margin:0 0 3px 0;">
                        <tr>
                            <td style="width:86px;vertical-align:top;padding:0;">Date</td>
                            <td style="width:414px;text-align:right;vertical-align:top;padding:0;unicode-bidi:plaintext;"
                                t-esc="date_value"/>
                        </tr>
                        <tr>
                            <td style="width:86px;vertical-align:top;padding:0;">Bill</td>
                            <td style="width:414px;text-align:right;vertical-align:top;padding:0;unicode-bidi:plaintext;"
                                t-esc="serial_text"/>
                        </tr>
                        <tr>
                            <td style="width:86px;vertical-align:top;padding:0;">Store</td>
                            <td style="width:414px;text-align:right;vertical-align:top;padding:0;unicode-bidi:plaintext;"
                                t-esc="store_name"/>
                        </tr>
                        <t t-if="customer_name">
                            <tr>
                                <td style="width:86px;vertical-align:top;padding:0;">Customer</td>
                                <td style="width:414px;text-align:right;vertical-align:top;padding:0;unicode-bidi:plaintext;"
                                    t-esc="customer_name"/>
                            </tr>
                            <tr>
                                <td style="width:86px;vertical-align:top;padding:0;">Phone</td>
                                <td style="width:414px;text-align:right;vertical-align:top;padding:0;unicode-bidi:plaintext;"
                                    t-esc="customer_phone"/>
                            </tr>
                            <tr>
                                <td style="width:86px;vertical-align:top;padding:0;">Address</td>
                                <td style="width:414px;text-align:right;vertical-align:top;padding:0;unicode-bidi:plaintext;"
                                    t-esc="customer_address"/>
                            </tr>
                        </t>
                        <t t-if="employee_name">
                            <tr>
                                <td style="width:86px;vertical-align:top;padding:0;">Employee</td>
                                <td style="width:414px;text-align:right;vertical-align:top;padding:0;unicode-bidi:plaintext;"
                                    t-esc="employee_name"/>
                            </tr>
                        </t>
                    </table>

                    <div style="border-top:1px dashed #333;border-bottom:1px dashed #333;padding:2px 0;margin:2px 0;">
                        <table style="width:500px;table-layout:fixed;border-collapse:collapse;font-size:18px;">
                            <thead>
                                <tr>
                                    <th style="width:284px;text-align:left;padding:0 2px 1px 0;">Item</th>
                                    <th style="width:50px;text-align:right;padding:0 1px 1px 0;">Qty</th>
                                    <th style="width:77px;text-align:right;padding:0 1px 1px 0;">Price</th>
                                    <th style="width:88px;text-align:right;padding:0 0 1px 0;">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="lines" t-as="line">
                                    <tr>
                                        <td style="width:284px;text-align:left;vertical-align:top;padding:0 2px 0 0;word-break:break-word;overflow-wrap:anywhere;unicode-bidi:plaintext;"
                                            t-esc="line['product_name']"/>
                                        <td style="width:50px;text-align:right;vertical-align:top;padding:0 1px 0 0;white-space:nowrap;"
                                            t-esc="line['qty_text']"/>
                                        <td style="width:77px;text-align:right;vertical-align:top;padding:0 1px 0 0;white-space:nowrap;"
                                            t-esc="line['price_text']"/>
                                        <td style="width:88px;text-align:right;vertical-align:top;padding:0;white-space:nowrap;"
                                            t-esc="line['line_total_text']"/>
                                    </tr>
                                    <t t-if="line['product_code']">
                                        <tr>
                                            <td colspan="4"
                                                style="padding:0 0 10px 0;font-size:12px;color:#333;word-break:break-word;overflow-wrap:anywhere;unicode-bidi:plaintext;"
                                                t-esc="line['product_code']"/>
                                        </tr>
                                    </t>
                                </t>
                            </tbody>
                        </table>
                    </div>

                    <table style="width:500px;table-layout:fixed;border-collapse:collapse;font-size:18px;margin-top:3px;">
                        <!--
                                <tr>
                                    <td style="width:188px;padding:0;">Items</td>
                                    <td style="width:188px;text-align:right;padding:0;" t-esc="item_count"/>
                                </tr>
                        -->
                        <t t-if="promo_name">
                            <tr>
                                <td style="width:188px;padding:0;">Promo</td>
                                <td style="width:188px;text-align:right;padding:0;" t-esc="promo_name"/>
                            </tr>
                        </t>
                        <t t-if="promo_discount_text">
                            <tr>
                                <td style="width:188px;padding:0;" t-esc="discount_label or 'Discount'"/>
                                <td style="width:188px;text-align:right;padding:0;" t-esc="'-' + promo_discount_text"/>
                            </tr>
                        </t>
                        <tr>
                            <td style="width:188px;padding:0;font-size:18px;font-weight:700;" t-esc="total_label or 'Total'"/>
                            <td style="width:188px;text-align:right;padding:0;font-size:18px;font-weight:700;"
                                t-esc="total_text"/>
                        </tr>
                    </table>
                </div>
            </body>
        </html>
    </template>

    <template id="bill_wizard_receipt_print_html_a4">
        <html>
            <head>
                <meta charset="utf-8"/>
                <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
                <title></title>
            </head>
            <body class="m-0 p-3 fw-bold text-dark"
                  style="width:210mm;height:auto;font-family:'Courier New',monospace;font-size:18px;">
                <div class="container-fluid p-0" style="width:100%;box-sizing:border-box;">
                    <t t-if="receipt_header">
                        <div class="text-center fw-bold mb-1" style="font-size:18px;" t-esc="receipt_header"/>
                    </t>

                    <div class="mb-2" style="font-size:18px;">
                        <div class="d-flex justify-content-between gap-2">
                            <span>Date</span>
                            <span t-esc="date_value"/>
                        </div>
                        <div class="d-flex justify-content-between gap-2">
                            <span>Bill</span>
                            <span t-esc="serial_text"/>
                        </div>
                        <div class="d-flex justify-content-between gap-2">
                            <span>Store</span>
                            <span t-esc="store_name"/>
                        </div>
                        <t t-if="customer_name">
                            <div class="d-flex justify-content-between gap-2">
                                <span>Customer</span>
                                <span t-esc="customer_name"/>
                            </div>
                        </t>
                        <t t-if="employee_name">
                            <div class="d-flex justify-content-between gap-2">
                                <span>Employee</span>
                                <span t-esc="employee_name"/>
                            </div>
                        </t>
                    </div>

                    <hr class="my-1" style="border-top:1px dashed #333;opacity:1;"/>

                    <table class="table table-borderless table-sm mb-0 w-100"
                           style="table-layout:fixed;font-size:18px;">
                        <thead>
                            <tr>
                                <th class="fw-bold text-start pb-1"
                                    style="width:55%;border-bottom:1px solid #333;">Item</th>
                                <th class="fw-bold text-end pb-1 text-nowrap"
                                    style="width:11%;border-bottom:1px solid #333;">Qty</th>
                                <th class="fw-bold text-end pb-1 text-nowrap"
                                    style="width:16%;border-bottom:1px solid #333;">Price</th>
                                <th class="fw-bold text-end pb-1 text-nowrap"
                                    style="width:18%;border-bottom:1px solid #333;">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="lines" t-as="line">
                                <tr>
                                    <td class="align-top py-0" style="width:55%;">
                                        <div class="fw-bolder" t-esc="line['product_name']"/>
                                        <div class="text-muted" style="font-size:18px;" t-esc="line['product_code']"/>
                                    </td>
                                    <td class="align-top text-end text-nowrap py-0"
                                        style="width:11%;"
                                        t-esc="line['qty_text']"/>
                                    <td class="align-top text-end text-nowrap py-0"
                                        style="width:16%;"
                                        t-esc="line['price_text']"/>
                                    <td class="align-top text-end text-nowrap py-0"
                                        style="width:18%;"
                                        t-esc="line['line_total_text']"/>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <hr class="my-1" style="border-top:1px dashed #333;opacity:1;"/>

                    <div class="mt-1" style="font-size:18px;">
                        <div class="d-flex justify-content-between gap-2 my-0">
                            <span>Items</span>
                            <span t-esc="item_count"/>
                        </div>
                        <t t-if="promo_name">
                            <div class="d-flex justify-content-between gap-2 my-0">
                                <span>Promo</span>
                                <span t-esc="promo_name"/>
                            </div>
                        </t>
                        <t t-if="promo_discount_text">
                            <div class="d-flex justify-content-between gap-2 my-0">
                                <span t-esc="discount_label or 'Discount'"/>
                                <span t-esc="'-' + promo_discount_text"/>
                            </div>
                        </t>
                        <div class="d-flex justify-content-between gap-2 fw-bold my-0" style="font-size:18px;">
                            <span t-esc="total_label or 'Total'"/>
                            <span t-esc="total_text"/>
                        </div>
                    </div>
                </div>
            </body>
        </html>
    </template>
</odoo>
