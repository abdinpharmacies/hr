<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ab_sales_unavailable_wizard_line_view_list" model="ir.ui.view">
            <field name="name">ab_sales_unavailable_wizard_line_view_list</field>
            <field name="model">ab_sales_unavailable_wizard_line</field>
            <field name="arch" type="xml">
                <list string="Unavailable Product Reason" create="0" edit="0" delete="0">
                    <field name="wizard_id" optional="show"/>
                    <field name="line_id" optional="show"/>
                    <field name="product_id" optional="show"/>
                    <field name="qty" optional="show"/>
                    <field name="balance" optional="show"/>
                    <field name="unavailable_reason" optional="show"/>
                    <field name="unavailable_reason_other" optional="show"/>
                    <field name="create_uid" optional="hide"/>
                    <field name="create_date" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="ab_sales_unavailable_wizard_line_view_form" model="ir.ui.view">
            <field name="name">ab_sales_unavailable_wizard_line_view_form</field>
            <field name="model">ab_sales_unavailable_wizard_line</field>
            <field name="arch" type="xml">
                <form string="Unvailable Product Reason" create="0" edit="0" delete="0">
                    <sheet>
                        <group>
                            <field name="wizard_id" readonly="1"/>
                            <field name="line_id" readonly="1"/>
                            <field name="product_id" readonly="1"/>
                            <field name="qty" readonly="1"/>
                            <field name="balance" readonly="1"/>
                        </group>
                        <group>
                            <field name="unavailable_reason" readonly="1"/>
                            <field name="unavailable_reason_other" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="ab_sales_unavailable_wizard_line_view_search" model="ir.ui.view">
            <field name="name">ab_sales_unavailable_wizard_line_view_search</field>
            <field name="model">ab_sales_unavailable_wizard_line</field>
            <field name="arch" type="xml">
                <search string="Unvailable Product Reason">
                    <field name="wizard_id"/>
                    <field name="line_id"/>
                    <field name="product_id"/>
                    <field name="unavailable_reason"/>
                </search>
            </field>
        </record>

        <record id="ab_sales_unavailable_wizard_line_action" model="ir.actions.act_window">
            <field name="name">Unvailable Product Reason</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">ab_sales_unavailable_wizard_line</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="ab_sales_unavailable_wizard_line_view_list"/>
            <field name="search_view_id" ref="ab_sales_unavailable_wizard_line_view_search"/>
        </record>

        <menuitem id="ab_sales_reports_menu"
                  name="Reports"
                  parent="sales_menu_root"
                  sequence="1000"/>

        <menuitem id="ab_sales_reports_sales_details_menu"
                  name="Sales Details"
                  parent="ab_sales_reports_menu"
                  action="ab_sales_line_action"
                  sequence="1"/>

        <menuitem id="ab_sales_reports_unavailable_reason_menu"
                  name="Unvailable Product Reason"
                  parent="ab_sales_reports_menu"
                  action="ab_sales_unavailable_wizard_line_action"
                  sequence="2"
                  groups="base.group_user"/>
    </data>
</odoo>
