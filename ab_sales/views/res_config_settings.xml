<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ab_sales_res_config_settings_view_form" model="ir.ui.view">
            <field name="name">ab.sales.res.config.settings.form</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//block[@id='user_default_rights']" position="before">
                    <block title="Abdin Sales" id="ab_sales_settings">
                        <setting string="Delivery Job"
                                 company_dependent="1"
                                 help="Job title used to filter delivery employees in Sales bills.">
                            <field name="delivery_job_id"/>
                        </setting>
                        <setting string="Salesperson Job"
                                 company_dependent="1"
                                 help="Job title used for salesperson-related logic.">
                            <field name="salesperson_job_id"/>
                        </setting>
                    </block>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
