<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="ab_customer_action" model="ir.actions.act_window">
            <field name="name">Customers</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">ab_customer</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="ab_customer_menu"
                  name="Customers"
                  parent="config_sub_menu"
                  action="ab_customer_action"
                  sequence="100"/>


        <menuitem id="ab_product_card_menu"
                  name="Products Cards"
                  parent="config_sub_menu"
                  action="ab_product.ab_product_card_action"
                  sequence="200"/>

        <menuitem id="ab_product_menu"
                  name="Products"
                  parent="config_sub_menu"
                  action="ab_product.ab_product_action"
                  sequence="300"/>

        <menuitem id="ab_store_menu"
                  name="Stores"
                  parent="config_sub_menu"
                  action="ab_store.ab_store_action"
                  sequence="400"/>

        <menuitem id="ab_replica_db_menu"
                  name="Replica Databases"
                  parent="config_sub_menu"
                  action="ab_store.ab_replica_db_action"
                  sequence="410"/>
    </data>
</odoo>
