<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="rule_ab_request_user_request" model="ir.rule">
            <field name="name">Request User Requests</field>
            <field name="model_id" ref="model_ab_request"/>
            <field name="groups" eval="[(4, ref('ab_request_management.group_ab_request_management_user'))]"/>
            <field name="domain_force">['|', '|', ('requester_user_id', '=', user.id), ('assigned_employee_ids.user_id', '=', user.id), ('assigned_user_id', '=', user.id)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_ab_request_manager_request" model="ir.rule">
            <field name="name">Department Manager Requests</field>
            <field name="model_id" ref="model_ab_request"/>
            <field name="groups" eval="[(4, ref('ab_request_management.group_ab_request_management_manager'))]"/>
            <field name="domain_force">[('manager_user_id', '=', user.id)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_ab_request_admin_request" model="ir.rule">
            <field name="name">Request Admin Requests</field>
            <field name="model_id" ref="model_ab_request"/>
            <field name="groups" eval="[(4, ref('ab_request_management.group_ab_request_management_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <record id="rule_ab_request_user_followup" model="ir.rule">
            <field name="name">Request User Follow-ups</field>
            <field name="model_id" ref="model_ab_request_followup"/>
            <field name="groups" eval="[(4, ref('ab_request_management.group_ab_request_management_user'))]"/>
            <field name="domain_force">['|', '|', ('request_id.requester_user_id', '=', user.id), ('request_id.assigned_employee_ids.user_id', '=', user.id), ('request_id.assigned_user_id', '=', user.id)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_ab_request_manager_followup" model="ir.rule">
