#. module: ab_request_management
msgid "Add a concise, factual progress update or requester note"
msgstr "أضف تحديثًا مختصرًا وموضوعيًا عن التقدم أو ملاحظة من مقدم الطلب"

#. module: ab_request_management
msgid "Describe the requested changes or feedback..."
msgstr "صف التعديلات المطلوبة أو الملاحظات..."

#. module: ab_request_management
msgid "Create your first request."
msgstr "أنشئ طلبك الأول."

#. module: ab_request_management
msgid "Requests move through review, execution, requester confirmation, and closure while preserving a complete timeline."
msgstr "تنتقل الطلبات عبر المراجعة والتنفيذ وتأكيد مقدم الطلب ثم الإغلاق مع الحفاظ على خط زمني كامل."

#. module: ab_request_management
msgid "Timeline entries are immutable after creation to preserve a reliable request history."
msgstr "تصبح عناصر الخط الزمني غير قابلة للتعديل بعد إنشائها للحفاظ على سجل طلب موثوق."

#. module: ab_request_management
msgid "Operational request dashboard"
msgstr "لوحة تشغيل الطلبات"

#. module: ab_request_management
msgid "Track workload, approvals, execution flow, and recent movement from one responsive workspace."
msgstr "تابع عبء العمل والاعتمادات وتدفق التنفيذ وآخر التحركات من مساحة عمل واحدة متجاوبة."

#. module: ab_request_management
msgid "Requests per Department"
msgstr "الطلبات حسب القسم"

#. module: ab_request_management
msgid "Live grouped workload"
msgstr "عبء العمل المجمع المباشر"

#. module: ab_request_management
msgid "No department activity yet. Create a request to start populating this chart."
msgstr "لا يوجد نشاط للأقسام بعد. أنشئ طلبًا لبدء تعبئة هذا المخطط."

#. module: ab_request_management
msgid "Requests by State"
msgstr "الطلبات حسب الحالة"

#. module: ab_request_management
msgid "Workflow distribution"
msgstr "توزيع سير العمل"

#. module: ab_request_management
msgid "No workflow activity yet. State analytics appear once requests are created."
msgstr "لا يوجد نشاط لسير العمل بعد. ستظهر تحليلات الحالة عند إنشاء الطلبات."

#. module: ab_request_management
msgid "Recent Activity"
msgstr "النشاط الأخير"

#. module: ab_request_management
msgid "Last 5 requests"
msgstr "آخر 5 طلبات"

#. module: ab_request_management
msgid "No recent requests yet. Use the New button from a list view to create the first one."
msgstr "لا توجد طلبات حديثة بعد. استخدم زر جديد من عرض القائمة لإنشاء أول طلب."

#. module: ab_request_management
msgid "Pending Approval"
msgstr "بانتظار الاعتماد"

#. module: ab_request_management
msgid "%(state)s | %(assigned)s assignee(s) | %(followups)s follow-up(s) | %(activities)s activity(ies)"
msgstr "%(state)s | %(assigned)s مُسند إليهم | %(followups)s متابعات | %(activities)s أنشطة"

#. module: ab_request_management
msgid "Request number must be unique."
msgstr "يجب أن يكون رقم الطلب فريدًا."

#. module: ab_request_management
msgid "Request type must be unique per department."
msgstr "يجب أن يكون نوع الطلب فريدًا داخل كل قسم."

#. module: ab_request_management
msgid "The selected request type must have a department manager."
msgstr "يجب أن يحتوي نوع الطلب المحدد على مدير قسم."

#. module: ab_request_management
msgid "The selected department must have a manager."
msgstr "يجب أن يكون للقسم المحدد مدير."

#. module: ab_request_management
msgid "The Related Link must be a valid URL starting with http:// or https://"
msgstr "يجب أن يكون الرابط المرتبط عنوان URL صالحًا يبدأ بـ http:// أو https://"

#. module: ab_request_management
msgid "The URL must start with http:// or https://"
msgstr "يجب أن يبدأ الرابط بـ http:// أو https://"

#. module: ab_request_management
msgid "All assigned employees must belong to the request department."
msgstr "يجب أن ينتمي جميع الموظفين المسندين إلى قسم الطلب."

#. module: ab_request_management
msgid "Deadline cannot be in the past."
msgstr "لا يمكن أن يكون الموعد النهائي في الماضي."

#. module: ab_request_management
msgid "Subject is required."
msgstr "الموضوع مطلوب."

#. module: ab_request_management
msgid "Description is required."
msgstr "الوصف مطلوب."

#. module: ab_request_management
msgid "The current user is not linked to an employee."
msgstr "المستخدم الحالي غير مرتبط بموظف."

#. module: ab_request_management
msgid "%s must contain letters and cannot be only numbers or symbols."
msgstr "يجب أن يحتوي %s على أحرف ولا يمكن أن يكون أرقامًا أو رموزًا فقط."

#. module: ab_request_management
msgid "You cannot modify the subject or description after creation."
msgstr "لا يمكنك تعديل الموضوع أو الوصف بعد الإنشاء."

#. module: ab_request_management
msgid "Only the department manager or request admin can update assignees or deadline."
msgstr "يمكن فقط لمدير القسم أو مسؤول الطلبات تحديث المسندين أو الموعد النهائي."

#. module: ab_request_management
msgid "State changes must be performed through the workflow buttons."
msgstr "يجب تنفيذ تغييرات الحالة من خلال أزرار سير العمل."

#. module: ab_request_management
msgid "Only the department manager or request admin can perform this action."
msgstr "يمكن فقط لمدير القسم أو مسؤول الطلبات تنفيذ هذا الإجراء."

#. module: ab_request_management
msgid "Only the assigned employee, department manager, or request admin can perform this action."
msgstr "يمكن فقط للموظف المسند أو مدير القسم أو مسؤول الطلبات تنفيذ هذا الإجراء."

#. module: ab_request_management
msgid "Only the requester can perform this action."
msgstr "يمكن فقط لمقدم الطلب تنفيذ هذا الإجراء."

#. module: ab_request_management
msgid "The requester cannot add follow-ups on rejected or closed requests."
msgstr "لا يمكن لمقدم الطلب إضافة متابعات إلى الطلبات المرفوضة أو المغلقة."

#. module: ab_request_management
msgid "Only the assigned employee, department manager, or request admin can add follow-ups."
msgstr "يمكن فقط للموظف المسند أو مدير القسم أو مسؤول الطلبات إضافة متابعات."

#. module: ab_request_management
msgid "Request %(request)s has been created by %(requester)s and is waiting for review."
msgstr "تم إنشاء الطلب %(request)s بواسطة %(requester)s وهو بانتظار المراجعة."

#. module: ab_request_management
msgid "Request %(request)s has been assigned to %(employees)s."
msgstr "تم إسناد الطلب %(request)s إلى %(employees)s."

#. module: ab_request_management
msgid "Requester %(requester)s has updated request %(request)s."
msgstr "قام مقدم الطلب %(requester)s بتحديث الطلب %(request)s."

#. module: ab_request_management
msgid "Only requests under review can be approved."
msgstr "يمكن اعتماد الطلبات التي هي قيد المراجعة فقط."

#. module: ab_request_management
msgid "Only requests under review can be rejected."
msgstr "يمكن رفض الطلبات التي هي قيد المراجعة فقط."

#. module: ab_request_management
msgid "Only scheduled requests can be assigned."
msgstr "يمكن إسناد الطلبات المجدولة فقط."

#. module: ab_request_management
msgid "Please select at least one assigned employee before assigning the request."
msgstr "يرجى اختيار موظف مسند واحد على الأقل قبل إسناد الطلب."

#. module: ab_request_management
msgid "Only scheduled requests can be moved to in progress."
msgstr "يمكن نقل الطلبات المجدولة فقط إلى قيد التنفيذ."

#. module: ab_request_management
msgid "The request must be assigned before it can start."
msgstr "يجب إسناد الطلب قبل بدء تنفيذه."

#. module: ab_request_management
msgid "Only requests in progress can be sent for requester confirmation."
msgstr "يمكن إرسال الطلبات قيد التنفيذ فقط لتأكيد مقدم الطلب."

#. module: ab_request_management
msgid "Only requests under requester confirmation can be marked as satisfied."
msgstr "يمكن وضع علامة تم التأكيد فقط على الطلبات التي تنتظر تأكيد مقدم الطلب."

#. module: ab_request_management
msgid "Only requests under requester confirmation can be sent back for changes."
msgstr "يمكن إعادة الطلبات التي تنتظر تأكيد مقدم الطلب فقط لإجراء تعديلات."

#. module: ab_request_management
msgid "Only satisfied or rejected requests can be closed."
msgstr "يمكن إغلاق الطلبات المؤكدة أو المرفوضة فقط."

#. module: ab_request_management
msgid "Follow-ups cannot be edited once created."
msgstr "لا يمكن تعديل المتابعات بعد إنشائها."

#. module: ab_request_management
msgid "Follow-ups cannot be deleted."
msgstr "لا يمكن حذف المتابعات."

#. module: ab_request_management
msgid "Follow-up description is required."
msgstr "وصف المتابعة مطلوب."

#. module: ab_request_management
msgid "This workflow move is not allowed for requests."
msgstr "نقل سير العمل هذا غير مسموح للطلبات."
