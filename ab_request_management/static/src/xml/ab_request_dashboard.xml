<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ab_request_management.AbRequestDashboard">
        <div class="ab_request_dashboard_view">
            <div class="ab_request_dashboard_shell">
                <section class="ab_request_dashboard_hero">
                    <div>
                        <span class="ab_request_dashboard_kicker">Request Management</span>
                        <h1>Operational request dashboard</h1>
                        <p>
                            Track workload, approvals, execution flow, and recent movement from one responsive workspace.
                        </p>
                    </div>
                </section>

                <section class="ab_request_dashboard_cards">
                    <button type="button" t-foreach="state.cards" t-as="card" t-key="card.key" class="ab_request_dashboard_card" t-on-click="() => this.openList(card.domain)">
                        <span class="ab_request_dashboard_card_icon" t-att-style="'--card-accent:' + card.accent">
                            <i t-att-class="card.icon"/>
                        </span>
                        <span class="ab_request_dashboard_card_label" t-out="card.label"/>
                        <strong class="ab_request_dashboard_card_value" t-out="card.value"/>
                    </button>
                </section>

                <section class="ab_request_dashboard_grid">
                    <article class="ab_request_dashboard_panel">
                        <div class="ab_request_dashboard_panel_head">
                            <h2>Requests per Department</h2>
                            <span class="text-muted">Live grouped workload</span>
                        </div>
                        <div t-if="state.departmentChart.length" class="ab_request_dashboard_bar_chart">
                            <div t-foreach="state.departmentChart" t-as="item" t-key="item.label" class="ab_request_bar_row">
                                <div class="ab_request_bar_meta">
                                    <span t-out="item.label"/>
                                    <strong t-out="item.value"/>
                                </div>
                                <div class="ab_request_bar_track">
                                    <span class="ab_request_bar_fill"
                                          t-att-style="'width:' + (item.value / maxDepartmentValue * 100) + '%; background:' + palette[item_index % palette.length]"/>
                                </div>
                            </div>
                        </div>
                        <div t-else="" class="ab_request_dashboard_empty">
                            No department activity yet. Create a request to start populating this chart.
                        </div>
                    </article>

                    <article class="ab_request_dashboard_panel">
                        <div class="ab_request_dashboard_panel_head">
                            <h2>Requests by State</h2>
                            <span class="text-muted">Workflow distribution</span>
                        </div>
                        <div t-if="state.stateChart.length" class="ab_request_dashboard_donut_wrap">
                            <svg viewBox="0 0 42 42" class="ab_request_dashboard_donut">
                                <circle class="ab_request_dashboard_donut_base" cx="21" cy="21" r="15.9155"/>
                                <circle t-foreach="donutSegments" t-as="segment" t-key="segment.key"
                                        class="ab_request_dashboard_donut_segment"
                                        cx="21" cy="21" r="15.9155"
                                        t-att-stroke="segment.color"
                                        t-att-stroke-dasharray="segment.dasharray"
                                        t-att-stroke-dashoffset="segment.dashoffset"/>
                            </svg>
                            <div class="ab_request_dashboard_legend">
                                <div t-foreach="state.stateChart" t-as="item" t-key="item.key" class="ab_request_legend_row">
                                    <span class="ab_request_legend_dot" t-att-style="'background:' + item.color"/>
                                    <span t-out="item.label"/>
                                    <strong t-out="item.value"/>
                                </div>
                            </div>
                        </div>
                        <div t-else="" class="ab_request_dashboard_empty">
                            No workflow activity yet. State analytics appear once requests are created.
                        </div>
                    </article>

                    <article class="ab_request_dashboard_panel ab_request_dashboard_recent">
                        <div class="ab_request_dashboard_panel_head">
                            <h2>Recent Activity</h2>
                            <span class="text-muted">Last 5 requests</span>
                        </div>
                        <div t-if="state.recent.length" class="ab_request_recent_list">
                            <button type="button" t-foreach="state.recent" t-as="item" t-key="item.id" class="ab_request_recent_item" t-on-click="() => this.openList([['id', '=', item.id]])">
                                <div class="ab_request_recent_top">
                                    <strong t-out="item.name"/>
                                    <span t-attf-class="ab_request_state_badge ab_request_state_#{item.state}" t-out="item.stateLabel"/>
                                </div>
                                <div class="ab_request_recent_subject" t-out="item.subject"/>
                                <div class="ab_request_recent_meta">
                                    <span t-out="item.requestType"/>
                                    <span t-out="item.deadline"/>
                                    <span><t t-out="item.assigneeCount"/> assignee(s)</span>
                                </div>
                            </button>
                        </div>
                        <div t-else="" class="ab_request_dashboard_empty">
                            No recent requests yet. Use the New button from a list view to create the first one.
                        </div>
                    </article>
                </section>
            </div>
        </div>
    </t>
</templates>
