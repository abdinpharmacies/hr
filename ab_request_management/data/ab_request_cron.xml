<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_auto_close_resolved_complaints" model="ir.cron">
            <field name="name">Auto Close Resolved Complaints</field>
            <field name="model_id" ref="model_ab_request"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_close_resolved_complaints()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="DateTime.now() + relativedelta(days=1)"/>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
