<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ab_request_website_view_search" model="ir.ui.view">
        <field name="name">ab_request_website.search</field>
        <field name="model">ab_request_website</field>
        <field name="arch" type="xml">
            <search string="Website Requests">
                <field name="name"/>
                <field name="customer_name"/>
                <field name="customer_phone"/>
                <field name="customer_email"/>
                <field name="subject"/>
                <field name="request_type_id"/>
                <filter name="filter_new" string="New" domain="[('state', '=', 'new')]"/>
                <filter name="filter_reviewed" string="Reviewed" domain="[('state', '=', 'reviewed')]"/>
                <filter name="filter_converted" string="Converted" domain="[('state', '=', 'converted')]"/>
                <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                <filter name="group_type" string="Request Type" context="{'group_by': 'request_type_id'}"/>
            </search>
        </field>
    </record>

    <record id="ab_request_website_view_list" model="ir.ui.view">
        <field name="name">ab_request_website.list</field>
        <field name="model">ab_request_website</field>
        <field name="arch" type="xml">
            <list string="Website Requests" default_order="create_date desc">
                <field name="name"/>
                <field name="state"/>
                <field name="customer_name"/>
                <field name="customer_phone"/>
                <field name="customer_email" optional="show"/>
                <field name="subject"/>
                <field name="request_type_id"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="ab_request_website_view_form" model="ir.ui.view">
        <field name="name">ab_request_website.form</field>
        <field name="model">ab_request_website</field>
        <field name="arch" type="xml">
            <form string="Website Request">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="new,reviewed,converted,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="subject"/>
                        <h1>
                            <field name="subject"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Customer">
                            <field name="name" readonly="1"/>
                            <field name="customer_name"/>
                            <field name="customer_phone"/>
                            <field name="customer_email"/>
                            <field name="source"/>
                        </group>
                        <group string="Request">
                            <field name="request_category_id"/>
                            <field name="request_type_id"/>
                            <field name="create_date" readonly="1"/>
                        </group>
                    </group>
                    <group string="Details">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="ab_request_website_action" model="ir.actions.act_window">
        <field name="name">Website Requests</field>
        <field name="res_model">ab_request_website</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="ab_request_website_view_search"/>
        <field name="context">{'search_default_filter_new': 1}</field>
    </record>
</odoo>
