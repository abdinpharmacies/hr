<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="customer_request_form" name="Customer Request Form">
        <html>
            <head>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <style>
                    body { margin: 0; font-family: Arial, sans-serif; color: #20242a; background: transparent; }
                    .ab-request-embed { max-width: 920px; margin: 0 auto; padding: 24px; }
                    .ab-request-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
                    .ab-request-full { grid-column: 1 / -1; }
                    .ab-request-title { margin: 0 0 4px; font-size: 24px; line-height: 1.2; }
                    .ab-request-muted { margin: 0; color: #667085; }
                    .ab-request-label { display: block; margin-bottom: 6px; font-size: 14px; font-weight: 600; }
                    .ab-request-input { width: 100%; box-sizing: border-box; border: 1px solid #d0d5dd; border-radius: 6px; padding: 10px 12px; font-size: 15px; background: #fff; }
                    .ab-request-input:focus { border-color: #2f6fdd; outline: 2px solid rgba(47, 111, 221, 0.16); }
                    .ab-request-alert { padding: 12px 14px; border-radius: 6px; background: #fff1f0; color: #b42318; border: 1px solid #fecdca; }
                    .ab-request-submit { border: 0; border-radius: 6px; padding: 11px 18px; background: #2f6fdd; color: #fff; font-weight: 700; cursor: pointer; }
                    @media (max-width: 720px) {
                        .ab-request-embed { padding: 16px; }
                        .ab-request-grid { grid-template-columns: 1fr; }
                    }
                </style>
            </head>
            <body>
                <form action="/requests/customer-submit" method="post" class="ab-request-embed ab-request-grid">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <div class="ab-request-full">
                        <h2 class="ab-request-title">Requests and Complaints</h2>
                        <p class="ab-request-muted">Send your request or complaint to our team.</p>
                    </div>

                    <t t-if="error">
                        <div class="ab-request-full">
                            <div class="ab-request-alert" t-out="error"/>
                        </div>
                    </t>

                    <div>
                        <label class="ab-request-label" for="customer_name">Name *</label>
                        <input id="customer_name" name="customer_name" class="ab-request-input" required="required" maxlength="120" t-att-value="post.get('customer_name') if post else ''"/>
                    </div>

                    <div>
                        <label class="ab-request-label" for="customer_phone">Phone *</label>
                        <input id="customer_phone" name="customer_phone" class="ab-request-input" required="required" inputmode="tel" maxlength="30" t-att-value="post.get('customer_phone') if post else ''"/>
                    </div>

                    <div>
                        <label class="ab-request-label" for="customer_email">Email</label>
                        <input id="customer_email" name="customer_email" type="email" class="ab-request-input" maxlength="120" t-att-value="post.get('customer_email') if post else ''"/>
                    </div>

                    <div>
                        <label class="ab-request-label" for="request_category_id">Category</label>
                        <select id="request_category_id" name="request_category_id" class="ab-request-input">
                            <option value="">Choose...</option>
                            <option t-foreach="categories" t-as="category" t-att-value="category.id" t-att-selected="'selected' if post and post.get('request_category_id') == str(category.id) else None">
                                <t t-out="category.name"/>
                            </option>
                        </select>
                    </div>

                    <div>
                        <label class="ab-request-label" for="request_type_id">Request Type *</label>
                        <select id="request_type_id" name="request_type_id" class="ab-request-input" required="required">
                            <option value="">Choose...</option>
                            <option t-foreach="request_types" t-as="request_type" t-att-value="request_type.id" t-att-selected="'selected' if post and post.get('request_type_id') == str(request_type.id) else None">
                                <t t-out="request_type.name"/>
                            </option>
                        </select>
                    </div>

                    <div>
                        <label class="ab-request-label" for="subject">Subject *</label>
                        <input id="subject" name="subject" class="ab-request-input" required="required" maxlength="200" t-att-value="post.get('subject') if post else ''"/>
                    </div>

                    <div class="ab-request-full">
                        <label class="ab-request-label" for="description">Details *</label>
                        <textarea id="description" name="description" class="ab-request-input" required="required" rows="5" maxlength="3000"><t t-out="post.get('description') if post else ''"/></textarea>
                    </div>

                    <div class="ab-request-full">
                        <button type="submit" class="ab-request-submit">Submit</button>
                    </div>
                </form>
            </body>
        </html>
    </template>

    <template id="customer_request_thanks" name="Customer Request Thanks">
        <html>
            <head>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <style>
                    body { margin: 0; font-family: Arial, sans-serif; color: #20242a; background: transparent; }
                    .ab-request-embed { max-width: 920px; margin: 0 auto; padding: 24px; }
                    .ab-request-success { padding: 14px 16px; border-radius: 6px; background: #ecfdf3; color: #067647; border: 1px solid #abefc6; }
                </style>
            </head>
            <body>
                <div class="ab-request-embed ab-request-success">
                    Your request has been received. Reference:
                    <strong t-out="website_request.name"/>
                </div>
            </body>
        </html>
    </template>
</odoo>
