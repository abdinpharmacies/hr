<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="customer_request_form" name="External Request Form">
        <html t-att-dir="'rtl' if request.env.lang and request.env.lang.startswith('ar') else 'ltr'">
            <head>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <title t-out="page_title"/>
                <t t-call-assets="ab_request_management.assets_public_request"/>
            </head>
            <body class="ab-public-request-page">
                <main class="ab-public-request-workspace">
                    <div class="ab-public-request-shell">
                        <header class="core_ui_card core_ui_card_hero ab-public-request-hero">
                            <span class="ab-public-request-eyebrow">External Service Desk</span>
                            <h1>How can we help?</h1>
                            <p>Send a request or complaint without signing in to Odoo.</p>
                            <div class="ab-public-request-steps" aria-label="Form sections">
                                <span><b>1</b> Contact</span>
                                <span><b>2</b> Classification</span>
                                <span><b>3</b> Details</span>
                            </div>
                        </header>

                        <form action="/requests/customer-submit"
                              method="post"
                              class="core_ui_card ab-public-request-form"
                              data-ab-external-request-form="1">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                            <div class="ab-request-honeypot" aria-hidden="true">
                                <label for="website_url">Website URL</label>
                                <input id="website_url" name="website_url" type="text" tabindex="-1" autocomplete="off"/>
                            </div>

                            <div class="ab-public-request-form-heading">
                                <div>
                                    <span class="ab-public-request-kicker">Public form</span>
                                    <h2>Submit your request</h2>
                                </div>
                                <span class="ab-public-request-required-note">* Required fields</span>
                            </div>

                            <div t-if="error" class="core_ui_alert danger ab-public-request-alert" role="alert">
                                <span class="ab-public-request-alert-symbol">!</span>
                                <div class="core_ui_alert_content">
                                    <div class="core_ui_alert_title">Please review your information</div>
                                    <t t-out="error"/>
                                </div>
                            </div>

                            <div t-if="not has_public_options" class="core_ui_alert warning ab-public-request-alert" role="status">
                                <span class="ab-public-request-alert-symbol">!</span>
                                <div class="core_ui_alert_content">
                                    <div class="core_ui_alert_title">Form setup is incomplete</div>
                                    No public request categories with public request types are currently available.
                                </div>
                            </div>

                            <section class="ab-public-request-section">
                                <div class="ab-public-request-section-heading">
                                    <span>1</span>
                                    <div>
                                        <h3>Your contact information</h3>
                                        <p>We will use these details only to identify and follow up on this submission.</p>
                                    </div>
                                </div>
                                <div class="ab-public-request-grid">
                                    <div class="core_ui_form_group">
                                        <label for="customer_name">Name <em>*</em></label>
                                        <input id="customer_name"
                                               name="customer_name"
                                               class="core_ui_input"
                                               required="required"
                                               maxlength="120"
                                               autocomplete="name"
                                               placeholder="Your full name"
                                               t-att-value="post.get('customer_name')"/>
                                    </div>

                                    <div class="core_ui_form_group">
                                        <label for="customer_phone">Phone <em>*</em></label>
                                        <input id="customer_phone"
                                               name="customer_phone"
                                               class="core_ui_input"
                                               required="required"
                                               inputmode="tel"
                                               maxlength="30"
                                               autocomplete="tel"
                                               placeholder="Your phone number"
                                               t-att-value="post.get('customer_phone')"/>
                                    </div>

                                    <div class="core_ui_form_group ab-public-request-full">
                                        <label for="customer_email">Email <span>Optional</span></label>
                                        <input id="customer_email"
                                               name="customer_email"
                                               type="email"
                                               class="core_ui_input"
                                               maxlength="254"
                                               autocomplete="email"
                                               placeholder="name@example.com"
                                               t-att-value="post.get('customer_email')"/>
                                    </div>
                                </div>
                            </section>

                            <section class="ab-public-request-section">
                                <div class="ab-public-request-section-heading">
                                    <span>2</span>
                                    <div>
                                        <h3>Classify your request</h3>
                                        <p>Choose a category first, then select one of its available request types.</p>
                                    </div>
                                </div>
                                <div class="ab-public-request-grid">
                                    <div class="core_ui_form_group">
                                        <label for="request_category_id">Category <em>*</em></label>
                                        <select id="request_category_id"
                                                name="request_category_id"
                                                class="core_ui_input core_ui_select"
                                                required="required"
                                                t-att-disabled="not has_public_options">
                                            <option value=""><t t-out="category_prompt"/></option>
                                            <option t-foreach="categories"
                                                    t-as="category"
                                                    t-att-value="category.id"
                                                    t-att-selected="'selected' if post.get('request_category_id') == str(category.id) else None">
                                                <t t-out="category.name"/>
                                            </option>
                                        </select>
                                    </div>

                                    <div class="core_ui_form_group">
                                        <label for="request_type_id">Request type <em>*</em></label>
                                        <select id="request_type_id"
                                                name="request_type_id"
                                                class="core_ui_input core_ui_select"
                                                required="required"
                                                t-att-data-selected-value="post.get('request_type_id', '')"
                                                t-att-data-placeholder-empty="select_category_prompt"
                                                t-att-data-placeholder-ready="request_type_prompt"
                                                disabled="disabled">
                                            <option value=""><t t-out="select_category_prompt"/></option>
                                            <option t-foreach="request_types"
                                                    t-as="request_type"
                                                    t-att-value="request_type.id"
                                                    t-att-data-category-id="request_type.category_id.id">
                                                <t t-out="request_type.name"/>
                                            </option>
                                        </select>
                                    </div>
                                </div>
                            </section>

                            <section class="ab-public-request-section">
                                <div class="ab-public-request-section-heading">
                                    <span>3</span>
                                    <div>
                                        <h3>Tell us what happened</h3>
                                        <p>Use a clear subject and include the details needed to understand your request.</p>
                                    </div>
                                </div>
                                <div class="ab-public-request-grid">
                                    <div class="core_ui_form_group ab-public-request-full">
                                        <label for="subject">Subject <em>*</em></label>
                                        <input id="subject"
                                               name="subject"
                                               class="core_ui_input"
                                               required="required"
                                               maxlength="200"
                                               placeholder="A short summary"
                                               t-att-value="post.get('subject')"/>
                                    </div>

                                    <div class="core_ui_form_group ab-public-request-full">
                                        <label for="description">Details <em>*</em></label>
                                        <textarea id="description"
                                                  name="description"
                                                  class="core_ui_input core_ui_textarea"
                                                  required="required"
                                                  rows="6"
                                                  maxlength="3000"
                                                  placeholder="Describe your request or complaint"><t t-out="post.get('description')"/></textarea>
                                        <div class="core_ui_help_text">Do not include passwords, payment card numbers, or other secrets.</div>
                                    </div>
                                </div>
                            </section>

                            <footer class="ab-public-request-actions">
                                <p>After submission, you will receive a reference number for follow-up.</p>
                                <button type="submit"
                                        class="core_ui_btn core_ui_btn_primary ab-public-request-submit"
                                        t-att-disabled="not has_public_options">
                                    Submit request
                                    <span aria-hidden="true">→</span>
                                </button>
                            </footer>
                        </form>

                        <p class="ab-public-request-footer-note">External submissions are stored separately from internal employee requests.</p>
                    </div>
                </main>
                <script type="module" src="/ab_request_management/static/src/js/customer_request_form.js"></script>
            </body>
        </html>
    </template>

    <template id="customer_request_thanks" name="External Request Thanks">
        <html t-att-dir="'rtl' if request.env.lang and request.env.lang.startswith('ar') else 'ltr'">
            <head>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <title t-out="page_title"/>
                <t t-call-assets="ab_request_management.assets_public_request"/>
            </head>
            <body class="ab-public-request-page">
                <main class="ab-public-request-workspace ab-public-request-workspace-success">
                    <div class="ab-public-request-success-shell">
                        <section class="core_ui_card ab-public-request-success-card">
                            <span class="ab-public-request-success-icon" aria-hidden="true">✓</span>
                            <span class="ab-public-request-kicker">Submission received</span>
                            <h1>Thank you</h1>
                            <t t-if="website_request">
                                <p>Your external request or complaint has been received.</p>
                                <div class="ab-public-request-reference">
                                    <span>Reference number</span>
                                    <strong t-out="website_request.name"/>
                                </div>
                            </t>
                            <t t-else="">
                                <p>Your external request or complaint has been received.</p>
                            </t>
                        </section>
                    </div>
                </main>
            </body>
        </html>
    </template>
</odoo>
