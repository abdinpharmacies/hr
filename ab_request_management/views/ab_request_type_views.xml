<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ab_request_category_view_list" model="ir.ui.view">
            <field name="name">ab_request_category.list</field>
            <field name="model">ab_request_category</field>
            <field name="arch" type="xml">
                <list string="Categories">
                    <field name="name"/>
                    <field name="type"/>
                    <field name="is_public" optional="show" widget="boolean_toggle" groups="ab_request_management.group_ab_request_management_viewer,ab_request_management.group_ab_request_management_admin"/>
                    <field name="public_request_type_count" optional="show" groups="ab_request_management.group_ab_request_management_viewer,ab_request_management.group_ab_request_management_admin"/>
                    <field name="is_public_form_ready" optional="show" groups="ab_request_management.group_ab_request_management_viewer,ab_request_management.group_ab_request_management_admin"/>
                </list>
            </field>
        </record>

        <record id="ab_request_category_view_form" model="ir.ui.view">
            <field name="name">ab_request_category.form</field>
            <field name="model">ab_request_category</field>
            <field name="arch" type="xml">
                <form string="Category">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="type"/>
                            <separator string="Public Form" groups="ab_request_management.group_ab_request_management_viewer,ab_request_management.group_ab_request_management_admin"/>
                            <field name="is_public" widget="boolean_toggle" groups="ab_request_management.group_ab_request_management_viewer,ab_request_management.group_ab_request_management_admin"/>
                            <field name="public_request_type_count" readonly="1" groups="ab_request_management.group_ab_request_management_viewer,ab_request_management.group_ab_request_management_admin" invisible="not is_public"/>
                            <field name="is_public_form_ready" invisible="1" groups="ab_request_management.group_ab_request_management_viewer,ab_request_management.group_ab_request_management_admin"/>
                        </group>
                        <div class="core_ui_alert warning"
                             groups="ab_request_management.group_ab_request_management_viewer,ab_request_management.group_ab_request_management_admin"
                             invisible="not is_public or public_request_type_count &gt; 0">
                            <i class="fa fa-exclamation-triangle"/>
                            <div class="core_ui_alert_content">
                                <div class="core_ui_alert_title">Public form setup is incomplete</div>
                                Enable “Available on Public Form” on at least one request type in this category.
                            </div>
                        </div>
                        <div class="core_ui_alert success"
                             groups="ab_request_management.group_ab_request_management_viewer,ab_request_management.group_ab_request_management_admin"
                             invisible="not is_public_form_ready">
                            <i class="fa fa-check-circle"/>
                            <div class="core_ui_alert_content">
                                <div class="core_ui_alert_title">Visible on the public form</div>
                                This category has at least one public request type and is ready for external submissions.
                            </div>
                        </div>
                        <notebook groups="ab_request_management.group_ab_request_management_viewer,ab_request_management.group_ab_request_management_admin">
                            <page string="Request Types">
                                <field name="request_type_ids" nolabel="1">
                                    <list editable="bottom" default_order="name asc">
                                        <field name="name"/>
                                        <field name="department_id"/>
                                        <field name="manager_id" readonly="1"/>
                                        <field name="is_public" string="Available on Public Form" widget="boolean_toggle"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="ab_request_category_action" model="ir.actions.act_window">
            <field name="name">Categories</field>
            <field name="res_model">ab_request_category</field>
            <field name="view_mode">list,form</field>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'sequence': 1, 'view_id': ref('ab_request_category_view_list')}),
                (0, 0, {'view_mode': 'form', 'sequence': 2, 'view_id': ref('ab_request_category_view_form')})]"/>
        </record>

        <record id="ab_request_type_view_search" model="ir.ui.view">
            <field name="name">ab_request_type.search</field>
            <field name="model">ab_request_type</field>
            <field name="arch" type="xml">
                <search string="Types">
                    <field name="name"/>
                    <field name="department_id"/>
                    <field name="manager_id"/>
                    <field name="is_public" groups="ab_request_management.group_ab_request_management_viewer,ab_request_management.group_ab_request_management_admin"/>
                    <separator/>
                    <filter name="filter_public" string="Public Form" domain="[('is_public', '=', True)]" groups="ab_request_management.group_ab_request_management_viewer,ab_request_management.group_ab_request_management_admin"/>
                    <filter name="group_department" string="Department" context="{'group_by': 'department_id'}"/>
                    <filter name="group_manager" string="Manager" context="{'group_by': 'manager_id'}"/>
                </search>
            </field>
        </record>

        <record id="ab_request_type_view_list" model="ir.ui.view">
            <field name="name">ab_request_type.list</field>
            <field name="model">ab_request_type</field>
            <field name="arch" type="xml">
                <list string="Types" class="ab_request_type_list" default_order="name asc">
                    <field name="name" optional="show"/>
                    <field name="department_id" optional="show"/>
                    <field name="manager_id" optional="show"/>
                    <field name="category_id" optional="show"/>
                    <field name="category_type" optional="show"/>
                    <field name="is_public" optional="show" widget="boolean_toggle" groups="ab_request_management.group_ab_request_management_viewer,ab_request_management.group_ab_request_management_admin"/>

                </list>
            </field>
        </record>

        <record id="ab_request_type_view_form" model="ir.ui.view">
            <field name="name">ab_request_type.form</field>
            <field name="model">ab_request_type</field>
            <field name="arch" type="xml">
                <form string="Type" class="ab_request_type_form">
                    <sheet class="ab_request_type_sheet">
                        <div class="oe_title ab_request_type_title_block">
                            <label for="name" string="Type"/>
                            <h1>
                                <field name="name" placeholder="Example: System Access, Procurement, Maintenance"/>
                            </h1>
                            <div class="text-muted">
                                Each request or complaint type belongs to one department and automatically inherits that department's manager.
                            </div>
                        </div>
                        <group col="2" class="ab_request_section_grid">
                            <group string="Configuration" class="ab_request_section">
                                <field name="category_id" placeholder="Choose the category that owns this request or complaint type"/>
                                <field name="category_type"/>
                                <separator string="Public Form"/>
                                <field name="is_public" widget="boolean_toggle" groups="ab_request_management.group_ab_request_management_viewer,ab_request_management.group_ab_request_management_admin"/>
                                <div class="core_ui_alert info"
                                     groups="ab_request_management.group_ab_request_management_viewer,ab_request_management.group_ab_request_management_admin"
                                     invisible="not is_public">
                                    <i class="fa fa-info-circle"/>
                                    <div class="core_ui_alert_content">
                                        This type will appear publicly under its selected category.
                                    </div>
                                </div>
                                <field name="department_id" placeholder="Choose the department that owns this request or complaint type"/>
                            </group>
                            <group string="Approval Routing" class="ab_request_section">
                                <field name="manager_id" readonly="1"/>
                                <div class="text-muted">
                                    The manager is derived from the selected department and remains read-only here.
                                </div>
                            </group>
                        </group>
                        <group class="mt-4">
                            <field name="question_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="question" string="Question"/>
                                    <field name="is_required"/>
                                </list>
                            </field>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="ab_request_type_action" model="ir.actions.act_window">
            <field name="name">Types</field>
            <field name="res_model">ab_request_type</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="ab_request_type_view_search"/>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'sequence': 1, 'view_id': ref('ab_request_type_view_list')}),
                (0, 0, {'view_mode': 'form', 'sequence': 2, 'view_id': ref('ab_request_type_view_form')})]"/>
        </record>
    </data>
</odoo>
