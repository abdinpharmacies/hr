<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ab_request_ticket_view_list" model="ir.ui.view">
            <field name="name">ab_request_ticket.list</field>
            <field name="model">ab_request_ticket</field>
            <field name="arch" type="xml">
                <list string="Request Tickets">
                    <field name="ticket_number"/>
                    <field name="title"/>
                    <field name="request_type_id"/>
                    <field name="requester"/>
                    <field name="assigned_to"/>
                    <field name="priority"/>
                    <field name="stage"/>
                    <field name="duration_days"/>
                    <field name="expected_close_date"/>
                    <field name="actual_close_date"/>
                    <field name="create_date" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="ab_request_ticket_view_form" model="ir.ui.view">
            <field name="name">ab_request_ticket.form</field>
            <field name="model">ab_request_ticket</field>
            <field name="arch" type="xml">
                <form string="Request Ticket">
                    <header>
                        <button name="action_start_progress" type="object" string="Start Progress" class="btn-primary"
                                invisible="stage != 'new' or not is_responsible_user"/>
                        <button name="action_start_progress" type="object" string="Resume Progress" class="btn-primary"
                                invisible="stage != 'add_notes' or not is_responsible_user"/>
                        <button name="action_send_for_requester_confirmation" type="object"
                                string="Send For Requester Confirmation" class="btn-primary"
                                invisible="stage != 'in_progress' or not is_responsible_user"/>
                        <button name="action_mark_satisfied" type="object" string="Mark Satisfied" class="btn-primary"
                                invisible="stage != 'requester_confirmation' or not is_requester"/>
                        <button name="action_add_notes" type="object" string="Add Notes" class="btn-secondary"
                                invisible="stage != 'requester_confirmation' or not is_requester"/>
                        <button name="action_close_by_dev" type="object" string="Close By Dev" class="btn-primary"
                                invisible="stage != 'satisfied' or not is_responsible_user"/>
                        <field name="stage" widget="statusbar" readonly="1"/>
                    </header>
                    <sheet>
                        <field name="is_requester" invisible="1"/>
                        <field name="is_responsible_user" invisible="1"/>
                        <field name="is_request_manager" invisible="1"/>
                        <widget name="web_ribbon" title="Closed"
                                invisible="stage != 'closed_by_dev'"/>
                        <group col="2">
                            <group string="Request Details">
                                <field name="ticket_number"/>
                                <field name="title" readonly="stage == 'closed_by_dev'"/>
                                <field name="request_type_id" readonly="stage == 'closed_by_dev'"/>
                                <field name="priority" readonly="stage == 'closed_by_dev'"/>
                                <field name="description" readonly="stage == 'closed_by_dev'"/>
                            </group>
                            <group string="Assignment">
                                <field name="requester"/>
                                <field name="assigned_to" readonly="stage == 'closed_by_dev'"/>
                                <field name="requester_confirmation" readonly="1"/>
                                <field name="active" invisible="1"/>
                            </group>
                        </group>
                        <group string="Timeline" col="4">
                            <field name="start_date" readonly="stage == 'closed_by_dev'"/>
                            <field name="duration_days" readonly="stage == 'closed_by_dev'"/>
                            <field name="expected_close_date" readonly="stage == 'closed_by_dev'"/>
                            <field name="actual_close_date" readonly="1"/>
                        </group>
                        <notebook>
                            <page string="Notes">
                                <field name="notes" placeholder="Requester can add testing notes here before returning the ticket to development."
                                       readonly="stage == 'closed_by_dev'"/>
                            </page>
                            <page string="Attachments">
                                <field name="attachments" widget="many2many_binary" readonly="stage == 'closed_by_dev'"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="ab_request_ticket_action" model="ir.actions.act_window">
            <field name="name">Request Tickets</field>
            <field name="res_model">ab_request_ticket</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
