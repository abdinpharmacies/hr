<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_ab_quality_assurance_visit_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <style>
                            .qa-report-table {
                                width: 100%;
                                table-layout: fixed;
                                border-collapse: collapse;
                            }
                            .qa-report-table th,
                            .qa-report-table td {
                                padding: 8px 10px;
                                vertical-align: top;
                                white-space: normal !important;
                                word-wrap: break-word;
                                word-break: break-word;
                                line-height: 1.45;
                                height: auto;
                            }
                            .qa-report-table .qa-number-cell {
                                text-align: center;
                                white-space: nowrap;
                            }
                            .qa-report-table .qa-cell-text {
                                display: block;
                                width: 100%;
                                white-space: normal !important;
                                word-wrap: break-word;
                                word-break: break-word;
                                line-height: 1.45;
                            }
                        </style>
                        <h2>Quality Visit</h2>
                        <table class="table table-sm table-bordered mb-4 qa-report-table">
                            <tbody>
                                <tr>
                                    <td><strong>Reference</strong></td>
                                    <td><div class="qa-cell-text"><span t-field="o.name"/></div></td>
                                    <td><strong>Visit Date</strong></td>
                                    <td><div class="qa-cell-text"><span t-field="o.visit_date"/></div></td>
                                </tr>
                                <tr>
                                    <td><strong>Branch</strong></td>
                                    <td><div class="qa-cell-text"><span t-field="o.department_id"/></div></td>
                                    <td><strong>Visited By</strong></td>
                                    <td><div class="qa-cell-text"><span t-field="o.employee_id"/></div></td>
                                </tr>
                                <tr>
                                    <td><strong>Department Manager</strong></td>
                                    <td><div class="qa-cell-text"><span t-field="o.department_manager_id"/></div></td>
                                    <td><strong>Status</strong></td>
                                    <td><div class="qa-cell-text"><span t-field="o.state"/></div></td>
                                </tr>
                                <tr>
                                    <td><strong>Earned Score</strong></td>
                                    <td><div class="qa-cell-text"><span t-out="'{:.2f}'.format(o.earned_total_score or 0.0)"/></div></td>
                                    <td><strong>Max Score</strong></td>
                                    <td><div class="qa-cell-text"><span t-out="'{:.2f}'.format(o.max_total_score or 0.0)"/></div></td>
                                </tr>
                                <tr>
                                    <td><strong>Total Percentage</strong></td>
                                    <td><div class="qa-cell-text"><span t-out="'{:.2f}%'.format(o.total_percentage or 0.0)"/></div></td>
                                    <td><strong>Submitted At</strong></td>
                                    <td><div class="qa-cell-text"><span t-field="o.submitted_at" t-if="o.submitted_at"/></div></td>
                                </tr>
                            </tbody>
                        </table>

                        <t t-foreach="o.visit_section_ids.sorted(lambda section: (section.sequence, section.id))" t-as="section">
                            <h4 class="mt-4 mb-2">
                                <span t-out="section.name"/>
                            </h4>
                            <table class="table table-sm table-bordered qa-report-table">
                                <colgroup>
                                    <col style="width: 40%;"/>
                                    <col style="width: 15%;"/>
                                    <col style="width: 15%;"/>
                                    <col style="width: 15%;"/>
                                    <col style="width: 15%;"/>
                                </colgroup>
                                <thead>
                                    <tr>
                                        <th>Standard</th>
                                        <th class="qa-number-cell">Max Score</th>
                                        <th class="qa-number-cell">Score</th>
                                        <th class="qa-number-cell">Percentage</th>
                                        <th>Attachment</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="section.visit_line_ids.sorted(lambda line: (line.sequence, line.id))" t-as="line">
                                        <td><div class="qa-cell-text"><span t-out="line.title"/></div></td>
                                        <td class="qa-number-cell"><span t-out="'{:.2f}'.format(line.max_score or 0.0)"/></td>
                                        <td class="qa-number-cell"><span t-out="'{:.2f}'.format(line.score or 0.0)"/></td>
                                        <td class="qa-number-cell"><span t-out="'{:.2f}%'.format(line.percentage or 0.0)"/></td>
                                        <td><div class="qa-cell-text"><span t-out="line.attachment_name or '-'"/></div></td>
                                    </tr>
                                    <tr t-if="not section.visit_line_ids">
                                        <td colspan="5" class="qa-number-cell">No standards found.</td>
                                    </tr>
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td><strong>Section Total</strong></td>
                                        <td class="qa-number-cell"><strong t-out="'{:.2f}'.format(section.max_score or 0.0)"/></td>
                                        <td class="qa-number-cell"><strong t-out="'{:.2f}'.format(section.earned_score or 0.0)"/></td>
                                        <td class="qa-number-cell"><strong t-out="'{:.2f}%'.format(section.percentage or 0.0)"/></td>
                                        <td></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="action_report_ab_quality_assurance_visit" model="ir.actions.report">
        <field name="name">Quality Visit</field>
        <field name="model">ab_quality_assurance_visit</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ab_quality_assurance.report_ab_quality_assurance_visit_document</field>
        <field name="report_file">ab_quality_assurance.report_ab_quality_assurance_visit_document</field>
        <field name="binding_model_id" ref="model_ab_quality_assurance_visit"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Quality Visit - %s' % (object.name or '')</field>
    </record>
</odoo>
