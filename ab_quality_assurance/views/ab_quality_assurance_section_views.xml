<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ab_quality_assurance_section_view_list" model="ir.ui.view">
            <field name="name">ab_quality_assurance_section.list</field>
            <field name="model">ab_quality_assurance_section</field>
            <field name="arch" type="xml">
                <list string="Review Sections" editable="bottom" multi_edit="1" open_form_view="True">
                    <field name="active" widget="boolean_toggle"/>
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="department_id"/>
                    <field name="department_manager_id" readonly="1" optional="show"/>
                    <field name="standard_count" readonly="1"/>
                </list>
            </field>
        </record>

        <record id="ab_quality_assurance_section_view_form" model="ir.ui.view">
            <field name="name">ab_quality_assurance_section.form</field>
            <field name="model">ab_quality_assurance_section</field>
            <field name="arch" type="xml">
                <form string="Review Section">
                    <sheet>
                        <group>
                            <group>
                                <field name="sequence"/>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="active"/>
                                <field name="department_id"/>
                                <field name="department_manager_id" readonly="1"/>
                                <field name="standard_count" readonly="1"/>
                            </group>
                        </group>
                        <field name="standard_ids" readonly="0">
                            <list editable="bottom" open_form_view="True">
                                <field name="active" widget="boolean_toggle"/>
                                <field name="sequence" widget="handle"/>
                                <field name="title"/>
                                <field name="max_score"/>
                            </list>
                        </field>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="ab_quality_assurance_section_view_search" model="ir.ui.view">
            <field name="name">ab_quality_assurance_section.search</field>
            <field name="model">ab_quality_assurance_section</field>
            <field name="arch" type="xml">
                <search string="Review Sections">
                    <field name="name"/>
                    <field name="department_id"/>
                    <separator/>
                    <filter name="filter_active" string="Active" domain="[('active', '=', True)]"/>
                    <filter name="filter_inactive" string="Archived" domain="[('active', '=', False)]"/>
                    <filter name="group_by_department" string="Responsible Department" context="{'group_by': 'department_id'}"/>
                </search>
            </field>
        </record>

        <record id="ab_quality_assurance_section_action" model="ir.actions.act_window">
            <field name="name">Sections</field>
            <field name="res_model">ab_quality_assurance_section</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="ab_quality_assurance_section_view_search"/>
            <field name="context">{'search_default_filter_active': 1}</field>
        </record>
    </data>
</odoo>
