<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ab_quality_assurance_visit_section_view_form" model="ir.ui.view">
            <field name="name">ab_quality_assurance_visit_section.form</field>
            <field name="model">ab_quality_assurance_visit_section</field>
            <field name="arch" type="xml">
                <form string="Visit Section" create="false" delete="false">
                    <sheet>
                        <field name="visit_id" invisible="1"/>
                        <field name="section_id" invisible="1"/>
                        <div class="o_qa_visit_summary_card">
                            <div class="o_qa_visit_summary_header">
                                <field name="name" readonly="1"/>
                            </div>
                            <group col="3">
                                <field name="earned_score" readonly="1"/>
                                <field name="max_score" readonly="1"/>
                                <field name="percentage" readonly="1"/>
                            </group>
                        </div>
                        <field name="visit_line_ids" readonly="visit_id.state == 'submitted'">
                            <list class="o_qa_visit_line_list" editable="bottom" create="false" delete="false">
                                <field name="visit_section_id" column_invisible="1"/>
                                <field name="visit_id" column_invisible="1"/>
                                <field name="visit_state" column_invisible="1"/>
                                <field name="can_upload_attachment" column_invisible="1"/>
                                <field name="section_id" column_invisible="1"/>
                                <field name="standard_id" column_invisible="1"/>
                                <field name="sequence" widget="handle"/>
                                <field name="title" readonly="1"/>
                                <field name="max_score" readonly="1"/>
                                <field name="score" options="{'type': 'number', 'step': 1}" class="o_qa_score_column"/>
                                <field name="percentage" readonly="1" class="o_qa_percentage_column"/>
                                <field name="note" string="Score Note" optional="show"/>
                                <field name="attachment" widget="qa_list_binary" filename="attachment_name"/>
                                <field name="attachment_name" optional="hide"/>
                            </list>
                            <form string="Standard Evaluation" create="false" delete="false">
                                <sheet>
                                    <field name="visit_id" invisible="1"/>
                                    <field name="visit_section_id" invisible="1"/>
                                    <field name="section_id" invisible="1"/>
                                    <field name="standard_id" invisible="1"/>
                                    <group>
                                        <group>
                                            <field name="section_id" readonly="1"/>
                                            <field name="title" readonly="1"/>
                                            <field name="max_score" readonly="1"/>
                                            <field name="percentage" readonly="1"/>
                                        </group>
                                        <group>
                                            <field name="score" readonly="visit_id.state == 'submitted'" options="{'type': 'number', 'step': 1}"/>
                                            <field name="has_attachment" readonly="1"/>
                                            <button name="action_download_attachment" type="object" string="Download Attachment" icon="fa-paperclip" class="btn-secondary" invisible="not has_attachment"/>
                                        </group>
                                    </group>
                                    <group>
                                        <field name="note" string="Score Note" placeholder="Clarify the reason for this score..." readonly="visit_id.state == 'submitted'"/>
                                    </group>
                                    <group>
                                        <field name="attachment" filename="attachment_name" readonly="visit_id.state == 'submitted'"/>
                                        <field name="attachment_name" invisible="1"/>
                                    </group>
                                </sheet>
                            </form>
                        </field>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="ab_quality_assurance_visit_line_view_form" model="ir.ui.view">
            <field name="name">ab_quality_assurance_visit_line.form</field>
            <field name="model">ab_quality_assurance_visit_line</field>
            <field name="arch" type="xml">
                <form string="Standard Evaluation">
                    <sheet>
                        <field name="visit_id" invisible="1"/>
                        <field name="visit_section_id" invisible="1"/>
                        <field name="section_id" invisible="1"/>
                        <field name="standard_id" invisible="1"/>
                        <group>
                            <group>
                                <field name="section_id" readonly="1"/>
                                <field name="title" readonly="1"/>
                                <field name="max_score" readonly="1"/>
                                <field name="percentage" readonly="1"/>
                            </group>
                            <group>
                                <field name="score" readonly="visit_id.state == 'submitted'" options="{'type': 'number', 'step': 1}"/>
                                <field name="has_attachment" readonly="1"/>
                                <button name="action_download_attachment" type="object" string="Download Attachment" icon="fa-paperclip" class="btn-secondary" invisible="not has_attachment"/>
                            </group>
                        </group>
                        <group>
                            <field name="note" string="Score Note" placeholder="Clarify the reason for this score..." readonly="visit_id.state == 'submitted'"/>
                        </group>
                        <group>
                            <field name="attachment" filename="attachment_name" readonly="visit_id.state == 'submitted'"/>
                            <field name="attachment_name" invisible="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="ab_quality_assurance_visit_view_list" model="ir.ui.view">
            <field name="name">ab_quality_assurance_visit.list</field>
            <field name="model">ab_quality_assurance_visit</field>
            <field name="arch" type="xml">
                <list string="Visits"
                      class="o_qa_visit_list"
                      default_order="visit_date desc, id desc"
                      decoration-success="state == 'submitted'"
                      decoration-warning="state == 'draft'">
                    <field name="name"/>
                    <field name="department_id"/>
                    <field name="employee_id"/>
                    <field name="visit_date"/>
                    <field name="department_manager_id" optional="hide"/>
                    <field name="section_count"/>
                    <field name="earned_total_score"/>
                    <field name="max_total_score" optional="hide"/>
                    <field name="total_percentage" widget="progressbar"/>
                    <field name="submitted_at" optional="show"/>
                    <field name="state" widget="badge"
                           decoration-success="state == 'submitted'"
                           decoration-warning="state == 'draft'"/>
                    <button name="action_export_pdf" type="object" icon="fa-file-pdf-o" title="Download PDF" class="o_qa_export_pdf"/>
                    <button name="action_export_xlsx" type="object" icon="fa-file-excel-o" title="Download Sheet" class="o_qa_export_xlsx"/>
                </list>
            </field>
        </record>

        <record id="ab_quality_assurance_visit_view_form" model="ir.ui.view">
            <field name="name">ab_quality_assurance_visit.form</field>
            <field name="model">ab_quality_assurance_visit</field>
            <field name="arch" type="xml">
                <form string="Quality Visit" class="o_qa_visit_form">
                    <header>
                        <button name="action_export_pdf" type="object" string="Export PDF" icon="fa-file-pdf-o" class="btn-secondary o_qa_export_pdf" invisible="not id"/>
                        <button name="action_export_xlsx" type="object" string="Export Excel" icon="fa-file-excel-o" class="btn-secondary o_qa_export_xlsx" invisible="not id"/>
                        <button name="action_submit_visit" type="object" string="Submit Visit"
                                class="btn-primary"
                                invisible="state != 'draft' or not can_edit_evaluation"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,submitted"/>
                    </header>
                    <sheet>
                        <widget name="web_ribbon" title="Submitted" bg_color="bg-success" invisible="state != 'submitted'"/>
                        <field name="user_id" invisible="1"/>
                        <field name="state" invisible="1"/>
                        <field name="can_edit_evaluation" invisible="1"/>
                        <field name="can_manage_follow_up" invisible="1"/>
                        <field name="can_edit_follow_up_response" invisible="1"/>
                        <div class="o_qa_visit_hero">
                            <div class="o_qa_visit_hero__content">
                                <div class="o_form_label o_qa_visit_hero__eyebrow">
                                    <field name="ui_hero_eyebrow" nolabel="1" readonly="1"/>
                                </div>
                                <div class="oe_title o_qa_visit_hero__title">
                                    <h1>
                                        <field name="ui_title" readonly="1" nolabel="1"/>
                                    </h1>
                                </div>
                                <div class="o_form_label o_qa_visit_hero__subtitle text-muted">
                                    <field name="ui_hero_subtitle" nolabel="1" readonly="1"/>
                                </div>
                            </div>
                            <div class="o_qa_visit_hero__aside">
                                <div class="o_qa_visit_status_card">
                                    <div class="o_form_label o_qa_visit_status_card__label">
                                        <field name="ui_status_label" nolabel="1" readonly="1"/>
                                    </div>
                                    <div class="o_qa_visit_status_card__value">
                                        <field name="state" nolabel="1" widget="badge"
                                               decoration-success="state == 'submitted'"
                                               decoration-warning="state == 'draft'"/>
                                    </div>
                                    <div class="o_form_label o_qa_visit_status_card__hint" invisible="state != 'submitted'">
                                        <field name="ui_status_submitted_at_label" nolabel="1" readonly="1"/>
                                    </div>
                                    <div class="o_qa_visit_status_card__hint text-muted" invisible="state != 'draft'">
                                        <span><field name="ui_status_draft_hint" nolabel="1" readonly="1"/></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="o_qa_visit_overview">
                            <div class="o_qa_visit_overview_card">
                                <div class="o_qa_visit_overview_card__head">
                                    <div class="o_form_label o_qa_visit_overview_card__eyebrow">
                                        <field name="ui_overview_department_eyebrow" nolabel="1" readonly="1"/>
                                    </div>
                                    <div class="o_form_label o_qa_visit_overview_card__title">
                                        <field name="ui_overview_department_title" nolabel="1" readonly="1"/>
                                    </div>
                                </div>
                                <div class="o_qa_visit_overview_card__body">
                                    <div class="o_qa_visit_overview_item">
                                        <div class="o_form_label o_qa_visit_overview_item__label">
                                            <field name="ui_overview_department_label" nolabel="1" readonly="1"/>
                                        </div>
                                        <field name="department_id" nolabel="1" readonly="state == 'submitted' or not can_edit_evaluation"
                                               domain="[('name', '=like', 'فرع%')]"/>
                                    </div>
                                    <div class="o_qa_visit_overview_item">
                                        <div class="o_form_label o_qa_visit_overview_item__label">
                                            <field name="ui_overview_department_manager_label" nolabel="1" readonly="1"/>
                                        </div>
                                        <field name="department_manager_id" nolabel="1" readonly="1"/>
                                    </div>
                                </div>
                            </div>
                            <div class="o_qa_visit_overview_card">
                                <div class="o_qa_visit_overview_card__head">
                                    <div class="o_form_label o_qa_visit_overview_card__eyebrow">
                                        <field name="ui_visit_eyebrow" nolabel="1" readonly="1"/>
                                    </div>
                                    <div class="o_form_label o_qa_visit_overview_card__title">
                                        <field name="ui_visit_title" nolabel="1" readonly="1"/>
                                    </div>
                                </div>
                                <div class="o_qa_visit_overview_card__body">
                                    <div class="o_qa_visit_overview_item">
                                        <div class="o_form_label o_qa_visit_overview_item__label">
                                            <field name="ui_visit_date_label" nolabel="1" readonly="1"/>
                                        </div>
                                        <field name="visit_date" nolabel="1" readonly="state == 'submitted' or not can_edit_evaluation"/>
                                    </div>
                                    <div class="o_qa_visit_overview_item" invisible="not id">
                                        <div class="o_form_label o_qa_visit_overview_item__label">
                                            <field name="ui_visit_performer_label" nolabel="1" readonly="1"/>
                                        </div>
                                        <field name="employee_id" nolabel="1" readonly="state == 'submitted' or not can_edit_evaluation"/>
                                    </div>
                                    <div class="o_qa_visit_overview_item" invisible="state != 'submitted'">
                                        <div class="o_form_label o_qa_visit_overview_item__label">
                                            <field name="ui_visit_submitted_at_label" nolabel="1" readonly="1"/>
                                        </div>
                                        <field name="submitted_at" nolabel="1" readonly="1"/>
                                    </div>
                                </div>
                            </div>
                            <div class="o_qa_visit_overview_card is-highlight">
                                <div class="o_qa_visit_overview_card__head">
                                    <div class="o_form_label o_qa_visit_overview_card__eyebrow">
                                        <field name="ui_result_eyebrow" nolabel="1" readonly="1"/>
                                    </div>
                                    <div class="o_form_label o_qa_visit_overview_card__title">
                                        <field name="ui_result_title" nolabel="1" readonly="1"/>
                                    </div>
                                </div>
                                <div class="o_qa_visit_overview_card__body">
                                    <div class="o_qa_visit_metric is-highlight">
                                        <div class="o_form_label o_qa_visit_metric__label">
                                            <field name="ui_overall_percentage_label" nolabel="1" readonly="1"/>
                                        </div>
                                        <field name="total_percentage" nolabel="1" readonly="1" widget="progressbar" class="o_qa_visit_metric__value"/>
                                    </div>
                                    <div class="o_qa_visit_overview_stats">
                                        <div class="o_qa_visit_overview_stat">
                                            <div class="o_form_label">
                                                <field name="ui_sections_label" nolabel="1" readonly="1"/>
                                            </div>
                                            <field name="section_count" nolabel="1" readonly="1"/>
                                        </div>
                                        <div class="o_qa_visit_overview_stat">
                                            <div class="o_form_label">
                                                <field name="ui_earned_score_label" nolabel="1" readonly="1"/>
                                            </div>
                                            <field name="earned_total_score" nolabel="1" readonly="1"/>
                                        </div>
                                        <div class="o_qa_visit_overview_stat">
                                            <div class="o_form_label">
                                                <field name="ui_maximum_score_label" nolabel="1" readonly="1"/>
                                            </div>
                                            <field name="max_total_score" nolabel="1" readonly="1"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="o_qa_visit_notes_card">
                            <div class="o_form_label o_qa_visit_summary_header">
                                <field name="ui_visit_notes_title" nolabel="1" readonly="1"/>
                            </div>
                            <div class="o_form_label o_qa_visit_notes_card__subtitle text-muted">
                                <field name="ui_visit_notes_subtitle" nolabel="1" readonly="1"/>
                            </div>
                            <div class="o_form_label o_qa_visit_notes_card__hint text-muted">
                                <field name="ui_visit_notes_hint" nolabel="1" readonly="1"/>
                            </div>
                            <field name="notes"
                                   nolabel="1"
                                   readonly="state == 'submitted' or not can_edit_evaluation"/>
                        </div>
                        <notebook>
                            <page string="Sections">
                                <div class="o_qa_visit_section_intro">
                                    <div>
                                        <strong>
                                            <field name="ui_evaluation_sections_title" nolabel="1" readonly="1"/>
                                        </strong>
                                        <span class="text-muted">
                                            <field name="ui_evaluation_sections_subtitle" nolabel="1" readonly="1"/>
                                        </span>
                                    </div>
                                </div>
                                <field name="visit_section_ids" readonly="state == 'submitted' or not can_edit_evaluation">
                                    <list class="o_qa_visit_section_list" create="false" delete="false" open_form_view="True">
                                        <field name="section_id" column_invisible="1"/>
                                        <field name="sequence" widget="handle"/>
                                        <field name="name" string="Section" readonly="1"/>
                                        <field name="earned_score" readonly="1"/>
                                        <field name="max_score" readonly="1"/>
                                        <field name="percentage" readonly="1" widget="progressbar"/>
                                    </list>
                                    <form string="Visit Review Section" create="false" delete="false">
                                        <sheet>
                                            <field name="visit_id" invisible="1"/>
                                            <field name="section_id" invisible="1"/>
                                            <div class="o_qa_visit_summary_card">
                                                <div class="o_qa_visit_summary_header">
                                                    <field name="name" readonly="1"/>
                                                </div>
                                                <group col="3">
                                                    <field name="earned_score" readonly="1"/>
                                                    <field name="max_score" readonly="1"/>
                                                    <field name="percentage" readonly="1"/>
                                                </group>
                                            </div>
                                            <field name="visit_line_ids" readonly="visit_id.state == 'submitted'">
                                                <list class="o_qa_visit_line_list" editable="bottom" create="false" delete="false">
                                                    <field name="visit_section_id" column_invisible="1"/>
                                                    <field name="visit_id" column_invisible="1"/>
                                                    <field name="visit_state" column_invisible="1"/>
                                                    <field name="can_upload_attachment" column_invisible="1"/>
                                                    <field name="section_id" column_invisible="1"/>
                                                    <field name="standard_id" column_invisible="1"/>
                                                    <field name="sequence" widget="handle"/>
                                                    <field name="title" readonly="1"/>
                                                    <field name="max_score" readonly="1"/>
                                                    <field name="score" options="{'type': 'number', 'step': 1}" class="o_qa_score_column"/>
                                                    <field name="percentage" readonly="1" class="o_qa_percentage_column"/>
                                                    <field name="note" string="Score Note" optional="show"/>
                                                    <field name="attachment" widget="qa_list_binary" filename="attachment_name"/>
                                                    <field name="attachment_name" optional="hide"/>
                                                </list>
                                                <form string="Visit Standard Score" create="false" delete="false">
                                                    <sheet>
                                                        <field name="visit_id" invisible="1"/>
                                                        <field name="visit_section_id" invisible="1"/>
                                                        <field name="section_id" invisible="1"/>
                                                        <field name="standard_id" invisible="1"/>
                                                        <group>
                                                            <group>
                                                                <field name="section_id" readonly="1"/>
                                                                <field name="title" readonly="1"/>
                                                                <field name="max_score" readonly="1"/>
                                                                <field name="percentage" readonly="1"/>
                                                            </group>
                                                            <group>
                                                                <field name="score" readonly="visit_id.state == 'submitted'" options="{'type': 'number', 'step': 1}"/>
                                                                <field name="has_attachment" readonly="1"/>
                                                                <button name="action_download_attachment" type="object" string="Download Attachment" icon="fa-paperclip" class="btn-secondary" invisible="not has_attachment"/>
                                                            </group>
                                                        </group>
                                                        <group>
                                                            <field name="note" string="Score Note" placeholder="Clarify the reason for this score..." readonly="visit_id.state == 'submitted'"/>
                                                        </group>
                                                        <group>
                                                            <field name="attachment" filename="attachment_name" readonly="visit_id.state == 'submitted'"/>
                                                            <field name="attachment_name" invisible="1"/>
                                                        </group>
                                                    </sheet>
                                                </form>
                                            </field>
                                        </sheet>
                                    </form>
                                </field>
                                <div class="o_qa_follow_up_card">
                                    <div class="o_form_label o_qa_visit_summary_header">Follow Up</div>
                                    <field name="follow_up_ids"
                                           nolabel="1"
                                           invisible="not can_manage_follow_up">
                                        <list class="o_qa_follow_up_list" editable="bottom" create="true" delete="true">
                                            <field name="can_edit_response" column_invisible="1"/>
                                            <field name="can_manage_follow_up" column_invisible="1"/>
                                            <field name="sequence" widget="handle"/>
                                            <field name="department_id"
                                                   string="Management"
                                                   domain="[('name', 'not like', 'فرع%')]"
                                                   options="{'no_create_edit': True}"
                                                   readonly="not can_manage_follow_up"/>
                                            <field name="response"
                                                   string="Management Response"
                                                   placeholder="Add response..."
                                                   readonly="not can_edit_response"/>
                                            <field name="response_user_id" readonly="1" optional="show"/>
                                            <field name="response_date" readonly="1" optional="show"/>
                                        </list>
                                        <form string="Follow Up">
                                            <sheet>
                                                <field name="can_edit_response" invisible="1"/>
                                                <field name="can_manage_follow_up" invisible="1"/>
                                                <group>
                                                    <field name="department_id"
                                                           string="Management"
                                                           domain="[('name', 'not like', 'فرع%')]"
                                                           options="{'no_create_edit': True}"
                                                           readonly="not can_manage_follow_up"/>
                                                    <field name="response_user_id" readonly="1"/>
                                                    <field name="response_date" readonly="1"/>
                                                </group>
                                                <group>
                                                    <field name="response"
                                                           string="Management Response"
                                                           placeholder="Add response..."
                                                           readonly="not can_edit_response"/>
                                                </group>
                                            </sheet>
                                        </form>
                                    </field>
                                    <field name="follow_up_ids"
                                           nolabel="1"
                                           invisible="can_manage_follow_up"
                                           readonly="not can_edit_follow_up_response">
                                        <list class="o_qa_follow_up_list" editable="bottom" create="false" delete="false">
                                            <field name="can_edit_response" column_invisible="1"/>
                                            <field name="can_manage_follow_up" column_invisible="1"/>
                                            <field name="sequence" column_invisible="1"/>
                                            <field name="department_id" string="Management" readonly="1"/>
                                            <field name="response"
                                                   string="Management Response"
                                                   placeholder="Add response..."
                                                   readonly="not can_edit_response"/>
                                            <field name="response_user_id" readonly="1" optional="show"/>
                                            <field name="response_date" readonly="1" optional="show"/>
                                        </list>
                                        <form string="Follow Up">
                                            <sheet>
                                                <field name="can_edit_response" invisible="1"/>
                                                <group>
                                                    <field name="department_id" string="Management" readonly="1"/>
                                                    <field name="response_user_id" readonly="1"/>
                                                    <field name="response_date" readonly="1"/>
                                                </group>
                                                <group>
                                                    <field name="response"
                                                           string="Management Response"
                                                           placeholder="Add response..."
                                                           readonly="not can_edit_response"/>
                                                </group>
                                            </sheet>
                                        </form>
                                    </field>
                                </div>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="ab_quality_assurance_visit_view_search" model="ir.ui.view">
            <field name="name">ab_quality_assurance_visit.search</field>
            <field name="model">ab_quality_assurance_visit</field>
            <field name="arch" type="xml">
                <search string="Visits">
                    <field name="name"/>
                    <field name="department_id"/>
                    <field name="employee_id"/>
                    <field name="visit_date"/>
                    <separator/>
                    <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                    <filter name="filter_submitted" string="Submitted" domain="[('state', '=', 'submitted')]"/>
                    <separator/>
                    <filter name="group_by_department" string="Department" context="{'group_by': 'department_id'}"/>
                    <filter name="group_by_employee" string="Performer" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                </search>
            </field>
        </record>

        <record id="ab_quality_assurance_visit_action" model="ir.actions.act_window">
            <field name="name">Visits</field>
            <field name="res_model">ab_quality_assurance_visit</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_filter_submitted': 1}</field>
            <field name="search_view_id" ref="ab_quality_assurance_visit_view_search"/>
        </record>

        <record id="ab_quality_assurance_visit_draft_action" model="ir.actions.act_window">
            <field name="name">Drafts</field>
            <field name="res_model">ab_quality_assurance_visit</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_filter_draft': 1}</field>
            <field name="search_view_id" ref="ab_quality_assurance_visit_view_search"/>
        </record>
    </data>
</odoo>
