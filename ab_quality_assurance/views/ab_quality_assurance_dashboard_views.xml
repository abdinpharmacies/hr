<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ab_quality_assurance_dashboard_view_list" model="ir.ui.view">
            <field name="name">ab_quality_assurance_department_dashboard.list</field>
            <field name="model">ab_quality_assurance_department_dashboard</field>
            <field name="arch" type="xml">
                <list string="Department Performance Dashboard">
                    <field name="department_id"/>
                    <field name="visit_count"/>
                    <field name="submitted_visit_count"/>
                    <field name="avg_earned_score"/>
                    <field name="avg_percentage"/>
                    <field name="best_percentage"/>
                    <field name="last_visit_date"/>
                </list>
            </field>
        </record>

        <record id="ab_quality_assurance_dashboard_view_graph" model="ir.ui.view">
            <field name="name">ab_quality_assurance_department_dashboard.graph</field>
            <field name="model">ab_quality_assurance_department_dashboard</field>
            <field name="arch" type="xml">
                <graph string="Department Performance" type="bar">
                    <field name="department_id" type="row"/>
                    <field name="avg_percentage" type="measure"/>
                    <field name="submitted_visit_count" type="measure"/>
                </graph>
            </field>
        </record>

        <record id="ab_quality_assurance_dashboard_view_pivot" model="ir.ui.view">
            <field name="name">ab_quality_assurance_department_dashboard.pivot</field>
            <field name="model">ab_quality_assurance_department_dashboard</field>
            <field name="arch" type="xml">
                <pivot string="Department Performance">
                    <field name="department_id" type="row"/>
                    <field name="visit_count" type="measure"/>
                    <field name="submitted_visit_count" type="measure"/>
                    <field name="avg_earned_score" type="measure"/>
                    <field name="avg_percentage" type="measure"/>
                    <field name="best_percentage" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="ab_quality_assurance_dashboard_action" model="ir.actions.act_window">
            <field name="name">Dashboard</field>
            <field name="res_model">ab_quality_assurance_department_dashboard</field>
            <field name="view_mode">graph,list,pivot</field>
        </record>
    </data>
</odoo>
