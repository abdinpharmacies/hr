<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="category_ab_quality_assurance" model="ir.module.category">
            <field name="name">Quality Assurance</field>
            <field name="sequence">35</field>
        </record>

        <record id="privilege_ab_quality_assurance" model="res.groups.privilege">
            <field name="name">Quality Assurance</field>
            <field name="category_id" ref="category_ab_quality_assurance"/>
            <field name="sequence">35</field>
        </record>

        <record id="group_ab_quality_assurance_member" model="res.groups">
            <field name="name">Quality Assurance Member</field>
            <field name="privilege_id" ref="privilege_ab_quality_assurance"/>
        </record>

        <record id="group_ab_quality_assurance_manager" model="res.groups">
            <field name="name">Quality Assurance Department Manager</field>
            <field name="privilege_id" ref="privilege_ab_quality_assurance"/>
            <field name="implied_ids" eval="[(4, ref('ab_quality_assurance.group_ab_quality_assurance_member'))]"/>
        </record>

        <record id="group_ab_quality_assurance_admin" model="res.groups">
            <field name="name">Quality Assurance Admin</field>
            <field name="privilege_id" ref="privilege_ab_quality_assurance"/>
            <field name="implied_ids" eval="[(4, ref('ab_quality_assurance.group_ab_quality_assurance_manager'))]"/>
        </record>

        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('ab_quality_assurance.group_ab_quality_assurance_admin'))]"/>
        </record>
    </data>
</odoo>
