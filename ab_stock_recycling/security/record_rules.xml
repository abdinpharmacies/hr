<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="rule_ab_stock_recycling_header_user" model="ir.rule">
            <field name="name">rule_ab_stock_recycling_header_user</field>
            <field name="model_id" ref="model_ab_stock_recycling_header"/>
            <field name="groups" eval="[(4, ref('group_ab_stock_recycling_user'))]"/>
            <field name="domain_force">[
                '|',
                ('create_uid', '=', False),
                ('create_uid', '=', user.id),
            ]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <record id="rule_ab_stock_recycling_header_manager" model="ir.rule">
            <field name="name">rule_ab_stock_recycling_header_manager</field>
            <field name="model_id" ref="model_ab_stock_recycling_header"/>
            <field name="groups" eval="[(4, ref('group_ab_stock_recycling_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>