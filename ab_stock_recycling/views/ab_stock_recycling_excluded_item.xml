<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="ab_stock_recycling_excluded_item_view_tree" model="ir.ui.view">
            <field name="name">ab_stock_recycling_excluded_item_view_tree</field>
            <field name="model">ab_stock_recycling_excluded_item</field>
            <field name="arch" type="xml">
                <list multi_edit="1" editable="top" string="ab_stock_recycling_excluded_item_tree">
                    <field name="item_code" string="Code" optional="show"/>
                    <field name="item_id" string="Item" optional="show"/>
                    <field name="exclusion_reason" string="Exclusion Reason" optional="show"/>
                </list>
            </field>
        </record>

        <record id="ab_stock_recycling_excluded_item_view_form" model="ir.ui.view">
            <field name="name">ab_stock_recycling_excluded_item_view_form</field>
            <field name="model">ab_stock_recycling_excluded_item</field>
            <field name="arch" type="xml">
                <form string="ab_stock_recycling_excluded_item_form">
                    <sheet>
                        <group>
                            <field name="item_code"/>
                            <field name="item_id"/>
                            <field name="exclusion_reason"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="ab_stock_recycling_excluded_item_view_pivot" model="ir.ui.view">
            <field name="name">ab_stock_recycling_excluded_item_view_pivot</field>
            <field name="model">ab_stock_recycling_excluded_item</field>
            <field name="arch" type="xml">
                <pivot string="ab_stock_recycling_excluded_item_pivot">
                </pivot>
            </field>
        </record>


        <record id="ab_stock_recycling_excluded_item_action" model="ir.actions.act_window">
            <field name="name">Ab stock recycling excluded item</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">ab_stock_recycling_excluded_item</field>
            <field name="view_mode">list,form,pivot</field>
        </record>

        <menuitem id="ab_stock_recycling_excluded_item_menu"
                  name="Excluded Items"
                  parent="ab_stock_recycling_data_sub_menu"
                  action="ab_stock_recycling_excluded_item_action"
                  sequence="101"/>

    </data>
</odoo>
