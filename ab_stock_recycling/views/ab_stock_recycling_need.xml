<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ab_stock_recycling_need_view_tree" model="ir.ui.view">
            <field name="name">ab_stock_recycling_need_view_tree</field>
            <field name="model">ab_stock_recycling_need</field>
            <field name="arch" type="xml">
                <list string="ab_stock_recycling_need_tree">
                    <field name="header_id" optional="hide"/>
                    <field name="item_code" optional="show"/>
                    <field name="item_id" optional="show"/>
                    <field name="parent_item_code" optional="hide"/>
                    <field name="parent_item_id" optional="hide"/>
                    <field name="item_cost" optional="show"/>
                    <field name="item_price" optional="show"/>
                    <field name="store_id" optional="show"/>
                    <field name="supplier_id" optional="show"/>
                    <field name="sales_qty" optional="show"/>
                    <field name="balance" optional="show"/>
                    <field name="qty" optional="show"/>
                    <field name="total_price" optional="show"/>
                    <field name="given_qty" optional="show"/>

                </list>
            </field>
        </record>

        <record id="ab_stock_recycling_need_view_form" model="ir.ui.view">
            <field name="name">ab_stock_recycling_need_view_form</field>
            <field name="model">ab_stock_recycling_need</field>
            <field name="arch" type="xml">
                <form string="ab_stock_recycling_need_form">
                    <sheet>
                        <group>
                            <field name="store_id"/>
                            <field name="item_code"/>
                            <field name="item_id"/>
                            <field name="sales_qty"/>
                            <field name="balance"/>
                            <field name="qty"/>
                            <field name="given_qty"/>

                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="ab_stock_recycling_need_view_pivot" model="ir.ui.view">
            <field name="name">ab_stock_recycling_need_view_pivot</field>
            <field name="model">ab_stock_recycling_need</field>
            <field name="arch" type="xml">
                <pivot string="ab_stock_recycling_need_pivot">
                </pivot>
            </field>
        </record>
        <record id="ab_stock_recycling_need_search" model="ir.ui.view">
            <field name="name"></field>
            <field name="model">ab_stock_recycling_need</field>
            <field name="arch" type="xml">
                <search string="ab_stock_recycling_need_search">
                    <field name="store_id"/>
                    <field name="item_id"/>
                    <field name="sales_qty"/>
                    <field name="balance"/>
                    <field name="qty"/>
                </search>
            </field>
        </record>

        <record id="ab_stock_recycling_need_action" model="ir.actions.act_window">
            <field name="name">Stock Need</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">ab_stock_recycling_need</field>
            <field name="view_mode">list,form,pivot</field>
        </record>

        <menuitem id="ab_stock_recycling_need_menu"
                  name="Need"
                  parent="ab_stock_recycling_data_sub_menu"
                  action="ab_stock_recycling_need_action"
                  sequence="2"/>


    </data>
</odoo>