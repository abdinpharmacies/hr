<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="abdin_eplus_ab_region_view_tree" model="ir.ui.view">
            <field name="name">abdin_eplus_ab_region_view_tree</field>
            <field name="model">abdin_eplus_ab_region</field>
            <field name="arch" type="xml">
                <list string="abdin_eplus_ab_region_tree">
                    <field name="name" string="Name" optional="show"/>
                </list>
            </field>
        </record>

        <record id="abdin_eplus_ab_region_view_form" model="ir.ui.view">
            <field name="name">abdin_eplus_ab_region_view_form</field>
            <field name="model">abdin_eplus_ab_region</field>
            <field name="arch" type="xml">
                <form string="abdin_eplus_ab_region_form">
                    <sheet>
                        <group>
                            <field name="name" string="Name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="abdin_eplus_ab_region_view_search" model="ir.ui.view">
            <field name="name">abdin_eplus_ab_region_view_search</field>
            <field name="model">abdin_eplus_ab_region</field>
            <field name="arch" type="xml">
                <search string="abdin_eplus_ab_region_search">
                    <field name="name" string="Name" optional="show"/>
                </search>
            </field>
        </record>
        <record id="abdin_eplus_ab_region_view_pivot" model="ir.ui.view">
            <field name="name">abdin_eplus_ab_region_view_pivot</field>
            <field name="model">abdin_eplus_ab_region</field>
            <field name="arch" type="xml">
                <pivot string="abdin_eplus_ab_region_pivot">
                </pivot>
            </field>
        </record>


        <record id="abdin_eplus_ab_region_action" model="ir.actions.act_window">
            <field name="name">Abdin eplus.ab region</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">abdin_eplus_ab_region</field>
            <field name="view_mode">list,form,pivot</field>
        </record>

        <menuitem id="abdin_eplus_ab_region_menu"
                  name="Region"
                  parent="config_sub_menu"
                  action="abdin_eplus_ab_region_action"
                  sequence="100"/>


    </data>
</odoo>
