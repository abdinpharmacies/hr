<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ab_internal_shipment_delivery_wizard_view_form" model="ir.ui.view">
            <field name="name">ab_internal_shipment.delivery_wizard.form</field>
            <field name="model">ab_internal_shipment.delivery_wizard</field>
            <field name="arch" type="xml">
                <form string="Capture Delivery Evidence">
                    <sheet>
                        <group>
                            <field name="shipment_id" invisible="1"/>
                            <field name="evidence_required" invisible="1"/>
                            <field name="delivery_proof_attachment_ids"
                                   widget="ais_delivery_evidence"
                                   nolabel="1"
                                   options="{'accepted_file_extensions': 'image/*'}"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_confirm_delivery"
                                type="object"
                                string="Deliver"
                                class="btn-primary"/>
                        <button string="Cancel" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
