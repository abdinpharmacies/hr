<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ab_internal_shipment_view_list" model="ir.ui.view">
            <field name="name">ab_internal_shipment.list</field>
            <field name="model">ab_internal_shipment</field>
            <field name="arch" type="xml">
                <list string="Internal Shipments"
                      decoration-muted="state == 'closed'"
                      decoration-danger="is_delayed"
                      decoration-success="state in ('received', 'closed')"
                      decoration-info="state in ('sent', 'in_transit')">
                    <field name="name"/>
                    <field name="shipment_date"/>
                    <field name="subject"/>
                    <field name="shipment_type"/>
                    <field name="delivery_method"/>
                    <field name="sender_display"/>
                    <field name="recipient_display"/>
                    <field name="current_holder_display"/>
                    <field name="expected_delivery_date" optional="show"/>
                    <field name="is_delayed" optional="hide"/>
                    <field name="state"/>
                    <field name="created_by_id" optional="hide"/>
                    <field name="sent_by_id" optional="hide"/>
                    <field name="delivered_by_id" optional="hide"/>
                    <field name="received_by_id" optional="hide"/>
                    <field name="create_date" optional="hide"/>
                    <field name="write_date" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="ab_internal_shipment_view_form" model="ir.ui.view">
            <field name="name">ab_internal_shipment.form</field>
            <field name="model">ab_internal_shipment</field>
            <field name="arch" type="xml">
                <form string="Internal Shipment">
                    <header>
                        <button name="action_send" type="object" string="Send" class="btn-primary"
                                invisible="state != 'draft'"/>
                        <button name="action_mark_in_transit" type="object" string="Mark In Transit"
                                invisible="state != 'sent'"/>
                        <button name="action_deliver" type="object" string="Mark Delivered" class="btn-primary"
                                invisible="state not in ('sent', 'in_transit')"/>
                        <button name="action_receive" type="object" string="Confirm Receipt" class="btn-primary"
                                invisible="state != 'awaiting_receipt' or not is_receipt_confirmation_user"/>
                        <button name="action_close" type="object" string="Close"
                                invisible="state != 'received'"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,sent,in_transit,awaiting_receipt,received,closed"/>
                    </header>
                    <sheet>
                        <field name="is_delayed" invisible="1"/>
                        <field name="is_receipt_confirmation_user" invisible="1"/>
                        <widget name="web_ribbon" title="Delayed" bg_color="text-bg-danger"
                                invisible="not is_delayed"/>
                        <widget name="web_ribbon" title="Closed"
                                invisible="state != 'closed'"/>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Shipment Information">
                                <field name="subject" readonly="state != 'draft'"/>
                                <field name="shipment_date" readonly="state != 'draft'"/>
                                <field name="expected_delivery_date" readonly="state in ('received', 'closed')"/>
                                <field name="shipment_type" readonly="state != 'draft'"/>
                                <field name="delivery_method" readonly="state != 'draft'"/>
                            </group>
                            <group string="Current Location">
                                <field name="current_holder_display" readonly="1"/>
                                <field name="current_holder_type" readonly="1"/>
                                <field name="current_holder_user_id" readonly="1"/>
                                <field name="created_by_id"/>
                            </group>
                        </group>
                        <group>
                            <group string="Sender">
                                <field name="sender_type" readonly="state != 'draft'"/>
                                <field name="sender_store_id"
                                       invisible="sender_type != 'branch'"
                                       required="sender_type == 'branch'"
                                       readonly="state != 'draft'"/>
                                <field name="sender_department_id"
                                       invisible="sender_type != 'department'"
                                       required="sender_type == 'department'"
                                       readonly="state != 'draft'"/>
                                <field name="sender_employee_id"
                                       invisible="sender_type != 'employee'"
                                       required="sender_type == 'employee'"
                                       readonly="state != 'draft'"/>
                                <field name="sender_user_id" readonly="1"/>
                            </group>
                            <group string="Recipient">
                                <field name="recipient_type" readonly="state != 'draft'"/>
                                <field name="recipient_store_id"
                                       invisible="recipient_type != 'branch'"
                                       required="recipient_type == 'branch'"
                                       readonly="state != 'draft'"/>
                                <field name="recipient_department_id"
                                       invisible="recipient_type != 'department'"
                                       required="recipient_type == 'department'"
                                       readonly="state != 'draft'"/>
                                <field name="recipient_employee_id"
                                       invisible="recipient_type != 'employee'"
                                       required="recipient_type == 'employee'"
                                       readonly="state != 'draft'"/>
                                <field name="recipient_user_id" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Contents">
                                <field name="line_ids" readonly="state != 'draft'">
                                    <list editable="bottom">
                                        <field name="item_name"/>
                                        <field name="description"/>
                                        <field name="quantity"/>
                                        <field name="notes"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Tracking">
                                <group>
                                    <group string="Dispatch">
                                        <field name="sent_by_id"/>
                                        <field name="sent_date"/>
                                        <field name="delivered_by_id"/>
                                        <field name="delivered_date"/>
                                    </group>
                                    <group string="Receipt">
                                        <field name="received_by_id"/>
                                        <field name="received_date"/>
                                        <field name="closed_by_id"/>
                                        <field name="closed_date"/>
                                    </group>
                                </group>
                                <field name="history_ids" nolabel="1">
                                    <list>
                                        <field name="action_date"/>
                                        <field name="action"/>
                                        <field name="action_by_id"/>
                                        <field name="state_from"/>
                                        <field name="state_to"/>
                                        <field name="from_holder_display"/>
                                        <field name="to_holder_display"/>
                                        <field name="notes"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Notes">
                                <group>
                                    <field name="description" nolabel="1" placeholder="Description"/>
                                    <field name="notes" nolabel="1" placeholder="Notes"/>
                                </group>
                            </page>
                            <page string="Delivery Proof">
                                <field name="delivery_proof_attachment_ids" widget="many2many_binary" nolabel="1"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="ab_internal_shipment_view_search" model="ir.ui.view">
            <field name="name">ab_internal_shipment.search</field>
            <field name="model">ab_internal_shipment</field>
            <field name="arch" type="xml">
                <search string="Internal Shipments">
                    <field name="name"/>
                    <field name="subject"/>
                    <field name="sender_display"/>
                    <field name="recipient_display"/>
                    <field name="current_holder_display"/>
                    <filter name="my_shipments" string="My Shipments"
                            domain="[('created_by_id', '=', uid)]"/>
                    <filter name="awaiting_receipt" string="Awaiting Receipt"
                            domain="[('is_receipt_confirmation_user', '=', True)]"/>
                    <filter name="delayed" string="Delayed"
                            domain="[('is_delayed', '=', True)]"/>
                    <separator/>
                    <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                    <filter name="sent" string="Sent" domain="[('state', '=', 'sent')]"/>
                    <filter name="in_transit" string="In Transit" domain="[('state', '=', 'in_transit')]"/>
                    <filter name="awaiting_receipt_state" string="Awaiting Receipt" domain="[('state', '=', 'awaiting_receipt')]"/>
                    <filter name="received" string="Received" domain="[('state', '=', 'received')]"/>
                    <filter name="closed" string="Closed" domain="[('state', '=', 'closed')]"/>
                    <separator/>
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                    <filter name="group_sender_type" string="Sender Type" context="{'group_by': 'sender_type'}"/>
                    <filter name="group_recipient_type" string="Recipient Type" context="{'group_by': 'recipient_type'}"/>
                    <filter name="group_shipment_type" string="Shipment Type" context="{'group_by': 'shipment_type'}"/>
                    <filter name="group_delivery_method" string="Delivery Method" context="{'group_by': 'delivery_method'}"/>
                    <filter name="group_current_holder" string="Current Holder" context="{'group_by': 'current_holder_display'}"/>
                    <filter name="group_shipment_date" string="Shipment Date" context="{'group_by': 'shipment_date'}"/>
                </search>
            </field>
        </record>

        <record id="ab_internal_shipment_view_pivot" model="ir.ui.view">
            <field name="name">ab_internal_shipment.pivot</field>
            <field name="model">ab_internal_shipment</field>
            <field name="arch" type="xml">
                <pivot string="Shipment Statistics">
                    <field name="state" type="row"/>
                    <field name="shipment_type" type="col"/>
                    <field name="shipment_count" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="ab_internal_shipment_view_graph" model="ir.ui.view">
            <field name="name">ab_internal_shipment.graph</field>
            <field name="model">ab_internal_shipment</field>
            <field name="arch" type="xml">
                <graph string="Shipment Statistics" type="bar">
                    <field name="state"/>
                    <field name="shipment_count" type="measure"/>
                </graph>
            </field>
        </record>

        <record id="ab_internal_shipment_action" model="ir.actions.act_window">
            <field name="name">Internal Shipments</field>
            <field name="res_model">ab_internal_shipment</field>
            <field name="view_mode">list,form,pivot,graph</field>
            <field name="domain">[('created_by_id', '=', uid)]</field>
            <field name="search_view_id" ref="ab_internal_shipment_view_search"/>
        </record>

        <record id="ab_internal_shipment_awaiting_receipt_action" model="ir.actions.act_window">
            <field name="name">Awaiting Receipt</field>
            <field name="res_model">ab_internal_shipment</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('is_receipt_confirmation_user', '=', True)]</field>
            <field name="search_view_id" ref="ab_internal_shipment_view_search"/>
            <field name="context">{'search_default_awaiting_receipt': 1, 'ab_awaiting_receipt_tab': 1}</field>
        </record>

        <record id="ab_internal_shipment_reporting_action" model="ir.actions.act_window">
            <field name="name">Shipment Statistics</field>
            <field name="res_model">ab_internal_shipment</field>
            <field name="view_mode">pivot,graph,list</field>
            <field name="search_view_id" ref="ab_internal_shipment_view_search"/>
        </record>
    </data>
</odoo>
