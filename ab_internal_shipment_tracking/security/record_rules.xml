<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Shipment record rules -->
        <record id="rule_ab_internal_shipment_user" model="ir.rule">
            <field name="name">Internal shipments: user read access</field>
            <field name="model_id" ref="model_ab_internal_shipment"/>
            <field name="groups" eval="[(4, ref('group_ab_internal_shipment_user'))]"/>
            <field name="domain_force">['|', '|', '|', '|', '|', '|',
                ('created_by_id', '=', user.id),
                '&amp;', ('sender_type', '=', 'employee'), ('sender_employee_id', 'in', user.ab_employee_ids.ids),
                '&amp;', ('sender_type', '=', 'employee'), ('sender_employee_id.department_id.manager_id.user_id', '=', user.id),
                '&amp;', ('sender_type', '=', 'employee'), ('sender_employee_id.department_id.store_id', 'in', user.ab_employee_ids.department_id.store_id.ids),
                '&amp;', ('sender_type', '=', 'department'), ('sender_department_id.manager_id.user_id', '=', user.id),
                '&amp;', ('sender_type', '=', 'branch'), ('sender_store_id', 'in', user.ab_employee_ids.department_id.store_id.ids),
                '|', '|',
                    '&amp;', ('recipient_type', '=', 'employee'), ('recipient_employee_id', 'in', user.ab_employee_ids.ids),
                    '&amp;', ('recipient_type', '=', 'department'), ('recipient_department_id.manager_id.user_id', '=', user.id),
                    '&amp;', ('recipient_type', '=', 'branch'), ('recipient_store_id', 'in', user.ab_employee_ids.department_id.store_id.ids)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_ab_internal_shipment_user_created_write" model="ir.rule">
            <field name="name">Internal shipments: creator workflow write</field>
            <field name="model_id" ref="model_ab_internal_shipment"/>
            <field name="groups" eval="[(4, ref('group_ab_internal_shipment_user'))]"/>
            <field name="domain_force">[('created_by_id', '=', user.id), ('state', 'in', ('draft', 'sent', 'in_transit'))]</field>
            <field name="perm_read" eval="0"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_ab_internal_shipment_user_recipient_write" model="ir.rule">
            <field name="name">Internal shipments: recipient receipt write</field>
            <field name="model_id" ref="model_ab_internal_shipment"/>
            <field name="groups" eval="[(4, ref('group_ab_internal_shipment_user'))]"/>
            <field name="domain_force">['&amp;', ('state', '=', 'awaiting_receipt'), '|', '|',
                '&amp;', ('recipient_type', '=', 'employee'), ('recipient_employee_id', 'in', user.ab_employee_ids.ids),
                '&amp;', ('recipient_type', '=', 'department'), ('recipient_department_id.manager_id.user_id', '=', user.id),
                '&amp;', ('recipient_type', '=', 'branch'), ('recipient_store_id', 'in', user.ab_employee_ids.department_id.store_id.ids)]</field>
            <field name="perm_read" eval="0"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_ab_internal_shipment_admin" model="ir.rule">
            <field name="name">Internal shipments: administrator all</field>
            <field name="model_id" ref="model_ab_internal_shipment"/>
            <field name="groups" eval="[(4, ref('group_ab_internal_shipment_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <record id="rule_ab_internal_shipment_recipient_received_read" model="ir.rule">
            <field name="name">Internal shipments: confirmed recipient read</field>
            <field name="model_id" ref="model_ab_internal_shipment"/>
            <field name="groups" eval="[(4, ref('group_ab_internal_shipment_user'))]"/>
            <field name="domain_force">[('received_by_id', '=', user.id)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_ab_internal_shipment_recipient_received_close_write" model="ir.rule">
            <field name="name">Internal shipments: confirmed recipient close write</field>
            <field name="model_id" ref="model_ab_internal_shipment"/>
            <field name="groups" eval="[(4, ref('group_ab_internal_shipment_user'))]"/>
            <field name="domain_force">[('state', '=', 'received'), ('received_by_id', '=', user.id)]</field>
            <field name="perm_read" eval="0"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

