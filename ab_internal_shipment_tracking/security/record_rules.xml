                '&amp;', ('shipment_id.sender_type', '=', 'employee'), ('shipment_id.sender_employee_id', 'in', user.ab_employee_ids.ids),
                '&amp;', ('shipment_id.sender_type', '=', 'employee'), ('shipment_id.sender_employee_id.department_id.manager_id.user_id', '=', user.id),
                '&amp;', ('shipment_id.sender_type', '=', 'employee'), ('shipment_id.sender_employee_id.department_id.store_id', 'in', user.ab_employee_ids.department_id.store_id.ids),
                '&amp;', ('shipment_id.sender_type', '=', 'department'), ('shipment_id.sender_department_id.manager_id.user_id', '=', user.id),
                '&amp;', ('shipment_id.sender_type', '=', 'branch'), ('shipment_id.sender_store_id', 'in', user.ab_employee_ids.department_id.store_id.ids),
                '|', '|',
                    '&amp;', ('shipment_id.recipient_type', '=', 'employee'), ('shipment_id.recipient_employee_id', 'in', user.ab_employee_ids.ids),
                    '&amp;', ('shipment_id.recipient_type', '=', 'department'), ('shipment_id.recipient_department_id.manager_id.user_id', '=', user.id),
                    '&amp;', ('shipment_id.recipient_type', '=', 'branch'), ('shipment_id.recipient_store_id', 'in', user.ab_employee_ids.department_id.store_id.ids)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_ab_internal_shipment_line_user_created_write" model="ir.rule">
            <field name="name">Internal shipment lines: creator draft write</field>
            <field name="model_id" ref="model_ab_internal_shipment_line"/>
            <field name="groups" eval="[(4, ref('group_ab_internal_shipment_user'))]"/>
            <field name="domain_force">[('shipment_id.created_by_id', '=', user.id), ('shipment_id.state', '=', 'draft')]</field>
            <field name="perm_read" eval="0"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_ab_internal_shipment_line_admin" model="ir.rule">
            <field name="name">Internal shipment lines: administrator all</field>
            <field name="model_id" ref="model_ab_internal_shipment_line"/>
            <field name="groups" eval="[(4, ref('group_ab_internal_shipment_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <record id="rule_ab_internal_shipment_line_recipient_received_read" model="ir.rule">
            <field name="name">Internal shipment lines: confirmed recipient read</field>
            <field name="model_id" ref="model_ab_internal_shipment_line"/>
            <field name="groups" eval="[(4, ref('group_ab_internal_shipment_user'))]"/>
            <field name="domain_force">[('shipment_id.received_by_id', '=', user.id)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Shipment history record rules -->
        <record id="rule_ab_internal_shipment_history_user" model="ir.rule">
            <field name="name">Internal shipment history: user read access</field>
            <field name="model_id" ref="model_ab_internal_shipment_history"/>
            <field name="groups" eval="[(4, ref('group_ab_internal_shipment_user'))]"/>
            <field name="domain_force">['|', '|', '|', '|', '|', '|',
                ('shipment_id.created_by_id', '=', user.id),
                '&amp;', ('shipment_id.sender_type', '=', 'employee'), ('shipment_id.sender_employee_id', 'in', user.ab_employee_ids.ids),
                '&amp;', ('shipment_id.sender_type', '=', 'employee'), ('shipment_id.sender_employee_id.department_id.manager_id.user_id', '=', user.id),
                '&amp;', ('shipment_id.sender_type', '=', 'employee'), ('shipment_id.sender_employee_id.department_id.store_id', 'in', user.ab_employee_ids.department_id.store_id.ids),
                '&amp;', ('shipment_id.sender_type', '=', 'department'), ('shipment_id.sender_department_id.manager_id.user_id', '=', user.id),
                '&amp;', ('shipment_id.sender_type', '=', 'branch'), ('shipment_id.sender_store_id', 'in', user.ab_employee_ids.department_id.store_id.ids),
                '|', '|',
                    '&amp;', ('shipment_id.recipient_type', '=', 'employee'), ('shipment_id.recipient_employee_id', 'in', user.ab_employee_ids.ids),
                    '&amp;', ('shipment_id.recipient_type', '=', 'department'), ('shipment_id.recipient_department_id.manager_id.user_id', '=', user.id),
                    '&amp;', ('shipment_id.recipient_type', '=', 'branch'), ('shipment_id.recipient_store_id', 'in', user.ab_employee_ids.department_id.store_id.ids)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_ab_internal_shipment_history_user_create" model="ir.rule">
            <field name="name">Internal shipment history: workflow create</field>
            <field name="model_id" ref="model_ab_internal_shipment_history"/>
            <field name="groups" eval="[(4, ref('group_ab_internal_shipment_user'))]"/>
            <field name="domain_force">['|', ('shipment_id.created_by_id', '=', user.id), ('shipment_id.received_by_id', '=', user.id)]</field>
            <field name="perm_read" eval="0"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_ab_internal_shipment_history_admin" model="ir.rule">
