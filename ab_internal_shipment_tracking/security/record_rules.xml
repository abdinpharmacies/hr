<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="rule_ab_internal_shipment_relevant_user" model="ir.rule">
            <field name="name">Internal shipments relevant to user</field>
            <field name="model_id" ref="model_ab_internal_shipment"/>
            <field name="groups" eval="[(4, ref('group_ab_internal_shipment_sender')), (4, ref('group_ab_internal_shipment_recipient'))]"/>
            <field name="domain_force">['|', '|', '|', '|', '|', '|',
                ('created_by_id', '=', user.id),
                ('sent_by_id', '=', user.id),
                ('delivered_by_id', '=', user.id),
                ('received_by_id', '=', user.id),
                ('sender_user_id', '=', user.id),
                ('recipient_user_id', '=', user.id),
                ('current_holder_user_id', '=', user.id)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

