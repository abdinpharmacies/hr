<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="employee_tools_inventory_move_view_list" model="ir.ui.view">
            <field name="name">ab_employee_tools_inventory_move.list</field>
            <field name="model">ab_employee_tools.inventory_move</field>
            <field name="arch" type="xml">
                <list string="Tools Inventory Moves">
                    <field name="date"/>
                    <field name="movement_type"/>
                    <field name="type_id"/>
                    <field name="quantity"/>
                    <field name="user_id" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="employee_tools_inventory_move_view_form" model="ir.ui.view">
            <field name="name">ab_employee_tools_inventory_move.form</field>
            <field name="model">ab_employee_tools.inventory_move</field>
            <field name="arch" type="xml">
                <form string="Tools Inventory Move">
                    <sheet>
                        <group col="2">
                            <field name="date"/>
                            <field name="quantity" autofocus="autofocus"/>
                            <field name="movement_type"/>
                            <field name="type_id"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="notes"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="employee_tools_inventory_move_action" model="ir.actions.act_window">
            <field name="name">Tools Inventory Moves</field>
            <field name="res_model">ab_employee_tools.inventory_move</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
