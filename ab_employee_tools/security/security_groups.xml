<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="cat_ab_employee_tools" model="ir.module.category">
            <field name="name">Employee Tools</field>
            <field name="sequence" eval="1"/>
        </record>

        <record id="group_ab_employee_tools_user" model="res.groups">
            <field name="name">Employee Tools User</field>
        </record>

        <record id="group_ab_employee_tools_admin" model="res.groups">
            <field name="name">Employee Tools Admin</field>
            <field name="implied_ids" eval="[(4, ref('ab_employee_tools.group_ab_employee_tools_user'))]"/>
        </record>
        
        <record id="group_ab_employee_tools_ro" model="res.groups">
            <field name="name">Employee Tools Read Only</field>
        </record>

        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('ab_employee_tools.group_ab_employee_tools_admin'))]"/>
        </record>

    </data>
</odoo>
