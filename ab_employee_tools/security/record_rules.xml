<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="rule_ab_employee_tools_user_user" model="ir.rule">
            <field name="name">rule_ab_employee_tools_user</field>
            <field name="model_id" ref="model_ab_employee_tools_employee_tools"/>
            <field name="groups" eval="[(4, ref('group_ab_employee_tools_user'))]"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>
        <record id="rule_ab_employee_tools_admin" model="ir.rule">
            <field name="name">rule_ab_employee_tools_admin</field>
            <field name="model_id" ref="model_ab_employee_tools_employee_tools"/>
            <field name="groups" eval="[(4, ref('group_ab_employee_tools_admin'))]"/>
            <field name="domain_force">[('status', '=', 'delivered')]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>
    </data>
</odoo>
