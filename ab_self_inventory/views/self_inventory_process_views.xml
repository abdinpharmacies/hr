<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_ab_self_inventory_process_line_list" model="ir.ui.view">
            <field name="name">ab_self_inventory_process_line_list</field>
            <field name="model">ab_self_inventory_process_line</field>
            <field name="arch" type="xml">
                <list editable="bottom" delete="0" decoration-danger="shortage_qty &gt; 0" decoration-success="extra_qty &gt; 0">
                    <field name="requested" readonly="1"/>
                    <field name="product_id" domain="[('id', 'in', parent.available_product_ids)]" readonly="id"/>
                    <field name="product_code" optional="show"/>
                    <field name="eplus_item_id" optional="hide"/>
                    <field name="eplus_item_code" optional="hide"/>
                    <field name="system_qty" readonly="id"/>
                    <field name="unit_cost" readonly="id"/>
                    <field name="actual_qty"/>
                    <field name="difference_qty" readonly="1"/>
                    <field name="shortage_qty" readonly="1"/>
                    <field name="extra_qty" readonly="1"/>
                    <field name="explanation"/>
                    <button name="action_delete_manual_line" type="object" icon="fa-trash" title="Delete" invisible="requested or parent.state != 'draft'"/>
                </list>
            </field>
        </record>

        <record id="view_ab_self_inventory_process_list" model="ir.ui.view">
            <field name="name">ab_self_inventory_process_list</field>
            <field name="model">ab_self_inventory_process</field>
            <field name="arch" type="xml">
                <list decoration-info="state == 'draft'" decoration-success="state == 'submitted'" decoration-muted="state == 'cancelled'">
                    <field name="name"/>
                    <field name="request_id"/>
                    <field name="branch_id"/>
                    <field name="requester_id"/>
                    <field name="receiver_id"  />
                    <field name="shortage_qty"/>
                    <field name="extra_qty"/>
                    <field name="state"/>
                    <field name="submitted_date" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_ab_self_inventory_process_form" model="ir.ui.view">
            <field name="name">ab_self_inventory_process_form</field>
            <field name="model">ab_self_inventory_process</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_submit_process" string="Submit Inventory" type="object" class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_export_count_sheet" string="Export Count Sheet" type="object" class="btn-secondary"/>
                        <button name="action_open_import_wizard" string="Import Actual Counts" type="object" class="btn-secondary" invisible="state != 'draft'"/>
                        <button name="action_cancel" string="Cancel" type="object" invisible="state != 'draft'"/>
                        <button name="action_reset_to_draft" string="Reset to Draft" type="object" invisible="state != 'cancelled'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,submitted"/>
                    </header>
                    <sheet>
                        <group col="4">
                            <field name="name"/>
                            <field name="request_id"/>
                            <field name="branch_id"/>
                            <field name="requester_id"/>
                            <field name="receiver_id" readonly="state != 'draft'" invisible="1"/>
                            <field name="deadline"/>
                            <field name="shortage_qty"/>
                            <field name="extra_qty"/>
                            <field name="submitted_date"/>
                        </group>
                        <group>
                            <field name="request_note"/>
                            <field name="branch_note" readonly="state != 'draft'"/>
                        </group>
                        <notebook>
                            <page string="Self Inventory Lines">
                                <field name="available_product_ids" invisible="1"/>
                                <field name="line_ids" context="{'list_view_ref': 'ab_self_inventory.view_ab_self_inventory_process_line_list'}" readonly="state != 'draft'"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_ab_self_inventory_process_search" model="ir.ui.view">
            <field name="name">ab_self_inventory_process_search</field>
            <field name="model">ab_self_inventory_process</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="request_id"/>
                    <field name="branch_id"/>
                    <field name="requester_id"/>
                    <field name="receiver_id"/>
                    <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                    <filter name="submitted" string="Submitted" domain="[('state', '=', 'submitted')]"/>
                    <filter name="group_branch" string="Branch" context="{'group_by': 'branch_id'}"/>
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                </search>
            </field>
        </record>

        <record id="action_ab_self_inventory_process" model="ir.actions.act_window">
            <field name="name">Self Inventory Processes</field>
            <field name="res_model">ab_self_inventory_process</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_ab_self_inventory_process"
                  name="Processes"
                  parent="menu_ab_self_inventory_root"
                  action="action_ab_self_inventory_process"
                  groups="group_ab_self_inventory_receiver,group_ab_self_inventory_manager,group_ab_self_inventory_requester"
                  sequence="20"/>
    </data>
</odoo>
