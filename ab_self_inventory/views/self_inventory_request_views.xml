<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_ab_self_inventory_request_line_list" model="ir.ui.view">
            <field name="name">ab_self_inventory_request_line_list</field>
            <field name="model">ab_self_inventory_request_line</field>
            <field name="arch" type="xml">
                <list class="ab_self_inventory_list ab_self_inventory_line_list" editable="bottom" delete="0" create="0">
                    <field name="request_state" column_invisible="True"/>
                    <field name="selected" string="Selected" widget="ab_inventory_selected_check"/>
                    <field name="product_id" readonly="1"/>
                    <field name="product_code" optional="show"/>
                    <field name="eplus_item_id" optional="hide"/>
                    <field name="eplus_item_code" optional="show"/>
                    <field name="system_qty"/>
                    <field name="sell_price" optional="show"/>
                    <field name="sold_qty" optional="show"/>
                    <field name="matched_by" widget="ab_inventory_match_badge"/>
                    <field name="note"/>
                </list>
            </field>
        </record>

        <record id="view_ab_self_inventory_request_list" model="ir.ui.view">
            <field name="name">ab_self_inventory_request_list</field>
            <field name="model">ab_self_inventory_request</field>
            <field name="arch" type="xml">
                <list class="ab_self_inventory_list" decoration-muted="state == 'cancelled'">
                    <field name="name" widget="ab_inventory_row_title" string="Request"/>
                    <field name="branch_id" widget="ab_inventory_relation_pill" string="Branch" options="{'type': 'branch', 'icon': 'B'}"/>
                    <field name="requester_id" string="Requester" optional="show"/>
                    <field name="deadline" widget="ab_inventory_deadline" string="Deadline" optional="show"/>
                    <field name="selected_line_count" widget="ab_inventory_kpi" string="Items" options="{'icon': 'items', 'label': 'Items'}" optional="show"/>
                    <field name="process_id" widget="ab_inventory_relation_pill" string="Process" optional="show" options="{'type': 'process', 'icon': 'P'}"/>
                    <field name="state" widget="ab_inventory_state_badge" string="Status"/>
                    <field name="submitted_date" string="Submitted" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_ab_self_inventory_request_form" model="ir.ui.view">
            <field name="name">ab_self_inventory_request_form</field>
            <field name="model">ab_self_inventory_request</field>
            <field name="arch" type="xml">
                <form class="ab_self_inventory_form">
                    <header>
                        <button name="action_fetch_branch_stock" string="Fetch Branch Stock" type="object" class="btn-secondary" invisible="state != 'draft'" groups="ab_self_inventory.group_ab_self_inventory_requester,ab_self_inventory.group_ab_self_inventory_manager"/>
                        <button name="action_submit_request" string="Submit Request" type="object" class="btn-primary" invisible="state != 'draft'" groups="ab_self_inventory.group_ab_self_inventory_requester,ab_self_inventory.group_ab_self_inventory_manager"/>
                        <button name="action_open_process" string="Open Process" type="object" class="btn-secondary" invisible="not can_open_process"/>
                        <button name="action_cancel" string="Cancel" type="object" invisible="state != 'draft'" groups="ab_self_inventory.group_ab_self_inventory_requester,ab_self_inventory.group_ab_self_inventory_manager"/>
                        <button name="action_reset_to_draft" string="Reset to Draft" type="object" invisible="state != 'cancelled'" groups="ab_self_inventory.group_ab_self_inventory_requester,ab_self_inventory.group_ab_self_inventory_manager"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,submitted"/>
                    </header>
                    <sheet>
                        <field name="can_open_process" invisible="1"/>
                        <div class="ab_request_compact_summary">
                            <div class="ab_request_summary_unified">
                                <div class="ab_request_summary_primary">
                                    <field name="name" widget="ab_inventory_form_hero" nolabel="1"/>
                                </div>
                                <div class="ab_request_summary_metric">
                                    <field name="selected_line_count" widget="ab_inventory_kpi_card" nolabel="1" options="{'type': 'items', 'icon': 'items', 'label': 'Selected'}"/>
                                </div>
                                <div class="ab_request_summary_info">
                                    <div class="ab_request_summary_item">
                                        <span class="ab_form_info_label">Branch</span>
                                        <span class="ab_form_info_value"><field name="branch_id" nolabel="1" readonly="state != 'draft'"/></span>
                                    </div>
                                    <div class="ab_request_summary_item">
                                        <span class="ab_form_info_label">Deadline</span>
                                        <span class="ab_form_info_value"><field name="deadline" nolabel="1" readonly="state != 'draft'"/></span>
                                    </div>
                                    <div class="ab_request_summary_item">
                                        <span class="ab_form_info_label">Status</span>
                                        <span class="ab_form_info_value"><field name="state" widget="ab_inventory_state_badge" nolabel="1"/></span>
                                    </div>
                                    <div class="ab_request_summary_item">
                                        <span class="ab_form_info_label">Requester</span>
                                        <span class="ab_form_info_value"><field name="requester_id" nolabel="1"/></span>
                                    </div>
                                    <div class="ab_request_summary_item" invisible="not process_id">
                                        <span class="ab_form_info_label">Process</span>
                                        <span class="ab_form_info_value"><field name="process_id" nolabel="1"/></span>
                                    </div>
                                    <div class="ab_request_summary_item">
                                        <span class="ab_form_info_label">Created</span>
                                        <span class="ab_form_info_value"><field name="create_date" nolabel="1"/></span>
                                    </div>
                                    <div class="ab_request_summary_item" invisible="not submitted_date">
                                        <span class="ab_form_info_label">Submitted</span>
                                        <span class="ab_form_info_value"><field name="submitted_date" nolabel="1"/></span>
                                    </div>
                                </div>
                                <div class="ab_request_summary_note">
                                    <span class="ab_form_info_label">Note</span>
                                    <field name="note" nolabel="1" placeholder="Add a note..." readonly="state != 'draft'"/>
                                </div>
                                <div class="ab_request_summary_timeline">
                                    <field name="write_date" widget="ab_inventory_timeline" nolabel="1"/>
                                </div>
                            </div>
                        </div>
                        <div class="ab_form_section" invisible="state != 'draft'" groups="ab_self_inventory.group_ab_self_inventory_requester,ab_self_inventory.group_ab_self_inventory_manager">
                            <div class="ab_form_section_title">Smart Inventory Analysis</div>
                            <div class="ab_form_section_body">
                                <div class="ab_analysis_toolbar" style="background: rgba(0,0,0,0.03); padding: 15px; border-radius: 8px; margin-bottom: 15px;">
                                    <div class="row align-items-end g-2 ab_analysis_filter_grid">
                                        <div class="col-lg-4 col-md-12 ab_analysis_mode_filter">
                                            <label for="analysis_mode" class="form-label font-weight-bold">Analysis Mode</label>
                                            <field name="analysis_mode" widget="radio" options="{'horizontal': true}"/>
                                        </div>
                                        <div class="col-lg-2 col-md-3 ab_analysis_optional_filter">
                                            <label for="analysis_top_n" class="form-label font-weight-bold" invisible="analysis_mode == 'min_price'">Top N Items</label>
                                            <field name="analysis_top_n" invisible="analysis_mode == 'min_price'"/>
                                        </div>
                                        <div class="col-lg-2 col-md-3 ab_analysis_optional_filter">
                                            <label for="analysis_min_price" class="form-label font-weight-bold" invisible="analysis_mode == 'top_n'">Min Price (EGP)</label>
                                            <field name="analysis_min_price" invisible="analysis_mode == 'top_n'"/>
                                        </div>
                                        <div class="col-lg-2 col-md-3">
                                            <label for="analysis_medicine_type" class="form-label font-weight-bold">Medicine Type</label>
                                            <field name="analysis_medicine_type"/>
                                        </div>
                                        <div class="col-lg-2 col-md-3">
                                            <label for="analysis_period_days" class="form-label font-weight-bold">Period (Days)</label>
                                            <field name="analysis_period_days"/>
                                        </div>
                                        <div class="col-lg-2 col-md-3 ab_analysis_action_filter">
                                            <button name="action_run_inventory_analysis" type="object" string="Run Analysis" class="btn-primary w-100"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <notebook class="ab_request_full_width_notebook">
                            <page string="Fetched Products">
                                <div class="ab_modern_table_panel ab_modern_table_panel--request">
                                    <div class="ab_modern_table_toolbar" invisible="state != 'draft'" groups="ab_self_inventory.group_ab_self_inventory_requester,ab_self_inventory.group_ab_self_inventory_manager">
                                        <div class="ab_modern_table_toolbar_title">
                                            <span class="ab_modern_table_toolbar_label">Fetched Products</span>
                                        </div>
                                        <div class="ab_modern_table_toolbar_actions">
                                            <button name="action_open_manual_add_line_wizard" type="object" string="Add Line" class="btn-primary"/>
                                            <button name="action_select_all_lines" type="object" string="Select All" class="btn-secondary"/>
                                            <button name="action_unselect_all_lines" type="object" string="Unselect All" class="btn-secondary"/>
                                            <button name="action_delete_selected_lines" type="object" string="Delete Selected" class="btn-secondary" confirm="Delete all selected fetched products?"/>
                                            <button name="action_delete_unselected_lines" type="object" string="Delete Unselected" class="btn-secondary" confirm="Delete all unselected fetched products?"/>
                                        </div>
                                    </div>
                                    <div class="ab_modern_table_body">
                                        <field name="line_ids" context="{'list_view_ref': 'ab_self_inventory.view_ab_self_inventory_request_line_list'}" readonly="state != 'draft'" create="0"/>
                                    </div>
                                </div>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_ab_self_inventory_request_search" model="ir.ui.view">
            <field name="name">ab_self_inventory_request_search</field>
            <field name="model">ab_self_inventory_request</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" string="Search Requests"/>
                    <field name="branch_id" string="Branch"/>
                    <field name="requester_id" string="Requester"/>
                    <separator/>
                    <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                    <filter name="in_progress" string="In Progress" domain="[('state', '=', 'in_progress')]"/>
                    <filter name="submitted" string="Submitted" domain="[('state', '=', 'submitted')]"/>
                    <separator/>
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                    <filter name="group_branch" string="Branch" context="{'group_by': 'branch_id'}"/>
                </search>
            </field>
        </record>

        <record id="action_ab_self_inventory_request" model="ir.actions.act_window">
            <field name="name">Self Inventory Requests</field>
            <field name="res_model">ab_self_inventory_request</field>
            <field name="view_mode">list,kanban,form</field>
        </record>

        <menuitem id="menu_ab_self_inventory_request"
                  name="Requests"
                  parent="menu_ab_self_inventory_root"
                  action="action_ab_self_inventory_request"
                  groups="group_ab_self_inventory_requester,group_ab_self_inventory_receiver,group_ab_self_inventory_manager"
                  sequence="10"/>
    </data>
</odoo>
