<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_ab_self_inventory_request_line_list" model="ir.ui.view">
            <field name="name">ab_self_inventory_request_line_list</field>
            <field name="model">ab_self_inventory_request_line</field>
            <field name="arch" type="xml">
                <list editable="bottom" delete="0">
                    <field name="selected"/>
                    <field name="product_id" readonly="1"/>
                    <field name="product_code" optional="show"/>
                    <field name="eplus_item_id" optional="hide"/>
                    <field name="eplus_item_code" optional="show"/>
                    <field name="system_qty"/>
                    <field name="matched_by"/>
                    <field name="note"/>
                </list>
            </field>
        </record>

        <record id="view_ab_self_inventory_request_list" model="ir.ui.view">
            <field name="name">ab_self_inventory_request_list</field>
            <field name="model">ab_self_inventory_request</field>
            <field name="arch" type="xml">
                <list class="ab_self_inventory_list" decoration-muted="state == 'cancelled'">
                    <field name="name" widget="ab_inventory_row_title" string="Request"/>
                    <field name="branch_id" string="Branch"/>
                    <field name="requester_id" string="Requester" optional="show"/>
                    <field name="deadline" widget="ab_inventory_deadline" string="Deadline" optional="show"/>
                    <field name="selected_line_count" widget="ab_inventory_kpi" string="Items" options="{'icon': 'items', 'label': 'Items'}" optional="show"/>
                    <field name="process_id" string="Process" optional="show"/>
                    <field name="state" widget="ab_inventory_state_badge" string="Status"/>
                    <field name="submitted_date" string="Submitted" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_ab_self_inventory_request_form" model="ir.ui.view">
            <field name="name">ab_self_inventory_request_form</field>
            <field name="model">ab_self_inventory_request</field>
            <field name="arch" type="xml">
                <form class="ab_self_inventory_form">
                    <header>
                        <button name="action_fetch_branch_stock" string="Fetch Branch Stock" type="object" class="btn-secondary" invisible="state != 'draft'"/>
                        <button name="action_submit_request" string="Submit Request" type="object" class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_open_process" string="Open Process" type="object" class="btn-secondary" invisible="not process_id"/>
                        <button name="action_cancel" string="Cancel" type="object" invisible="state != 'draft'"/>
                        <button name="action_reset_to_draft" string="Reset to Draft" type="object" invisible="state != 'cancelled'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,submitted"/>
                    </header>
                    <sheet>
                        <div class="ab_form_hero_row">
                            <field name="name" widget="ab_inventory_form_hero" nolabel="1"/>
                        </div>
                        <div class="ab_form_kpi_row">
                            <field name="selected_line_count" widget="ab_inventory_kpi_card" nolabel="1" options="{'type': 'items', 'icon': 'items', 'label': 'Items'}"/>
                        </div>
                        <div class="ab_form_two_column">
                            <div class="ab_form_main">
                                <div class="ab_form_section">
                                    <div class="ab_form_section_title">Details</div>
                                    <div class="ab_form_section_body">
                                        <field name="branch_id" readonly="state != 'draft'"/>
                                        <field name="deadline" readonly="state != 'draft'"/>
                                        <field name="note" nolabel="1" placeholder="Add a note..." readonly="state != 'draft'"/>
                                    </div>
                                </div>
                                <notebook>
                                    <page string="Fetched Products">
                                        <div class="ab_form_row" invisible="state != 'draft'">
                                            <button name="action_select_all_lines" type="object" string="Select All" class="btn-secondary"/>
                                            <button name="action_unselect_all_lines" type="object" string="Unselect All" class="btn-secondary"/>
                                            <button name="action_delete_selected_lines" type="object" string="Delete Selected" class="btn-secondary" confirm="Delete all selected fetched products?"/>
                                            <button name="action_delete_unselected_lines" type="object" string="Delete Unselected" class="btn-secondary" confirm="Delete all unselected fetched products?"/>
                                        </div>
                                        <field name="line_ids" domain="[('matched_by', '!=', 'none')]" context="{'list_view_ref': 'ab_self_inventory.view_ab_self_inventory_request_line_list'}" readonly="state != 'draft'"/>
                                    </page>
                                </notebook>
                            </div>
                            <div class="ab_form_sidebar">
                                <div class="ab_form_card">
                                    <div class="ab_form_card_title">Details</div>
                                    <div class="ab_form_card_body">
                                        <div class="ab_form_info_row">
                                            <span class="ab_form_info_label">Status</span>
                                            <span class="ab_form_info_value"><field name="state" widget="ab_inventory_state_badge" nolabel="1"/></span>
                                        </div>
                                        <div class="ab_form_info_row">
                                            <span class="ab_form_info_label">Branch</span>
                                            <span class="ab_form_info_value"><field name="branch_id" nolabel="1"/></span>
                                        </div>
                                        <div class="ab_form_info_row">
                                            <span class="ab_form_info_label">Deadline</span>
                                            <span class="ab_form_info_value"><field name="deadline" widget="ab_inventory_deadline" nolabel="1"/></span>
                                        </div>
                                        <div class="ab_form_info_row">
                                            <span class="ab_form_info_label">Requester</span>
                                            <span class="ab_form_info_value"><field name="requester_id" nolabel="1"/></span>
                                        </div>
                                        <div class="ab_form_info_row">
                                            <span class="ab_form_info_label">Created</span>
                                            <span class="ab_form_info_value"><field name="create_date" nolabel="1"/></span>
                                        </div>
                                        <div class="ab_form_info_row" invisible="not submitted_date">
                                            <span class="ab_form_info_label">Submitted</span>
                                            <span class="ab_form_info_value"><field name="submitted_date" nolabel="1"/></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="ab_form_card" invisible="not process_id">
                                    <div class="ab_form_card_title">Process</div>
                                    <div class="ab_form_card_body">
                                        <field name="process_id" nolabel="1"/>
                                    </div>
                                </div>
                                <div class="ab_form_card">
                                    <div class="ab_form_card_title">Timeline</div>
                                    <div class="ab_form_card_body">
                                        <field name="write_date" widget="ab_inventory_timeline" nolabel="1"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_ab_self_inventory_request_search" model="ir.ui.view">
            <field name="name">ab_self_inventory_request_search</field>
            <field name="model">ab_self_inventory_request</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" string="Search Requests"/>
                    <field name="branch_id" string="Branch"/>
                    <field name="requester_id" string="Requester"/>
                    <separator/>
                    <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                    <filter name="submitted" string="Submitted" domain="[('state', '=', 'submitted')]"/>
                    <separator/>
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                    <filter name="group_branch" string="Branch" context="{'group_by': 'branch_id'}"/>
                </search>
            </field>
        </record>

        <record id="action_ab_self_inventory_request" model="ir.actions.act_window">
            <field name="name">Self Inventory Requests</field>
            <field name="res_model">ab_self_inventory_request</field>
            <field name="view_mode">list,kanban,form</field>
        </record>

        <menuitem id="menu_ab_self_inventory_request"
                  name="Requests"
                  parent="menu_ab_self_inventory_root"
                  action="action_ab_self_inventory_request"
                  groups="group_ab_self_inventory_requester,group_ab_self_inventory_manager"
                  sequence="10"/>
    </data>
</odoo>
