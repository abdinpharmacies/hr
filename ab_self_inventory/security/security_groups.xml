<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="module_category_ab_self_inventory" model="ir.module.category">
            <field name="name">Self Inventory</field>
            <field name="sequence" eval="1"/>
        </record>

        <record id="privilege_ab_self_inventory" model="res.groups.privilege">
            <field name="name">Self Inventory</field>
            <field name="category_id" ref="module_category_ab_self_inventory"/>
            <field name="sequence">10</field>
        </record>

        <record id="group_ab_self_inventory_requester" model="res.groups">
            <field name="name">Requester</field>
            <field name="privilege_id" ref="privilege_ab_self_inventory"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_ab_self_inventory_receiver" model="res.groups">
            <field name="name">Branch Receiver</field>
            <field name="privilege_id" ref="privilege_ab_self_inventory"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_ab_self_inventory_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="privilege_ab_self_inventory"/>
            <field name="implied_ids" eval="[
                (4, ref('group_ab_self_inventory_requester')),
                (4, ref('group_ab_self_inventory_receiver'))
            ]"/>
        </record>

        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('ab_self_inventory.group_ab_self_inventory_manager'))]"/>
        </record>
    </data>
</odoo>
