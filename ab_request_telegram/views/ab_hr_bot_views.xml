<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_ab_hr_bot_list" model="ir.ui.view">
            <field name="name">ab.hr.bot.list</field>
            <field name="model">ab_hr_bot</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="employee_id" string="Manager"/>
                    <field name="employee_ref_id" string="Manager ID"/>
                    <field name="telegram_username"/>
                    <field name="chat_id"/>
                </list>
            </field>
        </record>

        <record id="view_ab_hr_bot_form" model="ir.ui.view">
            <field name="name">ab.hr.bot.form</field>
            <field name="model">ab_hr_bot</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="employee_id" string="Manager"/>
                            <field name="employee_ref_id" string="Manager ID" readonly="1"/>
                            <field name="telegram_username"/>
                            <field name="chat_id"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_ab_hr_bot" model="ir.actions.act_window">
            <field name="name">Telegram Chats</field>
            <field name="res_model">ab_hr_bot</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem
            id="menu_ab_hr_bot"
            name="Telegram Chats"
            parent="ab_request_management.ab_request_management_menu_settings"
            action="action_ab_hr_bot"
            sequence="20"
            groups="ab_request_management.group_ab_request_management_admin"
        />
    </data>
</odoo>
