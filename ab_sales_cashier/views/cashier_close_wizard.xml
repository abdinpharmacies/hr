<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ab_sales_cashier_close_wizard_view_form" model="ir.ui.view">
            <field name="name">ab.sales.cashier.close.wizard.form</field>
            <field name="model">ab_sales_cashier_close_wizard</field>
            <field name="arch" type="xml">
                <form string="Close Cashier" create="false" delete="false">
                    <group>
                        <group>
                            <field name="user_id" readonly="1"/>
                            <field name="store_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="close_time" readonly="1"/>
                            <field name="employee_id" required="1"/>
                        </group>
                    </group>

                    <field name="line_ids" nolabel="1">
                        <list create="false" delete="false" editable="bottom">
                            <field name="wallet_name" readonly="1"/>
                            <field name="opening_balance" readonly="1"/>
                            <field name="net_balance"/>
                        </list>
                    </field>

                    <footer>
                        <button name="action_confirm_close"
                                type="object"
                                string="Confirm Close"
                                class="btn-primary"/>
                        <button string="Cancel" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
