<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ab_widgets.ABMany2one">
        <div class="o_ab_sales_pos_m2o_wrapper o_ab_many2one_wrapper">
            <Many2One
                    relation="props.relation"
                    value="props.value"
                    update="props.onUpdate"
                    domain="domainGetter"
                    context="props.context"
                    placeholder="props.placeholder"
                    string="props.string"
                    canCreate="props.canCreate"
                    canCreateEdit="props.canCreateEdit"
                    canQuickCreate="props.canQuickCreate"
                    canOpen="props.canOpen"
                    canWrite="props.canWrite"
                    searchThreshold="props.searchThreshold"
                    searchMoreLabel="props.searchMoreLabel"
            />
            <t t-if="props.value and props.value.id">
                <button class="o_ab_many2one_clear"
                        type="button"
                        title="Clear"
                        t-on-click="clearValue">
                    <svg focusable="false"
                         aria-hidden="true"
                         xmlns="http://www.w3.org/2000/svg"
                         viewBox="0 0 24 24">
                        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"></path>
                    </svg>
                </button>
            </t>
        </div>
    </t>
</templates>
