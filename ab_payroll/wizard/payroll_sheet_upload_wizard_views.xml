<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_ab_hr_payroll_sheet_upload_wizard_form" model="ir.ui.view">
            <field name="name">ab.hr.payroll.sheet.upload.wizard.form</field>
            <field name="model">ab.hr.payroll.sheet.upload.wizard</field>
            <field name="arch" type="xml">
                <form string="Upload Payroll Sheets">
                    <sheet>
                        <div class="alert alert-info" role="alert">
                            <strong>File format:</strong>
                            Upload PDF or XLSX files named like
                            <code>Employee_Full_Name_1234_Department.pdf</code>.
                            ZIP files are accepted for bulk upload and should contain PDF/XLSX files with the same naming format.
                            The employee HR code can appear after the employee full name.
                            Duplicate validation is applied per payroll period and payroll type.
                        </div>
                        <group>
                            <field name="payroll_period" placeholder="2026-06"/>
                            <field name="payroll_type"/>
                            <field name="distribution_scope" widget="radio"/>
                            <field name="attachment_ids" widget="many2many_binary"/>
                            <field name="queue_after_upload"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_upload" type="object" string="Upload" class="btn-primary"/>
                        <button string="Cancel" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_ab_hr_payroll_sheet_upload_wizard" model="ir.actions.act_window">
            <field name="name">Upload Payroll Sheets</field>
            <field name="res_model">ab.hr.payroll.sheet.upload.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem id="menu_ab_hr_payroll_sheet_upload"
                  name="Upload Payroll Sheets"
                  parent="ab_hr.ab_hr_salaries_root"
                  action="action_ab_hr_payroll_sheet_upload_wizard"
                  groups="ab_payroll.group_ab_hr_payroll_sheet_admin"
                  sequence="34"/>
    </data>
</odoo>
