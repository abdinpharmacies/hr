<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_development_request_stage_list" model="ir.ui.view">
        <field name="name">development.request.stage.list</field>
        <field name="model">development.request.stage</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="fold"/>
                <field name="is_closed"/>
            </list>
        </field>
    </record>

    <record id="view_development_request_stage_form" model="ir.ui.view">
        <field name="name">development.request.stage.form</field>
        <field name="model">development.request.stage</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="fold"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
