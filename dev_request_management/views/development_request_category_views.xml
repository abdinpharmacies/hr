<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_development_request_category_list" model="ir.ui.view">
        <field name="name">development.request.category.list</field>
        <field name="model">development.request.category</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_development_request_category_form" model="ir.ui.view">
        <field name="name">development.request.category.form</field>
        <field name="model">development.request.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
