<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_development_request_team_list" model="ir.ui.view">
        <field name="name">development.request.team.list</field>
        <field name="model">development.request.team</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="lead_user_id"/>
                <field name="board_color"/>
                <field name="request_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_development_request_team_form" model="ir.ui.view">
        <field name="name">development.request.team.form</field>
        <field name="model">development.request.team</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="lead_user_id"/>
                            <field name="member_ids" widget="many2many_avatar_user"/>
                            <field name="board_color"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Requests">
                            <field name="request_ids" readonly="1">
                                <list>
                                    <field name="sequence"/>
                                    <field name="name"/>
                                    <field name="stage_id"/>
                                    <field name="priority"/>
                                    <field name="deadline"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
