<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_development_request_search" model="ir.ui.view">
        <field name="name">development.request.search</field>
        <field name="model">development.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="sequence"/>
                <field name="name"/>
                <field name="requester_id"/>
                <field name="assigned_user_ids"/>
                <field name="responsible_team_id"/>
                <field name="request_type"/>
                <field name="priority"/>
                <field name="stage_id"/>
                <filter name="my_requests" string="My Requests" domain="[('requester_id', '=', uid)]"/>
                <filter name="assigned_to_me" string="Assigned to Me" domain="[('assigned_user_ids', 'in', uid)]"/>
                <filter name="overdue" string="Overdue" domain="[('is_overdue', '=', True)]"/>
                <filter name="high_priority" string="High Priority" domain="[('priority', 'in', ['high', 'critical'])]"/>
                <filter name="under_review" string="Under Review" domain="[('stage_code', '=', 'under_review')]"/>
                <filter name="completed" string="Completed" domain="[('stage_code', '=', 'done')]"/>
                <filter name="needs_discussion" string="Needs Discussion" domain="[('need_discussion', '=', True)]"/>
                <separator/>
                <filter name="group_stage" string="Stage" context="{'group_by': 'stage_id'}"/>
                <filter name="group_team" string="Department" context="{'group_by': 'responsible_team_id'}"/>
                <filter name="group_request_type" string="Request Type" context="{'group_by': 'request_type'}"/>
                <filter name="group_priority" string="Priority" context="{'group_by': 'priority'}"/>
                <filter name="group_developer" string="Developer" context="{'group_by': 'assigned_user_ids'}"/>
                <filter name="group_requester_department" string="Requester Department" context="{'group_by': 'requester_department_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_development_request_list" model="ir.ui.view">
        <field name="name">development.request.list</field>
        <field name="model">development.request</field>
        <field name="arch" type="xml">
            <list default_group_by="stage_id" multi_edit="1" class="o_dev_request_list o_dev_request_theme_scope">
                <field name="sequence"/>
                <field name="name"/>
                <field name="requester_id"/>
                <field name="responsible_team_id"/>
                <field name="assigned_user_ids" widget="many2many_avatar_user"/>
                <field name="request_type"/>
                <field name="priority" widget="badge"
                    decoration-success="priority == 'low'"
                    decoration-info="priority == 'medium'"
                    decoration-warning="priority == 'high'"
                    decoration-danger="priority == 'critical'"/>
                <field name="stage_id"/>
                <field name="deadline" decoration-danger="is_overdue"/>
                <field name="need_discussion" optional="show"/>
                <field name="discussion_date" optional="show"/>
                <field name="completion_days" optional="show"/>
                <field name="activity_ids" widget="list_activity" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_development_request_kanban" model="ir.ui.view">
        <field name="name">development.request.kanban</field>
        <field name="model">development.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_small_column o_development_request_kanban o_dev_request_theme_scope" quick_create="0">
                <field name="sequence"/>
                <field name="name"/>
                <field name="request_type"/>
                <field name="priority"/>
                <field name="deadline"/>
                <field name="is_overdue"/>
                <field name="need_discussion"/>
                <field name="discussion_date"/>
                <field name="assigned_user_ids"/>
                <field name="department_lead_user_id"/>
                <field name="responsible_team_id"/>
                <field name="requester_department_id"/>
                <field name="category_ids"/>
                <field name="progress_percent"/>
                <field name="kanban_color_class"/>
                <field name="activity_ids"/>
                <field name="deadline_status"/>
                <templates>
                    <t t-name="card">
                        <div t-att-class="'o_dev_request_card card border-0 shadow-sm ' + (record.kanban_color_class.raw_value || '')">
                            <div class="o_dev_request_card_top_bar"/>
                            <div class="card-body">
                                <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                                    <div class="min-w-0">
                                        <div class="text-muted small">
                                            <field name="sequence"/>
                                        </div>
                                        <strong class="d-block text-truncate">
                                            <field name="name"/>
                                        </strong>
                                        <div class="small text-muted">
                                            <field name="responsible_team_id"/>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center gap-1">
                                        <field name="department_lead_user_id" widget="many2one_avatar_user" class="ms-auto"/>
                                    </div>
                                </div>
                                <div class="d-flex flex-wrap gap-1 mb-2">
                                    <field name="priority" widget="badge"
                                        decoration-success="priority == 'low'"
                                        decoration-info="priority == 'medium'"
                                        decoration-warning="priority == 'high'"
                                        decoration-danger="priority == 'critical'"/>
                                    <field name="request_type" widget="badge"/>
                                    <field name="category_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                </div>
                                <div class="o_dev_request_progress mb-2">
                                    <div class="o_dev_request_progress_bar" t-att-style="'width:' + (record.progress_percent.raw_value || 0) + '%;'"/>
                                </div>
                                <div class="small d-flex flex-column gap-1">
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted">Deadline</span>
                                        <span t-att-class="record.is_overdue.raw_value ? 'text-danger fw-bold' : ''">
                                            <field name="deadline"/>
                                        </span>
                                    </div>
                                    <div t-if="record.need_discussion.raw_value" class="text-warning fw-semibold">
                                        Discussion required
                                    </div>
                                </div>
                            </div>
                            <footer class="card-footer bg-transparent border-0 pt-0 d-flex align-items-center">
                                <field name="assigned_user_ids" widget="many2many_avatar_user"/>
                                <field name="activity_ids" widget="kanban_activity" class="ms-auto"/>
                            </footer>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_development_request_board_kanban" model="ir.ui.view">
        <field name="name">development.request.board.kanban</field>
        <field name="model">development.request</field>
        <field name="inherit_id" ref="dev_request_management.view_development_request_kanban"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="attributes">
                <attribute name="default_group_by">board_section</attribute>
                <attribute name="class">o_kanban_small_column o_development_request_kanban o_development_request_board</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_development_request_form" model="ir.ui.view">
        <field name="name">development.request.form</field>
        <field name="model">development.request</field>
        <field name="arch" type="xml">
            <form string="Development Request" class="o_dev_request_form o_dev_request_theme_scope">
                <header>
                    <button name="action_submit" type="object" string="Submit" class="btn-primary" invisible="stage_code != 'draft'"/>
                    <button name="action_review" type="object" string="Start Review" class="btn-secondary"
                        invisible="stage_code != 'submitted'"
                        groups="dev_request_management.group_development_request_developer,dev_request_management.group_development_request_lead,dev_request_management.group_development_request_admin"/>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary"
                        invisible="stage_code != 'under_review'"
                        groups="dev_request_management.group_development_request_lead,dev_request_management.group_development_request_admin"/>
                    <button name="action_reject" type="object" string="Reject" class="btn-secondary"
                        invisible="stage_code not in ('draft', 'submitted', 'under_review', 'approved', 'in_progress', 'testing')"
                        groups="dev_request_management.group_development_request_lead,dev_request_management.group_development_request_admin"/>
                    <button name="action_start_progress" type="object" string="Start Progress" class="btn-primary"
                        invisible="stage_code != 'approved'"
                        groups="dev_request_management.group_development_request_developer,dev_request_management.group_development_request_lead,dev_request_management.group_development_request_admin"/>
                    <button name="action_send_testing" type="object" string="Move to Testing" class="btn-secondary"
                        invisible="stage_code != 'in_progress'"
                        groups="dev_request_management.group_development_request_developer,dev_request_management.group_development_request_lead,dev_request_management.group_development_request_admin"/>
                    <button name="action_mark_done" type="object" string="Mark Done" class="btn-primary"
                        invisible="stage_code != 'testing'"
                        groups="dev_request_management.group_development_request_developer,dev_request_management.group_development_request_lead,dev_request_management.group_development_request_admin"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft" class="btn-secondary"
                        invisible="stage_code not in ('submitted', 'rejected')"
                        groups="dev_request_management.group_development_request_lead,dev_request_management.group_development_request_admin"/>
                    <button name="action_generate_recurring_copy" type="object" string="Generate Next Request"
                        invisible="not is_recurring or stage_code != 'done'"
                        groups="dev_request_management.group_development_request_lead,dev_request_management.group_development_request_admin"/>
                    <field name="stage_id" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Development request title"/>
                        </h1>
                        <div class="text-muted">
                            <field name="sequence" readonly="1"/>
                        </div>
                    </div>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_followups" icon="fa-comments">
                            <field name="followup_count" widget="statinfo" string="Follow-ups"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="requester_id"/>
                            <field name="requester_department_id"/>
                            <field name="responsible_team_id"/>
                            <field name="assigned_user_ids" widget="many2many_avatar_user"/>
                            <field name="reviewer_id" readonly="1"/>
                            <field name="approved_by_id" readonly="1"/>
                            <field name="completed_by_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="request_type"/>
                            <field name="priority"/>
                            <field name="category_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            <field name="deadline"/>
                            <field name="discussion_date"/>
                            <field name="need_discussion"/>
                            <field name="deadline_status" widget="badge"
                                decoration-success="deadline_status == 'on_track'"
                                decoration-warning="deadline_status == 'due_today'"
                                decoration-danger="deadline_status == 'overdue'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Requirements">
                            <group>
                                <field name="description"/>
                                <field name="state_notes"/>
                                <field name="next_action"/>
                            </group>
                        </page>
                        <page string="Execution">
                            <group>
                                <group>
                                    <field name="estimated_hours"/>
                                    <field name="actual_hours"/>
                                    <field name="git_reference"/>
                                    <field name="git_commit_url" widget="url"/>
                                    <field name="related_project_ref"/>
                                    <field name="business_requirement_ref"/>
                                </group>
                                <group>
                                    <field name="implemented_solution"/>
                                    <field name="completion_note"/>
                                </group>
                            </group>
                        </page>
                        <page string="Planning">
                            <group>
                                <group>
                                    <field name="is_recurring"/>
                                    <field name="recurring_interval" invisible="not is_recurring"/>
                                    <field name="next_recurrence_date" readonly="1" invisible="not is_recurring"/>
                                </group>
                                <group>
                                    <field name="submitted_date" readonly="1"/>
                                    <field name="review_date" readonly="1"/>
                                    <field name="approved_date" readonly="1"/>
                                    <field name="in_progress_date" readonly="1"/>
                                    <field name="testing_date" readonly="1"/>
                                    <field name="completed_date" readonly="1"/>
                                    <field name="rejected_date" readonly="1"/>
                                    <field name="last_stage_update" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Follow-ups">
                            <field name="followup_ids" context="{'default_request_id': id}">
                                <list editable="bottom">
                                    <field name="followup_date"/>
                                    <field name="user_id"/>
                                    <field name="summary"/>
                                    <field name="next_action"/>
                                    <field name="decision"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_development_request_pivot" model="ir.ui.view">
        <field name="name">development.request.pivot</field>
        <field name="model">development.request</field>
        <field name="arch" type="xml">
            <pivot string="Development Request Analysis">
                <field name="responsible_team_id" type="row"/>
                <field name="request_type" type="col"/>
                <field name="priority" type="col"/>
                <field name="completion_days" type="measure"/>
                <field name="id" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_development_request_graph" model="ir.ui.view">
        <field name="name">development.request.graph</field>
        <field name="model">development.request</field>
        <field name="arch" type="xml">
            <graph string="Development Requests" type="bar">
                <field name="responsible_team_id"/>
                <field name="id" type="measure"/>
                <field name="priority"/>
            </graph>
        </field>
    </record>

    <record id="view_development_request_calendar" model="ir.ui.view">
        <field name="name">development.request.calendar</field>
        <field name="model">development.request</field>
        <field name="arch" type="xml">
            <calendar string="Development Requests" date_start="discussion_date" date_stop="deadline" color="responsible_team_id" mode="month" event_open_popup="true">
                <field name="name"/>
                <field name="priority"/>
                <field name="assigned_user_ids" widget="many2many_avatar_user"/>
                <field name="stage_id" filters="1"/>
                <field name="need_discussion"/>
            </calendar>
        </field>
    </record>

    <record id="action_development_request" model="ir.actions.act_window">
        <field name="name">Development Requests</field>
        <field name="res_model">development.request</field>
        <field name="view_mode">kanban,list,form,pivot,graph,calendar,activity</field>
        <field name="search_view_id" ref="dev_request_management.view_development_request_search"/>
        <field name="context">{'search_default_my_requests': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create the first development request.</p>
            <p>Track intake, review, approval, execution, discussion, and delivery in one structured pipeline.</p>
        </field>
    </record>

    <record id="action_development_request_board" model="ir.actions.act_window">
        <field name="name">Overview Board</field>
        <field name="res_model">development.request</field>
        <field name="view_mode">kanban,list,graph,pivot,form</field>
        <field name="view_id" ref="dev_request_management.view_development_request_board_kanban"/>
        <field name="search_view_id" ref="dev_request_management.view_development_request_search"/>
        <field name="context">{'group_by': 'board_section'}</field>
    </record>

    <record id="action_development_request_reporting" model="ir.actions.act_window">
        <field name="name">Analytics</field>
        <field name="res_model">development.request</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="search_view_id" ref="dev_request_management.view_development_request_search"/>
        <field name="context">{'search_default_group_team': 1}</field>
    </record>
</odoo>
