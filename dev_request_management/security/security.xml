<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_development_request_management" model="ir.module.category">
        <field name="name">Development Request Management</field>
        <field name="sequence">35</field>
    </record>

    <record id="development_request_groups_privilege" model="res.groups.privilege">
        <field name="name">Development Requests</field>
        <field name="category_id" ref="dev_request_management.module_category_development_request_management"/>
    </record>

    <record id="group_development_request_user" model="res.groups">
        <field name="name">Development Request Requester</field>
        <field name="privilege_id" ref="dev_request_management.development_request_groups_privilege"/>
        <field name="comment">Can create and monitor their own development requests.</field>
    </record>

    <record id="group_development_request_developer" model="res.groups">
        <field name="name">Development Request Developer</field>
        <field name="privilege_id" ref="dev_request_management.development_request_groups_privilege"/>
        <field name="implied_ids" eval="[(4, ref('dev_request_management.group_development_request_user'))]"/>
        <field name="comment">Can review, execute, and update development requests.</field>
    </record>

    <record id="group_development_request_lead" model="res.groups">
        <field name="name">Development Request Team Lead</field>
        <field name="privilege_id" ref="dev_request_management.development_request_groups_privilege"/>
        <field name="implied_ids" eval="[(4, ref('dev_request_management.group_development_request_developer'))]"/>
        <field name="comment">Can prioritize, approve, reject, and reassign requests.</field>
    </record>

    <record id="group_development_request_admin" model="res.groups">
        <field name="name">Development Request Administrator</field>
        <field name="privilege_id" ref="dev_request_management.development_request_groups_privilege"/>
        <field name="implied_ids" eval="[(4, ref('dev_request_management.group_development_request_lead'))]"/>
        <field name="comment">Can configure the module and see all analytics.</field>
    </record>

    <record id="group_development_request_ui_customizer" model="res.groups">
        <field name="name">Development Request UI Customizer</field>
        <field name="privilege_id" ref="dev_request_management.development_request_groups_privilege"/>
        <field name="comment">Can preview and manage personal appearance customization for the module.</field>
    </record>

    <record id="alias_group_development_request_user" model="ir.model.data">
        <field name="module">dev_request_management</field>
        <field name="name">development.request.user</field>
        <field name="model">res.groups</field>
        <field name="res_id" ref="dev_request_management.group_development_request_user"/>
        <field name="noupdate" eval="True"/>
    </record>

    <record id="alias_group_development_request_developer" model="ir.model.data">
        <field name="module">dev_request_management</field>
        <field name="name">development.request.developer</field>
        <field name="model">res.groups</field>
        <field name="res_id" ref="dev_request_management.group_development_request_developer"/>
        <field name="noupdate" eval="True"/>
    </record>

    <record id="alias_group_development_request_lead" model="ir.model.data">
        <field name="module">dev_request_management</field>
        <field name="name">development.request.lead</field>
        <field name="model">res.groups</field>
        <field name="res_id" ref="dev_request_management.group_development_request_lead"/>
        <field name="noupdate" eval="True"/>
    </record>

    <record id="alias_group_development_request_admin" model="ir.model.data">
        <field name="module">dev_request_management</field>
        <field name="name">development.request.admin</field>
        <field name="model">res.groups</field>
        <field name="res_id" ref="dev_request_management.group_development_request_admin"/>
        <field name="noupdate" eval="True"/>
    </record>

    <record id="development_request_rule_requester_own" model="ir.rule">
        <field name="name">Development Requests: requester sees own</field>
        <field name="model_id" ref="model_development_request"/>
        <field name="domain_force">[('requester_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('dev_request_management.group_development_request_user'))]"/>
    </record>

    <record id="development_request_rule_developer_all" model="ir.rule">
        <field name="name">Development Requests: developers see assigned or own</field>
        <field name="model_id" ref="model_development_request"/>
        <field name="domain_force">['|', '|', ('requester_id', '=', user.id), ('assigned_user_ids', 'in', [user.id]), ('department_lead_user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('dev_request_management.group_development_request_developer'))]"/>
    </record>

    <record id="development_request_rule_lead_all" model="ir.rule">
        <field name="name">Development Requests: leads see all</field>
        <field name="model_id" ref="model_development_request"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('dev_request_management.group_development_request_lead'))]"/>
    </record>

    <record id="development_request_rule_admin_all" model="ir.rule">
        <field name="name">Development Requests: admins see all</field>
        <field name="model_id" ref="model_development_request"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('dev_request_management.group_development_request_admin'))]"/>
    </record>

    <record id="development_request_followup_rule_requester_own" model="ir.rule">
        <field name="name">Development Request Follow-ups: requester sees own request logs</field>
        <field name="model_id" ref="model_development_request_followup"/>
        <field name="domain_force">[('request_id.requester_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('dev_request_management.group_development_request_user'))]"/>
    </record>

    <record id="development_request_followup_rule_developer_all" model="ir.rule">
        <field name="name">Development Request Follow-ups: developers see all</field>
        <field name="model_id" ref="model_development_request_followup"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('dev_request_management.group_development_request_developer'))]"/>
    </record>

    <record id="ui_appearance_settings_rule_user_read_global" model="ir.rule">
        <field name="name">Appearance Settings: read own or global</field>
        <field name="model_id" ref="model_ui_appearance_settings"/>
        <field name="domain_force">['|', ('scope', '=', 'global'), ('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('dev_request_management.group_development_request_user')), (4, ref('dev_request_management.group_development_request_developer')), (4, ref('dev_request_management.group_development_request_lead')), (4, ref('dev_request_management.group_development_request_admin')), (4, ref('dev_request_management.group_development_request_ui_customizer'))]"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="ui_appearance_settings_rule_internal_read_global" model="ir.rule">
        <field name="name">Appearance Settings: internal users read own or global</field>
        <field name="model_id" ref="model_ui_appearance_settings"/>
        <field name="domain_force">['|', ('scope', '=', 'global'), ('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="ui_appearance_settings_rule_customizer_write_own" model="ir.rule">
        <field name="name">Appearance Settings: customizer manages own override</field>
        <field name="model_id" ref="model_ui_appearance_settings"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('dev_request_management.group_development_request_ui_customizer'))]"/>
        <field name="perm_read" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="ui_appearance_settings_rule_admin_all" model="ir.rule">
        <field name="name">Appearance Settings: admin manages all</field>
        <field name="model_id" ref="model_ui_appearance_settings"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('dev_request_management.group_development_request_admin'))]"/>
    </record>
</odoo>
