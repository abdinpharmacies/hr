<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="dev_request_management.AppearanceButton">
        <button
            t-if="shouldDisplay"
            class="btn btn-primary o_dev_request_theme_button"
            t-on-click="openAppearanceDialog"
            title="Appearance Settings"
            aria-label="Appearance Settings"
        >
            <i class="fa fa-gear"/>
        </button>
    </t>

    <t t-name="dev_request_management.AppearanceDialog">
        <Dialog title="'Appearance Settings'" size="'xl'">
            <div class="o_dev_request_appearance_dialog">
                <div class="o_dev_request_appearance_sidebar">
                    <div class="btn-group-vertical w-100 gap-2">
                        <button class="btn" t-att-class="state.activeTab === 'colors' ? 'btn-primary' : 'btn-outline-secondary'" t-on-click="() => setTab('colors')">Colors</button>
                        <button class="btn" t-att-class="state.activeTab === 'background' ? 'btn-primary' : 'btn-outline-secondary'" t-on-click="() => setTab('background')">Background</button>
                        <button class="btn" t-att-class="state.activeTab === 'cards' ? 'btn-primary' : 'btn-outline-secondary'" t-on-click="() => setTab('cards')">Cards &amp; Layout</button>
                        <button class="btn" t-att-class="state.activeTab === 'typography' ? 'btn-primary' : 'btn-outline-secondary'" t-on-click="() => setTab('typography')">Typography</button>
                        <button class="btn" t-att-class="state.activeTab === 'advanced' ? 'btn-primary' : 'btn-outline-secondary'" t-on-click="() => setTab('advanced')">Advanced</button>
                    </div>
                    <div class="mt-4">
                        <label class="form-label">Scope</label>
                        <select class="form-select" t-model="state.scope" t-on-change="onChangeScope">
                            <option t-if="state.settings.can_edit_global" value="global">Global Theme</option>
                            <option t-if="state.settings.can_edit_personal" value="user">Personal Override</option>
                        </select>
                    </div>
                    <div class="mt-4">
                        <label class="form-label">Presets</label>
                        <div class="d-grid gap-2">
                            <button class="btn btn-outline-secondary" t-on-click="() => applyPreset('default')">Default</button>
                            <button class="btn btn-outline-secondary" t-on-click="() => applyPreset('dark_mode')">Dark Mode</button>
                            <button class="btn btn-outline-secondary" t-on-click="() => applyPreset('glass_ui')">Glass UI</button>
                            <button class="btn btn-outline-secondary" t-on-click="() => applyPreset('corporate')">Corporate</button>
                            <button class="btn btn-outline-secondary" t-on-click="() => applyPreset('minimal')">Minimal</button>
                        </div>
                    </div>
                </div>
                <div class="o_dev_request_appearance_content">
                    <div t-if="state.activeTab === 'colors'" class="o_dev_request_settings_grid">
                        <div class="o_dev_request_field">
                            <label class="form-label">Theme Mode</label>
                            <select class="form-select" t-att-value="state.settings.theme_mode" t-on-input="(ev) => onFieldInput('theme_mode', ev)">
                                <option value="light">Light</option>
                                <option value="dark">Dark</option>
                                <option value="custom">Custom</option>
                            </select>
                        </div>
                        <div class="o_dev_request_field">
                            <label class="form-label">Primary Color</label>
                            <input class="form-control form-control-color" type="color" t-att-value="state.settings.primary_color" t-on-input="(ev) => onFieldInput('primary_color', ev)"/>
                        </div>
                        <div class="o_dev_request_field">
                            <label class="form-label">Secondary Color</label>
                            <input class="form-control form-control-color" type="color" t-att-value="state.settings.secondary_color" t-on-input="(ev) => onFieldInput('secondary_color', ev)"/>
                        </div>
                        <div class="o_dev_request_field">
                            <label class="form-label">Accent Color</label>
                            <input class="form-control form-control-color" type="color" t-att-value="state.settings.accent_color" t-on-input="(ev) => onFieldInput('accent_color', ev)"/>
                        </div>
                        <div class="o_dev_request_field">
                            <label class="form-label">Text Color</label>
                            <input class="form-control form-control-color" type="color" t-att-value="state.settings.text_color" t-on-input="(ev) => onFieldInput('text_color', ev)"/>
                        </div>
                    </div>

                    <div t-if="state.activeTab === 'background'" class="o_dev_request_settings_grid">
                        <div class="o_dev_request_field">
                            <label class="form-label">Background Type</label>
                            <select class="form-select" t-att-value="state.settings.background_type" t-on-input="(ev) => onFieldInput('background_type', ev)">
                                <option value="solid">Solid</option>
                                <option value="gradient">Gradient</option>
                                <option value="image">Image</option>
                            </select>
                        </div>
                        <div class="o_dev_request_field" t-if="state.settings.background_type === 'solid'">
                            <label class="form-label">Background Color</label>
                            <input class="form-control form-control-color" type="color" t-att-value="state.settings.background_color" t-on-input="(ev) => onFieldInput('background_color', ev)"/>
                        </div>
                        <div class="o_dev_request_field o_dev_request_field_full" t-if="state.settings.background_type === 'gradient'">
                            <label class="form-label">CSS Gradient</label>
                            <input class="form-control" type="text" t-att-value="state.settings.background_gradient" t-on-input="(ev) => onFieldInput('background_gradient', ev)"/>
                        </div>
                        <div class="o_dev_request_field o_dev_request_field_full" t-if="state.settings.background_type === 'image'">
                            <label class="form-label">Background Image URL</label>
                            <input class="form-control" type="text" t-att-value="state.settings.background_image_url" t-on-input="(ev) => onFieldInput('background_image_url', ev)"/>
                        </div>
                        <div class="o_dev_request_field" t-if="state.settings.background_type === 'image'">
                            <label class="form-label">Upload Image</label>
                            <input class="form-control" type="file" accept="image/*" t-on-change="onBackgroundFileSelected"/>
                        </div>
                        <div class="o_dev_request_field" t-if="state.settings.background_type === 'image'">
                            <label class="form-label">Opacity</label>
                            <input class="form-range" type="range" min="0" max="1" step="0.05" t-att-value="state.settings.background_image_opacity" t-on-input="(ev) => onFieldInput('background_image_opacity', ev)"/>
                        </div>
                        <div class="o_dev_request_field" t-if="state.settings.background_type === 'image'">
                            <label class="form-label">Blur</label>
                            <input class="form-range" type="range" min="0" max="16" step="1" t-att-value="state.settings.background_image_blur" t-on-input="(ev) => onFieldInput('background_image_blur', ev)"/>
                        </div>
                        <div class="o_dev_request_field" t-if="state.settings.background_type === 'image'">
                            <label class="form-label">Image Size</label>
                            <select class="form-select" t-att-value="state.settings.background_image_size" t-on-input="(ev) => onFieldInput('background_image_size', ev)">
                                <option value="cover">Cover</option>
                                <option value="contain">Contain</option>
                                <option value="repeat">Repeat</option>
                            </select>
                        </div>
                        <div class="o_dev_request_field" t-if="state.settings.background_type === 'image'">
                            <label class="form-check">
                                <input class="form-check-input" type="checkbox" t-att-checked="state.settings.enable_parallax" t-on-change="(ev) => onFieldInput('enable_parallax', ev)"/>
                                <span class="form-check-label">Parallax Effect</span>
                            </label>
                        </div>
                    </div>

                    <div t-if="state.activeTab === 'cards'" class="o_dev_request_settings_grid">
                        <div class="o_dev_request_field">
                            <label class="form-label">Card Style</label>
                            <select class="form-select" t-att-value="state.settings.card_style" t-on-input="(ev) => onFieldInput('card_style', ev)">
                                <option value="default">Default</option>
                                <option value="glass">Glass</option>
                                <option value="flat">Flat</option>
                                <option value="shadowed">Shadowed</option>
                            </select>
                        </div>
                        <div class="o_dev_request_field">
                            <label class="form-label">Card Radius</label>
                            <input class="form-range" type="range" min="0" max="32" step="1" t-att-value="state.settings.card_border_radius" t-on-input="(ev) => onFieldInput('card_border_radius', ev)"/>
                        </div>
                        <div class="o_dev_request_field">
                            <label class="form-label">Kanban Density</label>
                            <select class="form-select" t-att-value="state.settings.kanban_density" t-on-input="(ev) => onFieldInput('kanban_density', ev)">
                                <option value="compact">Compact</option>
                                <option value="normal">Normal</option>
                                <option value="spacious">Spacious</option>
                            </select>
                        </div>
                        <div class="o_dev_request_field">
                            <label class="form-check">
                                <input class="form-check-input" type="checkbox" t-att-checked="state.settings.enable_hover_effects" t-on-change="(ev) => onFieldInput('enable_hover_effects', ev)"/>
                                <span class="form-check-label">Enable Hover Effects</span>
                            </label>
                        </div>
                        <div class="o_dev_request_field">
                            <label class="form-check">
                                <input class="form-check-input" type="checkbox" t-att-checked="state.settings.enable_animations" t-on-change="(ev) => onFieldInput('enable_animations', ev)"/>
                                <span class="form-check-label">Enable Animations</span>
                            </label>
                        </div>
                    </div>

                    <div t-if="state.activeTab === 'typography'" class="o_dev_request_settings_grid">
                        <div class="o_dev_request_field o_dev_request_field_full">
                            <label class="form-label">Font Family</label>
                            <input class="form-control" type="text" t-att-value="state.settings.font_family" t-on-input="(ev) => onFieldInput('font_family', ev)"/>
                        </div>
                        <div class="o_dev_request_field">
                            <label class="form-label">Base Font Size</label>
                            <input class="form-range" type="range" min="12" max="20" step="1" t-att-value="state.settings.font_size_base" t-on-input="(ev) => onFieldInput('font_size_base', ev)"/>
                        </div>
                        <div class="o_dev_request_field">
                            <label class="form-check">
                                <input class="form-check-input" type="checkbox" t-att-checked="state.settings.auto_dark_mode" t-on-change="(ev) => onFieldInput('auto_dark_mode', ev)"/>
                                <span class="form-check-label">Auto Dark Mode</span>
                            </label>
                        </div>
                    </div>

                    <div t-if="state.activeTab === 'advanced'" class="o_dev_request_settings_grid">
                        <div class="o_dev_request_field o_dev_request_field_full">
                            <label class="form-label">Custom CSS</label>
                            <textarea class="form-control" rows="5" t-on-input="(ev) => onFieldInput('custom_css', ev)"><t t-esc="state.settings.custom_css"/></textarea>
                        </div>
                        <div class="o_dev_request_field o_dev_request_field_full">
                            <label class="form-label">Export / Import Theme JSON</label>
                            <textarea class="form-control" rows="8" t-model="state.importExportJson"/>
                        </div>
                    </div>

                    <div class="o_dev_request_live_preview mt-4">
                        <div class="o_dev_request_preview_canvas">
                            <div class="o_dev_request_preview_card">
                                <div class="o_dev_request_preview_badges">
                                    <span class="badge text-bg-primary">High</span>
                                    <span class="badge" style="background: var(--devreq-accent-color); color: var(--devreq-text-on-primary);">Feature</span>
                                </div>
                                <h5>Live Preview</h5>
                                <p>Changes apply instantly to Development Requests kanban cards, forms, and dashboard elements.</p>
                                <div class="o_dev_request_progress">
                                    <div class="o_dev_request_progress_bar" style="width: 68%;"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <t t-set-slot="footer">
                <div class="d-flex justify-content-between align-items-center w-100">
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary" t-on-click="exportTheme">Export JSON</button>
                        <button class="btn btn-outline-secondary" t-on-click="importTheme">Import JSON</button>
                        <button class="btn btn-outline-danger" t-on-click="resetTheme">Reset to Default</button>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-secondary" t-on-click="props.close">Cancel</button>
                        <button class="btn btn-primary" t-on-click="save" t-att-disabled="state.saving">Save</button>
                    </div>
                </div>
            </t>
        </Dialog>
    </t>
</templates>
