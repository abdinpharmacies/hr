<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="ir_cron_development_request_deadline_watch" model="ir.cron">
        <field name="name">Development Request Deadline Watch</field>
        <field name="model_id" ref="model_development_request"/>
        <field name="state">code</field>
        <field name="code">model._cron_deadline_watch()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">1</field>
    </record>
    <record id="ir_cron_development_request_recurring" model="ir.cron">
        <field name="name">Development Request Recurring Generator</field>
        <field name="model_id" ref="model_development_request"/>
        <field name="state">code</field>
        <field name="code">model._cron_generate_recurring_requests()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">1</field>
    </record>
</odoo>
