<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Seed data for workflow stages.
        Sequence controls kanban column order from left to right.
    -->

    <record id="stage_under_review" model="hr.feedback.stage">
        <field name="name">Under Review</field>
        <field name="sequence">10</field>
        <field name="color">1</field>
    </record>

    <record id="stage_in_progress" model="hr.feedback.stage">
        <field name="name">In Progress</field>
        <field name="sequence">20</field>
        <field name="color">3</field>
    </record>

    <record id="stage_resolved" model="hr.feedback.stage">
        <field name="name">Resolved</field>
        <field name="sequence">30</field>
        <field name="is_final">True</field>
        <field name="color">2</field>
    </record>

    <record id="stage_rejected" model="hr.feedback.stage">
        <field name="name">Rejected</field>
        <field name="sequence">40</field>
        <field name="is_final">True</field>
        <field name="color">4</field>
    </record>
</odoo>
