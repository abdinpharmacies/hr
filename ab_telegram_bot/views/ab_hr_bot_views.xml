<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_ab_hr_bot_list" model="ir.ui.view">
            <field name="name">ab.hr.bot.list</field>
            <field name="model">ab_hr_bot</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="employee_id"/>
                    <field name="employee_ref_id"/>
                    <field name="telegram_username"/>
                    <field name="chat_id"/>
                </list>
            </field>
        </record>

        <record id="view_ab_hr_bot_form" model="ir.ui.view">
            <field name="name">ab.hr.bot.form</field>
            <field name="model">ab_hr_bot</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="employee_id"/>
                            <field name="employee_ref_id"/>
                            <field name="telegram_username"/>
                            <field name="chat_id"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_ab_hr_bot" model="ir.actions.act_window">
            <field name="name">Telegram Chats</field>
            <field name="res_model">ab_hr_bot</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem
            id="menu_ab_telegram_bot_root"
            name="Telegram Bot"
            groups="base.group_system"
            sequence="90"
        />

        <menuitem
            id="menu_ab_hr_bot"
            name="Telegram Chats"
            parent="menu_ab_telegram_bot_root"
            action="action_ab_hr_bot"
            sequence="10"
            groups="base.group_system"
        />
    </data>
</odoo>
