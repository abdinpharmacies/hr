<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_distribution_store_invoice">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <t t-foreach="docs" t-as="o">
                        <div class="page">
                            <h2 style="text-align:center;">Customer Invoice</h2>
                            <hr/>
                            <table class="table table-sm">
                                <tr>
                                    <th>Company</th>
                                    <td><t t-esc="o.company_id.name"/></td>
                                    <th>Commercial Registry</th>
                                    <td><t t-esc="o.company_id.company_registry"/></td>
                                </tr>
                                <tr>
                                    <th>Tax Card</th>
                                    <td><t t-esc="o.company_id.vat"/></td>
                                    <th></th>
                                    <td></td>
                                </tr>
                            </table>
                            <table class="table table-sm">
                                <tr>
                                    <th>Customer</th>
                                    <td><t t-esc="o.customer_name"/></td>
                                    <th>Phone</th>
                                    <td><t t-esc="o.customer_phone"/></td>
                                </tr>
                                <tr>
                                    <th>Address</th>
                                    <td><t t-esc="o.customer_address"/></td>
                                    <th>Reference</th>
                                    <td><t t-esc="o.reference"/></td>
                                </tr>
                                <tr>
                                    <th>Date</th>
                                    <td><t t-esc="o.document_date"/></td>
                                    <th>Note</th>
                                    <td><t t-esc="o.customer_note"/></td>
                                </tr>
                            </table>

                            <table class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th>Batch</th>
                                        <th>Expiry</th>
                                        <th class="text-end">Qty</th>
                                        <th class="text-end">Price</th>
                                        <th class="text-end">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="o.line_ids" t-as="line">
                                        <td><t t-esc="line.product_id.display_name"/></td>
                                        <td><t t-esc="line.batch_number"/></td>
                                        <td><t t-esc="line.expiry_date"/></td>
                                        <td class="text-end"><t t-esc="line.qty"/></td>
                                        <td class="text-end"><t t-esc="line.customer_price"/></td>
                                        <td class="text-end"><t t-esc="line.line_total"/></td>
                                    </tr>
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <th colspan="3" class="text-end">Totals</th>
                                        <th class="text-end"><t t-esc="o.total_qty"/></th>
                                        <th></th>
                                        <th class="text-end"><t t-esc="o.total_amount"/></th>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </t>
                </t>
            </t>
        </template>

        <record id="action_report_distribution_store_invoice" model="ir.actions.report">
            <field name="name">Distribution Store Invoice</field>
            <field name="model">ab_distribution_store_header</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">ab_distribution_store.report_distribution_store_invoice</field>
            <field name="report_file">ab_distribution_store.report_distribution_store_invoice</field>
            <field name="print_report_name">'Distribution Invoice - %s' % (object.customer_name or '')</field>
            <field name="binding_model_id" ref="model_ab_distribution_store_header"/>
            <field name="binding_type">report</field>
        </record>
    </data>
</odoo>
