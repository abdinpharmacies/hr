<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="distribution_store_product_view_list" model="ir.ui.view">
            <field name="name">distribution_store_product_view_list</field>
            <field name="model">ab_distribution_store_product</field>
            <field name="arch" type="xml">
                <list string="Distribution Store Products" multi_edit="1">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="default_price"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="distribution_store_product_view_form" model="ir.ui.view">
            <field name="name">distribution_store_product_view_form</field>
            <field name="model">ab_distribution_store_product</field>
            <field name="arch" type="xml">
                <form string="Distribution Store Product">
                    <sheet>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="default_price"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_distribution_store_product" model="ir.actions.act_window">
            <field name="name">Distribution Store Products</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">ab_distribution_store_product</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
