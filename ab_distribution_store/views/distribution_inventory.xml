<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="distribution_store_inventory_view_list" model="ir.ui.view">
            <field name="name">distribution_store_inventory_view_list</field>
            <field name="model">ab_distribution_store_inventory</field>
            <field name="arch" type="xml">
                <list string="Distribution Store Inventory" multi_edit="1">
                    <field name="product_id"/>
                    <field name="balance"/>
                    <field name="pharma_price"/>
                    <field name="customer_price"/>
                    <field name="batch_number"/>
                    <field name="expiry_date"/>
                </list>
            </field>
        </record>

        <record id="distribution_store_inventory_view_form" model="ir.ui.view">
            <field name="name">distribution_store_inventory_view_form</field>
            <field name="model">ab_distribution_store_inventory</field>
            <field name="arch" type="xml">
                <form string="Distribution Store Inventory">
                    <sheet>
                        <group>
                            <field name="product_id"/>
                            <field name="balance"/>
                            <field name="pharma_price"/>
                            <field name="customer_price"/>
                            <field name="batch_number"/>
                            <field name="expiry_date"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_distribution_store_inventory" model="ir.actions.act_window">
            <field name="name">Distribution Store Inventory</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">ab_distribution_store_inventory</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
