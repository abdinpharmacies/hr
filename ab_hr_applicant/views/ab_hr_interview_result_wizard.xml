<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_ab_hr_interview_result_wizard_form" model="ir.ui.view">
            <field name="name">ab_hr_interview_result_wizard.form</field>
            <field name="model">ab_hr_interview_result_wizard</field>
            <field name="arch" type="xml">
                <form string="Register Interview Result">
                    <sheet>
                        <group>
                            <group>
                                <field name="interview_id" invisible="1"/>
                                <field name="applicant_id"/>
                                <field name="interviewer_id"/>
                                <field name="interview_date"/>
                            </group>
                            <group>
                                <field name="action" required="1"/>
                            </group>
                        </group>

                        <group string="Training Details" invisible="action not in ('accepted_job_offer','training','advanced_training','duplicated_training')">
                            <group>
                                <field name="store_id" required="action in ('accepted_job_offer','training','advanced_training','duplicated_training')"/>

                            </group>
                            <group invisible="action in ('accepted_job_offer')">

                                <field name="starting_date" required="action  in ('training','advanced_training','duplicated_training')"/>
                                <field name="ending_date" required="action  in ('training','advanced_training','duplicated_training')"/>
                            </group>
                            <group invisible="action in ('accepted_job_offer')">
                                <field name="from_hour" widget="float_time" required="action in ('training','advanced_training','duplicated_training')"/>
                                <field name="to_hour" widget="float_time" required="action in ('training','advanced_training','duplicated_training')"/>
                            </group>
                        </group>

                        <group string="Notes">
                            <field name="note" placeholder="Optional notes..."/>
                        </group>

                        <footer>
                            <button string="Confirm" type="object" name="action_confirm" class="btn-primary"/>
                            <button string="Cancel" special="cancel" class="btn-secondary"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_ab_hr_interview_result_wizard" model="ir.actions.act_window">
            <field name="name">Register Result</field>
            <field name="res_model">ab_hr_interview_result_wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>
