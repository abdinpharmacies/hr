<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="ab_hr_job_post_tree_view" model="ir.ui.view">
            <field name="name">ab_hr_job_post.tree</field>
            <field name="model">ab_hr_job_post</field>
            <field name="arch" type="xml">
                <list default_order="registration_start desc">
                    <field name="name"/>
                    <field name="job_id"/>
                    <field name="city_id" optional="show"/>
                    <field name="registration_start"/>
                    <field name="registration_end"/>
                    <field name="status" widget="badge"/>
                    <field name="website_published"/>
                </list>
            </field>
        </record>


        <record id="ab_hr_job_post_form_view" model="ir.ui.view">
            <field name="name">ab_hr_job_post.form</field>
            <field name="model">ab_hr_job_post</field>
            <field name="arch" type="xml">
                <form string="Job Post">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>

                        <group>
                            <group>
                                <field name="job_id" required="1"/>
                                <field name="city_id"/>
                                <field name="sequence"/>
                            </group>
                            <group>
                                <field name="registration_start" required="1"/>
                                <field name="registration_end" required="1"/>
                                <field name="status" readonly="1" widget="badge"/>
                                <field name="website_published"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Description">
                                <field name="description" placeholder="Write job post description..."/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>


        <record id="ab_hr_job_post_action" model="ir.actions.act_window">
            <field name="name">Job Posts</field>
            <field name="res_model">ab_hr_job_post</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="ab_hr_job_post_menu" name="Job Posts" parent="ab_hr_application_menu" action="ab_hr_job_post_action" sequence="10"/>

    </data>
</odoo>
