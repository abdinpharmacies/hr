<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <template id="ab_hr_job_post_website_list" name="Job Openings">
    <t t-call="website.layout">
      <div class="container my-5">

        <div class="text-center mb-4">
          <h1 class="fw-bold">Job Openings</h1>
          <p class="text-muted">Explore our current vacancies and apply online</p>
        </div>

        <div class="row g-4">
          <t t-foreach="posts" t-as="p">
            <div class="col-12 col-md-6 col-lg-4">
              <div class="card h-100 shadow-sm border-0">

                <div class="card-body d-flex flex-column">
                  <h5 class="card-title mb-1">
                    <t t-esc="p.job_id.name"/>
                  </h5>

                  <t t-if="p.city_id">
                    <p class="text-muted mb-2">
                      <i class="fa fa-map-marker me-1"/>
                      <t t-esc="p.city_id.display_name"/>
                    </p>
                  </t>

                  <p class="small text-muted mb-2">
                    <strong>Registration Period:</strong><br/>
                    <span>
                      <t t-esc="p.registration_start"/>
                      &#8211;
                      <t t-esc="p.registration_end"/>
                    </span>
                  </p>

                  <div class="mb-2">
                    <t t-if="p.status == 'available'">
                      <span class="badge bg-success">Open</span>
                    </t>
                    <t t-elif="p.status == 'upcoming'">
                      <span class="badge bg-info">Upcoming</span>
                    </t>
                    <t t-else="">
                      <span class="badge bg-secondary">Closed</span>
                    </t>
                  </div>

                  <t t-if="p.description">
                    <div class="text-muted small mb-3"
                         style="max-height: 90px; overflow: hidden;">
                      <t t-raw="p.description"/>
                    </div>
                  </t>

                  <div class="mt-auto">
                    <t t-if="p.status == 'available'">
                      <a class="btn btn-primary w-100"
                         t-att-href="'/jobs/apply?required_job_id=%s' % p.job_id.id">
                        Apply Now
                      </a>
                    </t>
                    <t t-else="">
                      <button class="btn btn-outline-secondary w-100" disabled="disabled">
                        Applications Closed
                      </button>
                    </t>
                  </div>
                </div>

              </div>
            </div>
          </t>
        </div>

        <t t-if="not posts">
          <div class="alert alert-info text-center mt-4">
            There are currently no job openings available.
          </div>
        </t>

      </div>
    </t>
  </template>

</odoo>
