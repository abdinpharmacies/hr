<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="cat_ab_customer" model="ir.module.category">
            <field name="name">Customers</field>
            <field name="sequence" eval="1"/>
        </record>

        <record id="privilege_ab_customer" model="res.groups.privilege">
            <field name="name">Customers</field>
            <field name="category_id" ref="cat_ab_customer"/>
            <field name="sequence" eval="10"/>
        </record>

        <record id="group_customer_branch" model="res.groups">
            <field name="name">Customer Branch</field>
            <field name="privilege_id" ref="privilege_ab_customer"/>
        </record>

        <record id="group_customer_marketing" model="res.groups">
            <field name="name">Customer Marketing</field>
            <field name="privilege_id" ref="privilege_ab_customer"/>
        </record>

        <record id="group_customer_viewer" model="res.groups">
            <field name="name">Customer Viewer</field>
            <field name="privilege_id" ref="privilege_ab_customer"/>
        </record>

    </data>
</odoo>
