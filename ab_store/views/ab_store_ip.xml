<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="ab_store_ip_view_tree" model="ir.ui.view">
            <field name="name">ab_store_ip_view_tree</field>
            <field name="model">ab_store_ip</field>
            <field name="arch" type="xml">
                <list string="ab_store_ip_tree" multi_edit="1">
                    <field name="name" optional="show"/>
                    <field name="store_id" optional="show"/>
                    <field name="include" optional="show"/>
                    <button name="btn_include_exclude"
                            type="object"
                            groups="base.group_system"
                            string="Include"
                            invisible="include == True"
                            class="btn-success"/>
                    <button name="btn_include_exclude"
                            type="object"
                            groups="base.group_system"
                            string="Exclude"
                            invisible="include == False"
                            class="btn-danger"/>

                    <field name="create_uid" optional="hide"/>
                    <field name="create_date" optional="hide"/>
                    <field name="write_uid" optional="hide"/>
                    <field name="write_date" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="ab_store_ip_view_form" model="ir.ui.view">
            <field name="name">ab_store_ip_view_form</field>
            <field name="model">ab_store_ip</field>
            <field name="arch" type="xml">
                <form string="ab_store_ip_form">
                    <header>
                        <button name="btn_include_exclude"
                                type="object"
                                groups="base.group_system"
                                string="Include"
                                invisible="include == True"
                                class="btn-success"/>
                        <button name="btn_include_exclude"
                                type="object"
                                groups="base.group_system"
                                string="Exclude"
                                invisible="include == False"
                                class="btn-danger"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="store_id"/>
                            <field name="include"/>

                            <field name="create_uid"/>
                            <field name="create_date"/>
                            <field name="write_uid"/>
                            <field name="write_date"/>

                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="ab_store_ip_view_search" model="ir.ui.view">
            <field name="name">ab_store_ip_view_search</field>
            <field name="model">ab_store_ip</field>
            <field name="arch" type="xml">
                <search string="ab_store_ip_search">
                    <field name="name"/>
                    <field name="store_id"/>
                    <field name="create_uid"/>
                    <field name="create_date"/>
                    <field name="write_uid"/>
                    <field name="write_date"/>
                </search>
            </field>
        </record>
        <record id="ab_store_ip_view_pivot" model="ir.ui.view">
            <field name="name">ab_store_ip_view_pivot</field>
            <field name="model">ab_store_ip</field>
            <field name="arch" type="xml">
                <pivot string="ab_store_ip_pivot">
                </pivot>
            </field>
        </record>


        <record id="ab_store_ip_action" model="ir.actions.act_window">
            <field name="name">Ab store ip</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">ab_store_ip</field>
            <field name="view_mode">list,form,pivot</field>
        </record>

    </data>
</odoo>