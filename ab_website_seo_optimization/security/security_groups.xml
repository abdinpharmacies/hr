<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="category_ab_website_seo_optimization" model="ir.module.category">
            <field name="name">SEO Optimization</field>
            <field name="sequence" eval="35"/>
        </record>

        <record id="privilege_ab_website_seo_optimization" model="res.groups.privilege">
            <field name="name">SEO Optimization</field>
            <field name="category_id" ref="category_ab_website_seo_optimization"/>
            <field name="sequence" eval="35"/>
        </record>

        <record id="group_ab_website_seo_optimization_user" model="res.groups">
            <field name="name">SEO User</field>
            <field name="privilege_id" ref="privilege_ab_website_seo_optimization"/>
        </record>

        <record id="group_ab_website_seo_optimization_reviewer" model="res.groups">
            <field name="name">SEO Reviewer</field>
            <field name="implied_ids" eval="[(4, ref('ab_website_seo_optimization.group_ab_website_seo_optimization_user'))]"/>
            <field name="privilege_id" ref="privilege_ab_website_seo_optimization"/>
        </record>

        <record id="group_ab_website_seo_optimization_manager" model="res.groups">
            <field name="name">SEO Manager</field>
            <field name="implied_ids" eval="[(4, ref('ab_website_seo_optimization.group_ab_website_seo_optimization_reviewer'))]"/>
            <field name="privilege_id" ref="privilege_ab_website_seo_optimization"/>
        </record>

        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('ab_website_seo_optimization.group_ab_website_seo_optimization_manager'))]"/>
        </record>
    </data>
</odoo>
