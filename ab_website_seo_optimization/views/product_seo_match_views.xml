<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_ab_website_seo_optimization_match_list" model="ir.ui.view">
            <field name="name">ab.product.seo.match.list</field>
            <field name="model">ab.product.seo.match</field>
            <field name="arch" type="xml">
                <list>
                    <field name="seo_id"/>
                    <field name="source"/>
                    <field name="match_method"/>
                    <field name="match_score"/>
                    <field name="external_reference"/>
                    <field name="status"/>
                </list>
            </field>
        </record>

        <record id="view_ab_website_seo_optimization_match_form" model="ir.ui.view">
            <field name="name">ab.product.seo.match.form</field>
            <field name="model">ab.product.seo.match</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="seo_id"/>
                            <field name="source"/>
                            <field name="match_method"/>
                            <field name="match_score"/>
                            <field name="external_reference"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="matched_payload"/>
                            <field name="notes"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
