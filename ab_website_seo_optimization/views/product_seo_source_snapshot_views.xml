<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_ab_website_seo_optimization_source_snapshot_list" model="ir.ui.view">
            <field name="name">ab.product.seo.source.snapshot.list</field>
            <field name="model">ab.product.seo.source.snapshot</field>
            <field name="arch" type="xml">
                <list>
                    <field name="snapshot_date"/>
                    <field name="seo_id"/>
                    <field name="product_code"/>
                    <field name="eplus_serial"/>
                    <field name="manufacturer"/>
                    <field name="scientific_name"/>
                    <field name="usage_manner"/>
                    <field name="origin"/>
                </list>
            </field>
        </record>

        <record id="view_ab_website_seo_optimization_source_snapshot_form" model="ir.ui.view">
            <field name="name">ab.product.seo.source.snapshot.form</field>
            <field name="model">ab.product.seo.source.snapshot</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="seo_id" readonly="1"/>
                                <field name="ab_product_id" readonly="1"/>
                                <field name="product_template_id" readonly="1"/>
                                <field name="snapshot_date" readonly="1"/>
                                <field name="product_code" readonly="1"/>
                                <field name="eplus_serial" readonly="1"/>
                            </group>
                            <group>
                                <field name="manufacturer" readonly="1"/>
                                <field name="scientific_name" readonly="1"/>
                                <field name="scientific_group" readonly="1"/>
                                <field name="usage_manner" readonly="1"/>
                                <field name="origin" readonly="1"/>
                                <field name="group_path" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="barcode_values" readonly="1"/>
                            <field name="effective_material" readonly="1"/>
                            <field name="effective_material_conc" readonly="1"/>
                            <field name="notes" readonly="1"/>
                            <field name="raw_eplus_payload" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
