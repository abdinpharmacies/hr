<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_ab_product_drug_data_list" model="ir.ui.view">
            <field name="name">ab.product.drug.data.list</field>
            <field name="model">ab.product.drug.data</field>
            <field name="arch" type="xml">
                <list create="0" edit="0" delete="0">
                    <field name="commercial_name_en"/>
                    <field name="commercial_name_ar"/>
                    <field name="scientific_name"/>
                    <field name="manufacturer"/>
                    <field name="drug_class"/>
                    <field name="route"/>
                    <field name="price"/>
                    <field name="regulatory_status"/>
                    <field name="last_synced_at"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_ab_product_drug_data_form" model="ir.ui.view">
            <field name="name">ab.product.drug.data.form</field>
            <field name="model">ab.product.drug.data</field>
            <field name="arch" type="xml">
                <form create="0" edit="0" delete="0">
                    <sheet>
                        <group>
                            <group>
                                <field name="active"/>
                                <field name="external_id"/>
                                <field name="product_name"/>
                                <field name="commercial_name_en"/>
                                <field name="commercial_name_ar"/>
                                <field name="scientific_name"/>
                                <field name="active_ingredient"/>
                                <field name="manufacturer"/>
                                <field name="drug_class"/>
                            </group>
                            <group>
                                <field name="route"/>
                                <field name="category"/>
                                <field name="dosage_form"/>
                                <field name="strength"/>
                                <field name="package_size"/>
                                <field name="price"/>
                                <field name="currency"/>
                                <field name="regulatory_status"/>
                                <field name="source_url"/>
                                <field name="last_synced_at"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Raw API Payload">
                                <field name="raw_payload" readonly="1"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_ab_product_drug_data_search" model="ir.ui.view">
            <field name="name">ab.product.drug.data.search</field>
            <field name="model">ab.product.drug.data</field>
            <field name="arch" type="xml">
                <search>
                    <field name="product_name"/>
                    <field name="commercial_name_en"/>
                    <field name="commercial_name_ar"/>
                    <field name="scientific_name"/>
                    <field name="manufacturer"/>
                    <field name="active_ingredient"/>
                    <field name="drug_class"/>
                    <filter name="filter_active" string="Active" domain="[('active', '=', True)]"/>
                    <filter name="group_manufacturer" string="Manufacturer" context="{'group_by': 'manufacturer'}"/>
                    <filter name="group_drug_class" string="Drug Class" context="{'group_by': 'drug_class'}"/>
                    <filter name="group_route" string="Route" context="{'group_by': 'route'}"/>
                </search>
            </field>
        </record>
    </data>
</odoo>
