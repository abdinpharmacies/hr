<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_ab_website_seo_optimization_bulk_optimization_list" model="ir.ui.view">
            <field name="name">ab.product.seo.bulk.optimization.list</field>
            <field name="model">ab.product.seo.bulk.optimization</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <list decoration-info="state == 'queued'"
                      decoration-warning="state == 'running'"
                      decoration-success="state == 'done'"
                      decoration-danger="state == 'failed'"
                      decoration-muted="state in ('cancelled', 'archived')">
                    <field name="name"/>
                    <field name="state" widget="badge"
                           decoration-info="state == 'queued'"
                           decoration-warning="state == 'running'"
                           decoration-success="state == 'done'"
                           decoration-danger="state == 'failed'"
                           decoration-muted="state == 'cancelled'"/>
                    <field name="target"/>
                    <field name="website_id"/>
                    <field name="assistant_id"/>
                    <field name="lang_mode"/>
                    <field name="batch_limit"/>
                    <field name="request_delay_seconds"/>
                    <field name="rate_limit_retry_count"/>
                    <field name="rate_limit_wait_seconds"/>
                    <field name="processed_count"/>
                    <field name="optimized_count"/>
                    <field name="skipped_count"/>
                    <field name="error_count"/>
                    <field name="started_at"/>
                    <field name="finished_at"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_ab_website_seo_optimization_bulk_optimization_form" model="ir.ui.view">
            <field name="name">ab.product.seo.bulk.optimization.form</field>
            <field name="model">ab.product.seo.bulk.optimization</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_fill_with_ai_for_published_products"
                                type="object"
                                string="Fill with AI for Published Products"
                                class="btn-success"
                                invisible="active == False or state != 'draft'"
                                groups="ab_website_seo_optimization.group_ab_website_seo_optimization_manager"/>
                        <button name="action_cancel_batch"
                                type="object"
                                string="Cancel Batch"
                                class="btn-danger"
                                invisible="active == False or state != 'queued'"
                                groups="ab_website_seo_optimization.group_ab_website_seo_optimization_manager"/>
                        <button name="action_archive"
                                type="object"
                                string="Archive"
                                class="btn-secondary"
                                invisible="active == False"
                                groups="ab_website_seo_optimization.group_ab_website_seo_optimization_manager"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="active"/>
                                <field name="target"/>
                                <field name="website_id"/>
                                <field name="assistant_id"/>
                                <field name="lang_mode"/>
                            </group>
                            <group>
                                <field name="batch_limit"/>
                                <field name="request_delay_seconds"/>
                                <field name="rate_limit_retry_count"/>
                                <field name="rate_limit_wait_seconds"/>
                                <field name="compact_assistant_context"/>
                                <field name="only_missing_seo"/>
                                <field name="publish_description"/>
                                <field name="generate_drug_data"/>
                                <field name="started_at" readonly="1"/>
                                <field name="finished_at" readonly="1"/>
                            </group>
                        </group>
                        <group string="Results">
                            <field name="state" readonly="1" widget="badge"
                                   decoration-info="state == 'queued'"
                                   decoration-warning="state == 'running'"
                                   decoration-success="state == 'done'"
                                   decoration-danger="state == 'failed'"
                                   decoration-muted="state == 'cancelled'"/>
                            <field name="processed_count" readonly="1"/>
                            <field name="optimized_count" readonly="1"/>
                            <field name="skipped_count" readonly="1"/>
                            <field name="error_count" readonly="1"/>
                        </group>
                        <field name="line_ids" readonly="1">
                            <list decoration-success="status == 'optimized'"
                                  decoration-warning="status in ('skipped', 'deferred')"
                                  decoration-danger="status == 'error'"
                                  decoration-muted="status == 'cancelled'">
                                <field name="status" widget="badge"
                                       decoration-success="status == 'optimized'"
                                       decoration-warning="status in ('skipped', 'deferred')"
                                       decoration-danger="status == 'error'"
                                       decoration-muted="status == 'cancelled'"/>
                                <field name="product_template_id"/>
                                <field name="ab_product_id"/>
                                <field name="website_page_id"/>
                                <field name="website_url"/>
                                <field name="message"/>
                            </list>
                        </field>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_ab_website_seo_optimization_bulk_optimization_search" model="ir.ui.view">
            <field name="name">ab.product.seo.bulk.optimization.search</field>
            <field name="model">ab.product.seo.bulk.optimization</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="website_id"/>
                    <field name="assistant_id"/>
                    <field name="target"/>
                    <field name="request_delay_seconds"/>
                    <filter name="filter_active" string="Active" domain="[('active', '=', True)]"/>
                    <filter name="filter_done" string="Done" domain="[('state', '=', 'done')]"/>
                    <filter name="filter_failed" string="Failed" domain="[('state', '=', 'failed')]"/>
                    <filter name="filter_cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
                </search>
            </field>
        </record>

        <record id="view_ab_website_seo_optimization_bulk_optimization_line_list" model="ir.ui.view">
            <field name="name">ab.product.seo.bulk.optimization.line.list</field>
            <field name="model">ab.product.seo.bulk.optimization.line</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <list>
                    <field name="bulk_id"/>
                    <field name="status"/>
                    <field name="product_template_id"/>
                    <field name="ab_product_id"/>
                    <field name="website_page_id"/>
                    <field name="website_url"/>
                    <field name="message"/>
                </list>
            </field>
        </record>

        <record id="action_ab_website_seo_optimization_bulk_optimization_view_list" model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_ab_website_seo_optimization_bulk_optimization_list"/>
            <field name="act_window_id" ref="action_ab_website_seo_optimization_bulk_optimization"/>
        </record>

        <record id="action_ab_website_seo_optimization_bulk_optimization_view_form" model="ir.actions.act_window.view">
            <field name="sequence" eval="2"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_ab_website_seo_optimization_bulk_optimization_form"/>
            <field name="act_window_id" ref="action_ab_website_seo_optimization_bulk_optimization"/>
        </record>
    </data>
</odoo>
