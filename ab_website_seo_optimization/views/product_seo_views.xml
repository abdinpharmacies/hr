<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_ab_website_seo_optimization_list" model="ir.ui.view">
            <field name="name">ab.product.seo.list</field>
            <field name="model">ab.product.seo</field>
            <field name="arch" type="xml">
                <list decoration-success="state == 'published'"
                      decoration-warning="state == 'under_review'"
                      decoration-danger="has_conflict">
                    <field name="name"/>
                    <field name="state"/>
                    <field name="ab_product_id"/>
                    <field name="product_template_id"/>
                    <field name="website_id"/>
                    <field name="source_quality"/>
                    <field name="seo_score"/>
                    <field name="ready_for_publish"/>
                    <field name="has_conflict"/>
                    <field name="last_published_at"/>
                </list>
            </field>
        </record>

        <record id="view_ab_website_seo_optimization_form" model="ir.ui.view">
            <field name="name">ab.product.seo.form</field>
            <field name="model">ab.product.seo</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_create_source_snapshot" type="object" string="Snapshot"
                                class="btn-secondary" invisible="state == 'archived'"/>
                        <button name="action_fill_with_ai" type="object" string="Fill with AI"
                                class="btn-secondary" invisible="state not in ('draft', 'generated', 'rejected')"/>
                        <button name="action_submit_review" type="object" string="Submit Review"
                                class="btn-primary" invisible="state not in ('draft', 'generated', 'rejected')"/>
                        <button name="action_approve" type="object" string="Approve"
                                class="btn-primary" groups="ab_website_seo_optimization.group_ab_website_seo_optimization_reviewer"
                                invisible="state != 'under_review'"/>
                        <button name="action_reject" type="object" string="Reject"
                                class="btn-secondary" groups="ab_website_seo_optimization.group_ab_website_seo_optimization_reviewer"
                                invisible="state != 'under_review'"/>
                        <button name="action_publish" type="object" string="Publish"
                                class="btn-primary" groups="ab_website_seo_optimization.group_ab_website_seo_optimization_manager"
                                invisible="state not in ('approved', 'published')"/>
                        <button name="action_force_publish" type="object" string="Force Publish"
                                class="btn-secondary" groups="ab_website_seo_optimization.group_ab_website_seo_optimization_manager"
                                invisible="not has_conflict"/>
                        <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                                class="btn-secondary" invisible="state not in ('rejected', 'generated')"/>
                        <button name="action_archive" type="object" string="Archive"
                                class="btn-secondary" groups="ab_website_seo_optimization.group_ab_website_seo_optimization_manager"
                                invisible="state == 'archived'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="ab_product_id" readonly="state not in ('draft', 'generated')"/>
                                <field name="product_template_id" readonly="state not in ('draft', 'generated')"/>
                                <field name="website_id" readonly="state not in ('draft', 'generated')"/>
                                <field name="assistant_id" readonly="state not in ('draft', 'generated', 'rejected')"/>
                                <field name="company_id"/>
                                <field name="active"/>
                            </group>
                            <group>
                                <field name="source_quality" readonly="1"/>
                                <field name="seo_score" readonly="1"/>
                                <field name="ready_for_publish" readonly="1"/>
                                <field name="current_version_id" readonly="1"/>
                                <field name="published_version_id" readonly="1"/>
                                <field name="last_published_at" readonly="1"/>
                                <field name="last_published_by" readonly="1"/>
                            </group>
                        </group>
                        <group invisible="not has_conflict">
                            <field name="has_conflict" readonly="1"/>
                            <field name="conflict_note" readonly="1" nolabel="1"/>
                        </group>
                        <notebook>
                            <page string="Translations">
                                <field name="translation_ids" context="{'default_seo_id': id}">
                                    <list editable="bottom">
                                        <field name="lang_code"/>
                                        <field name="meta_title"/>
                                        <field name="meta_description"/>
                                        <field name="keyword_text"/>
                                        <field name="seo_name"/>
                                        <field name="content_source"/>
                                        <field name="current_version_id" readonly="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Versions">
                                <field name="version_ids" readonly="1">
                                    <list>
                                        <field name="version_number"/>
                                        <field name="lang_code"/>
                                        <field name="meta_title"/>
                                        <field name="approved_by"/>
                                        <field name="approved_at"/>
                                        <field name="is_published"/>
                                        <field name="published_at"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Source">
                                <field name="source_snapshot_ids" readonly="1">
                                    <list>
                                        <field name="snapshot_date"/>
                                        <field name="product_code"/>
                                        <field name="eplus_serial"/>
                                        <field name="manufacturer"/>
                                        <field name="scientific_name"/>
                                        <field name="usage_manner"/>
                                        <field name="origin"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Publish Logs">
                                <field name="publish_log_ids" readonly="1">
                                    <list>
                                        <field name="published_at"/>
                                        <field name="lang_code"/>
                                        <field name="field_name"/>
                                        <field name="operation"/>
                                        <field name="published_by"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_ab_website_seo_optimization_search" model="ir.ui.view">
            <field name="name">ab.product.seo.search</field>
            <field name="model">ab.product.seo</field>
            <field name="arch" type="xml">
                <search string="Website SEO">
                    <field name="name"/>
                    <field name="ab_product_id"/>
                    <field name="product_template_id"/>
                    <filter string="Active" name="filter_active" domain="[('active', '=', True)]"/>
                    <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="Generated" name="filter_generated" domain="[('state', '=', 'generated')]"/>
                    <filter string="Under Review" name="filter_review" domain="[('state', '=', 'under_review')]"/>
                    <filter string="Approved" name="filter_approved" domain="[('state', '=', 'approved')]"/>
                    <filter string="Published" name="filter_published" domain="[('state', '=', 'published')]"/>
                    <filter string="Conflicts" name="filter_conflict" domain="[('has_conflict', '=', True)]"/>
                    <separator/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Source Quality" name="group_source_quality" context="{'group_by': 'source_quality'}"/>
                    <filter string="Website" name="group_website" context="{'group_by': 'website_id'}"/>
                </search>
            </field>
        </record>
    </data>
</odoo>
