<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_ab_website_seo_optimization_list" model="ir.ui.view">
            <field name="name">ab.product.seo.list</field>
            <field name="model">ab.product.seo</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <list decoration-success="state == 'published'"
                      decoration-warning="state == 'under_review'"
                      decoration-danger="has_conflict">
                    <field name="name"/>
                    <field name="state"/>
                    <field name="ab_product_id"/>
                    <field name="product_template_id"/>
                    <field name="website_id"/>
                    <field name="assistant_id"/>
                    <field name="lang_mode"/>
                    <field name="product_optimization_state" widget="badge"
                           decoration-success="product_optimization_state == 'optimized'"
                           decoration-warning="product_optimization_state == 'partial'"
                           decoration-danger="product_optimization_state == 'missing'"/>
                    <field name="result_status" widget="badge"
                           decoration-success="result_status == 'optimized'"
                           decoration-warning="result_status in ('skipped', 'deferred')"
                           decoration-danger="result_status == 'error'"
                           decoration-muted="result_status in ('not_run', 'cancelled')"/>
                    <field name="optimized_count"/>
                    <field name="skipped_count"/>
                    <field name="error_count"/>
                    <field name="finished_at"/>
                </list>
            </field>
        </record>

        <record id="view_ab_website_seo_optimization_form" model="ir.ui.view">
            <field name="name">ab.product.seo.form</field>
            <field name="model">ab.product.seo</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_fill_with_ai" type="object" string="Optimize Product"
                                class="btn-success" invisible="state == 'archived'"
                                groups="ab_website_seo_optimization.group_ab_website_seo_optimization_manager"/>
                        <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                                class="btn-secondary" invisible="state not in ('rejected', 'generated', 'published')"/>
                        <button name="action_archive" type="object" string="Archive"
                                class="btn-secondary" groups="ab_website_seo_optimization.group_ab_website_seo_optimization_manager"
                                invisible="state == 'archived'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <field name="available_product_template_ids" invisible="1"/>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="active"/>
                                <field name="target"/>
                                <field name="website_id" readonly="state not in ('draft', 'generated', 'rejected')"/>
                                <field name="product_template_id" readonly="state not in ('draft', 'generated', 'rejected')"
                                       domain="[('id', 'in', available_product_template_ids)]"/>
                                <field name="assistant_id" readonly="state not in ('draft', 'generated', 'rejected')"
                                       domain="[('assistant_type', '=', 'ai'), ('active', '=', True)]"/>
                                <field name="lang_mode" readonly="state not in ('draft', 'generated', 'rejected')"/>
                            </group>
                            <group>
                                <field name="only_missing_seo"/>
                                <field name="publish_description"/>
                                <field name="started_at" readonly="1"/>
                                <field name="finished_at" readonly="1"/>
                            </group>
                        </group>
                        <group string="Results">
                            <field name="product_optimization_state" readonly="1" widget="badge"
                                   decoration-success="product_optimization_state == 'optimized'"
                                   decoration-warning="product_optimization_state == 'partial'"
                                   decoration-danger="product_optimization_state == 'missing'"/>
                            <field name="result_status" readonly="1" widget="badge"
                                   decoration-success="result_status == 'optimized'"
                                   decoration-warning="result_status in ('skipped', 'deferred')"
                                   decoration-danger="result_status == 'error'"
                                   decoration-muted="result_status in ('not_run', 'cancelled')"/>
                            <field name="last_bulk_id" readonly="1"/>
                            <field name="website_url" readonly="1"/>
                            <field name="processed_count" readonly="1"/>
                            <field name="optimized_count" readonly="1"/>
                            <field name="skipped_count" readonly="1"/>
                            <field name="error_count" readonly="1"/>
                        </group>
                        <field name="result_message" readonly="1"/>
                        <notebook>
                            <page string="English Result">
                                <group>
                                    <field name="en_meta_title" readonly="1"/>
                                    <field name="en_meta_description" readonly="1"/>
                                    <field name="en_keyword_text" readonly="1"/>
                                    <field name="en_seo_name" readonly="1"/>
                                </group>
                                <field name="en_public_description" readonly="1"/>
                            </page>
                            <page string="Arabic Result">
                                <group>
                                    <field name="ar_meta_title" readonly="1"/>
                                    <field name="ar_meta_description" readonly="1"/>
                                    <field name="ar_keyword_text" readonly="1"/>
                                    <field name="ar_seo_name" readonly="1"/>
                                </group>
                                <field name="ar_public_description" readonly="1"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_ab_website_seo_optimization_search" model="ir.ui.view">
            <field name="name">ab.product.seo.search</field>
            <field name="model">ab.product.seo</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <search string="Website SEO">
                    <field name="name"/>
                    <field name="ab_product_id"/>
                    <field name="product_template_id"/>
                    <filter string="Active" name="filter_active" domain="[('active', '=', True)]"/>
                    <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="Generated" name="filter_generated" domain="[('state', '=', 'generated')]"/>
                    <filter string="Under Review" name="filter_review" domain="[('state', '=', 'under_review')]"/>
                    <filter string="Approved" name="filter_approved" domain="[('state', '=', 'approved')]"/>
                    <filter string="Published" name="filter_published" domain="[('state', '=', 'published')]"/>
                    <filter string="Conflicts" name="filter_conflict" domain="[('has_conflict', '=', True)]"/>
                    <separator/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Source Quality" name="group_source_quality" context="{'group_by': 'source_quality'}"/>
                    <filter string="Website" name="group_website" context="{'group_by': 'website_id'}"/>
                </search>
            </field>
        </record>

        <record id="action_ab_website_seo_optimization_all_view_list" model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_ab_website_seo_optimization_list"/>
            <field name="act_window_id" ref="action_ab_website_seo_optimization_all"/>
        </record>

        <record id="action_ab_website_seo_optimization_all_view_form" model="ir.actions.act_window.view">
            <field name="sequence" eval="2"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_ab_website_seo_optimization_form"/>
            <field name="act_window_id" ref="action_ab_website_seo_optimization_all"/>
        </record>
    </data>
</odoo>
