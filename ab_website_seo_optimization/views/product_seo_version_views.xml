<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_ab_website_seo_optimization_version_list" model="ir.ui.view">
            <field name="name">ab.product.seo.version.list</field>
            <field name="model">ab.product.seo.version</field>
            <field name="arch" type="xml">
                <list decoration-success="is_published">
                    <field name="seo_id"/>
                    <field name="version_number"/>
                    <field name="lang_code"/>
                    <field name="meta_title"/>
                    <field name="approved_by"/>
                    <field name="approved_at"/>
                    <field name="is_published"/>
                    <field name="published_at"/>
                </list>
            </field>
        </record>

        <record id="view_ab_website_seo_optimization_version_form" model="ir.ui.view">
            <field name="name">ab.product.seo.version.form</field>
            <field name="model">ab.product.seo.version</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="seo_id" readonly="1"/>
                                <field name="translation_id" readonly="1"/>
                                <field name="version_number" readonly="1"/>
                                <field name="lang_code" readonly="1"/>
                                <field name="source_snapshot_id" readonly="1"/>
                            </group>
                            <group>
                                <field name="approved_by" readonly="1"/>
                                <field name="approved_at" readonly="1"/>
                                <field name="is_published" readonly="1"/>
                                <field name="published_by" readonly="1"/>
                                <field name="published_at" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="SEO">
                                <group>
                                    <field name="meta_title" readonly="1"/>
                                    <field name="meta_description" readonly="1"/>
                                    <field name="keyword_text" readonly="1"/>
                                    <field name="seo_name" readonly="1"/>
                                </group>
                            </page>
                            <page string="Content">
                                <group>
                                    <field name="short_description" readonly="1"/>
                                    <field name="public_description" readonly="1" widget="html"/>
                                    <field name="active_ingredient" readonly="1"/>
                                    <field name="warnings" readonly="1"/>
                                    <field name="contraindications" readonly="1"/>
                                    <field name="storage" readonly="1"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
