<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ab_odoo_replication_1_user" model="ir.cron">
            <field name="name">ab_odoo_replication_1_user</field>
            <field name="active" eval="True"/>
            <field name="priority" eval="5"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number" eval="10"/>
            <field name="interval_type">minutes</field>
            <field name="model_id" ref="ab_odoo_replication.model_ab_odoo_replication"/>
            <field name="state">code</field>
            <field name="code">
                # @formatter:off
model.replicate_model('res.partner', replicate_all=True)
model.replicate_model('res.users', extra_fields={'group_ids': 'many2many'})
model.add_res_company_rel_for_all_users()

            </field>
        </record>

        <record id="ab_odoo_replication_2_hr" model="ir.cron">
            <field name="name">ab_odoo_replication_2_hr</field>
            <field name="active" eval="True"/>
            <field name="priority" eval="5"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number" eval="30"/>
            <field name="interval_type">minutes</field>
            <field name="model_id" ref="ab_odoo_replication.model_ab_odoo_replication"/>
            <field name="state">code</field>
            <field name="code">
model.replicate_model('ab_costcenter')
model.replicate_model('ab_store')
model.replicate_model('ab_replica_db', extra_fields={'allowed_sales_store_ids': 'many2many'},
                      replicate_all=True)
model.replicate_model('ab_hr_region')
model.replicate_model('ab_hr_job')
model.replicate_model('ab_hr_department')
model.replicate_model('ab_hr_employee')
model.replicate_model('ab_hr_job_occupied')
            </field>
        </record>

        <record id="ab_odoo_replication_3_customer" model="ir.cron">
            <field name="name">ab_odoo_replication_3_customer</field>
            <field name="active" eval="True"/>
            <field name="priority" eval="5"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number" eval="1"/>
            <field name="interval_type">hours</field>
            <field name="model_id" ref="ab_odoo_replication.model_ab_odoo_replication"/>
            <field name="state">code</field>
            <field name="code">model.replicate_model('ab_customer')</field>
        </record>

        <record id="ab_odoo_replication_4_product" model="ir.cron">
            <field name="name">ab_odoo_replication_4_product</field>
            <field name="active" eval="True"/>
            <field name="priority" eval="5"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number" eval="1"/>
            <field name="interval_type">hours</field>
            <field name="model_id" ref="ab_odoo_replication.model_ab_odoo_replication"/>
            <field name="state">code</field>
            <field name="code">
model.replicate_model('ab_uom_type')
model.replicate_model('ab_uom')

model.replicate_model('ab_product_uom_category')
model.replicate_model('ab_product_uom')
model.replicate_model('ab_product_card')
model.replicate_model('ab_product')
model.replicate_model('ab_product_barcode', limit=10000,
                      extra_fields={'product_ids': 'many2many'})
            </field>
        </record>

        <record id="ab_odoo_replication_4_product__all" model="ir.cron">
            <field name="name">ab_odoo_replication_4_product__all</field>
            <field name="active" eval="True"/>
            <field name="priority" eval="5"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number" eval="1"/>
            <field name="interval_type">days</field>
            <field name="model_id" ref="ab_odoo_replication.model_ab_odoo_replication"/>
            <field name="state">code</field>
            <field name="code">
model.replicate_model('ab_uom_type')
model.replicate_model('ab_uom')

model.replicate_model('ab_product_uom_category')
model.replicate_model('ab_product_uom')
model.replicate_model('ab_product_card')
model.replicate_model('ab_product', replicate_all=True)
model.replicate_model('ab_product_barcode', limit=10000,
                      extra_fields={'product_ids': 'many2many'})
            </field>
        </record>

        <record id="ab_odoo_replication_5_contract" model="ir.cron">
            <field name="name">ab_odoo_replication_5_contract</field>
            <field name="active" eval="True"/>
            <field name="priority" eval="5"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number" eval="1"/>
            <field name="interval_type">hours</field>
            <field name="model_id" ref="ab_odoo_replication.model_ab_odoo_replication"/>
            <field name="state">code</field>
            <field name="code">model.replicate_model('ab_contract')</field>
        </record>

        <record id="ab_odoo_replication_6_promo" model="ir.cron">
            <field name="name">ab_odoo_replication_6_promo</field>
            <field name="active" eval="True"/>
            <field name="priority" eval="5"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number" eval="1"/>
            <field name="interval_type">hours</field>
            <field name="model_id" ref="ab_odoo_replication.model_ab_odoo_replication"/>
            <field name="state">code</field>
            <field name="code">
model.replicate_model('ab_promo_program', limit=10000, replicate_all=True,
                     extra_fields={'product_ids': 'many2many',
                     'store_ids': 'many2many',
                     'replica_db_ids': 'many2many'})

            </field>
        </record>

        <record id="ab_sales_inventory" model="ir.cron">
            <field name="name">ab_sales_inventory</field>
            <field name="active" eval="True"/>
            <field name="priority" eval="5"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number" eval="2"/>
            <field name="interval_type">hours</field>
            <field name="model_id" ref="ab_sales.model_ab_sales_inventory"/>
            <field name="state">code</field>
            <field name="code">model.btn_update_balance_total()</field>
        </record>

        <record id="ab_sales_inventory_per_pos" model="ir.cron">
            <field name="name">ab_sales_inventory_per_pos</field>
            <field name="active" eval="True"/>
            <field name="priority" eval="5"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number" eval="4"/>
            <field name="interval_type">hours</field>
            <field name="model_id" ref="ab_sales.model_ab_sales_inventory"/>
            <field name="state">code</field>
            <field name="code">model.btn_update_balance_per_pos()</field>
        </record>

        <record id="ab_sales_sync_status" model="ir.cron">
            <field name="name">ab_sales_sync_status</field>
            <field name="active" eval="True"/>
            <field name="priority" eval="5"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number" eval="5"/>
            <field name="interval_type">minutes</field>
            <field name="model_id" ref="ab_sales.model_ab_sales_header"/>
            <field name="state">code</field>
            <field name="code">model.cron_update_status_from_store()</field>
        </record>
    </data>
</odoo>
