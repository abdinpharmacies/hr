<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="ab_security_role_view_list" model="ir.ui.view">
            <field name="name">ab_security_role.list</field>
            <field name="model">ab_security_role</field>
            <field name="arch" type="xml">
                <list string="Security Roles">
                    <field name="name"/>
                    <field name="group_id"/>
                    <field name="parent_role_id"/>
                    <field name="inherited"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="ab_security_role_view_search" model="ir.ui.view">
            <field name="name">ab_security_role.search</field>
            <field name="model">ab_security_role</field>
            <field name="arch" type="xml">
                <search string="Security Roles">
                    <field name="name"/>
                    <field name="group_id"/>
                    <field name="parent_role_id"/>
                    <filter name="filter_active" string="Active" domain="[('active', '=', True)]"/>
                    <filter name="filter_inherited" string="Inherited" domain="[('inherited', '=', True)]"/>
                </search>
            </field>
        </record>

        <record id="ab_security_role_view_form" model="ir.ui.view">
            <field name="name">ab_security_role.form</field>
            <field name="model">ab_security_role</field>
            <field name="arch" type="xml">
                <form string="Security Role">
                    <header>
                        <button name="action_apply_permissions" string="Apply Permissions" type="object" class="btn-primary"/>
                        <button name="action_duplicate_role" string="Duplicate Role" type="object"/>
                        <button name="action_inherit_role" string="Inherit Role" type="object"/>
                    </header>
                    <sheet>
                        <group col="2">
                            <group>
                                <field name="name"/>
                                <field name="group_id" readonly="1"/>
                                <field name="active"/>
                            </group>
                            <group>
                                <field name="parent_role_id"/>
                                <field name="inherited" readonly="1"/>
                                <field name="managed_group" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="user_ids" widget="many2many_tags"/>
                        </group>
                        <notebook>
                            <page string="Model Permissions">
                                <field name="model_access_ids" context="{'default_role_id': id}">
                                    <list editable="bottom" string="Model Permissions">
                                        <field name="active"/>
                                        <field name="model_id"/>
                                        <field name="perm_read"/>
                                        <field name="perm_write"/>
                                        <field name="perm_create"/>
                                        <field name="perm_unlink"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Field Permissions">
                                <field name="field_access_ids" context="{'default_role_id': id}">
                                    <list editable="bottom" string="Field Permissions">
                                        <field name="field_id"/>
                                        <field name="field_type" readonly="1"/>
                                        <field name="relation_model_name" readonly="1" optional="hide"/>
                                        <field name="can_view"/>
                                        <field name="can_edit"/>
                                        <field name="warning_message" readonly="1" optional="hide"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="ab_security_role_action" model="ir.actions.act_window">
            <field name="name">Roles</field>
            <field name="res_model">ab_security_role</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="ab_security_role_view_search"/>
            <field name="context">{'search_default_filter_active': 1}</field>
        </record>
    </data>
</odoo>
