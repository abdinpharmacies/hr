<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="ab_res_users_view_form_inherit_security_manager" model="ir.ui.view">
            <field name="name">res.users.form.ab.smart.security.manager</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='access_rights']//group" position="after">
                    <group string="Smart Security Roles">
                        <field name="ab_role_ids" widget="many2many_tags"/>
                    </group>
                </xpath>
            </field>
        </record>

        <record id="ab_res_users_view_list_inherit_security_manager" model="ir.ui.view">
            <field name="name">res.users.list.ab.smart.security.manager</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//list" position="inside">
                    <field name="ab_role_ids" widget="many2many_tags" optional="hide"/>
                </xpath>
            </field>
        </record>

        <record id="ab_security_user_role_assignment_action" model="ir.actions.act_window">
            <field name="name">User Role Assignment</field>
            <field name="res_model">res.users</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('share', '=', False)]</field>
        </record>
    </data>
</odoo>
