<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="ab_security_model_access_view_list" model="ir.ui.view">
            <field name="name">ab_security_model_access.list</field>
            <field name="model">ab_security_model_access</field>
            <field name="arch" type="xml">
                <list string="Model Permissions">
                    <field name="role_id"/>
                    <field name="model_id"/>
                    <field name="perm_read"/>
                    <field name="perm_write"/>
                    <field name="perm_create"/>
                    <field name="perm_unlink"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="ab_security_model_access_view_search" model="ir.ui.view">
            <field name="name">ab_security_model_access.search</field>
            <field name="model">ab_security_model_access</field>
            <field name="arch" type="xml">
                <search string="Model Permissions">
                    <field name="role_id"/>
                    <field name="model_id"/>
                    <field name="model_name"/>
                    <filter name="filter_custom_models" string="Custom Models" domain="[('model_name', '=like', 'ab_%')]"/>
                    <filter name="filter_hide_technical" string="Hide Technical" domain="[('model_is_technical', '=', False)]"/>
                    <filter name="filter_business_models" string="Business Models" domain="[('model_is_business', '=', True)]"/>
                    <filter name="filter_active" string="Active" domain="[('active', '=', True)]"/>
                </search>
            </field>
        </record>

        <record id="ab_security_model_access_view_form" model="ir.ui.view">
            <field name="name">ab_security_model_access.form</field>
            <field name="model">ab_security_model_access</field>
            <field name="arch" type="xml">
                <form string="Model Permission">
                    <sheet>
                        <group col="2">
                            <group>
                                <field name="role_id"/>
                                <field name="model_id"/>
                                <field name="active"/>
                            </group>
                            <group>
                                <field name="perm_read"/>
                                <field name="perm_write"/>
                                <field name="perm_create"/>
                                <field name="perm_unlink"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="ab_security_model_access_action" model="ir.actions.act_window">
            <field name="name">Model Permissions</field>
            <field name="res_model">ab_security_model_access</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="ab_security_model_access_view_search"/>
            <field name="context">{'search_default_filter_custom_models': 1, 'search_default_filter_active': 1}</field>
        </record>
    </data>
</odoo>
