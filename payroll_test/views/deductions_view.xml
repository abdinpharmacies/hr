<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_daily_hours_deduction_tree" model="ir.ui.view">
        <field name="name">daily.hours.deduction.tree</field>
        <field name="model">daily.hours.deduction</field>
        <field name="arch" type="xml">
            <list string="Deductions">
                <field name="employee_id"/>
                <field name="period_id"/>
                <field name="absence_deduction_basic"/>
                <field name="absence_deduction_allowances"/>
                <field name="delay_deduction"/>
                <field name="total_deductions"/>
            </list>
        </field>
    </record>

    <record id="view_daily_hours_deduction_form" model="ir.ui.view">
        <field name="name">daily.hours.deduction.form</field>
        <field name="model">daily.hours.deduction</field>
        <field name="arch" type="xml">
            <form string="Deduction">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="period_id"/>
                        </group>
                        <group>
                            <field name="absence_deduction_basic"/>
                            <field name="absence_deduction_allowances"/>
                            <field name="delay_deduction"/>
                            <field name="total_deductions"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
