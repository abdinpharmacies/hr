<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_daily_hours_payroll_period_tree" model="ir.ui.view">
        <field name="name">daily.hours.payroll.period.tree</field>
        <field name="model">daily.hours.payroll.period</field>
        <field name="arch" type="xml">
            <list string="Payroll Periods">
                <field name="name"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="total_working_days"/>
            </list>
        </field>
    </record>

    <record id="view_daily_hours_payroll_period_form" model="ir.ui.view">
        <field name="name">daily.hours.payroll.period.form</field>
        <field name="model">daily.hours.payroll.period</field>
        <field name="arch" type="xml">
            <form string="Payroll Period">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group>
                            <field name="total_working_days"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
