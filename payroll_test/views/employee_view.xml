<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_daily_hours" model="ir.ui.view">
        <field name="name">hr.employee.form.daily.hours</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <div class="oe_title">
                    <label for="registration_number" class="oe_edit_only"/>
                    <h1>
                        <field name="registration_number" placeholder="كود الموظف"/>
                    </h1>
                </div>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Payroll Accounting" name="payroll_accounting">
                    <group>
                        <group string="Identity and Job Settings">
                            <field name="registration_number" />
                            <field name="job_id" />
                            <field name="department_id" />
                            <field name="work_location_id" />
                        </group>
                        <group string="Payroll Settings">
                            <field name="payroll_system" />
                            <field name="working_hours_per_day" />
                            <field name="shift_scheduled_start" widget="float_time" />
                            <field name="hourly_rate_basic" />
                            <field name="hourly_rate_allowances" />
                            <field name="is_delivery_staff" />
                            <field name="sector" />
                        </group>
                        <group string="Insurance and Deductions">
                            <field name="social_insurance" />
                            <field name="health_insurance" />
                            <field name="syndicate_fund" />
                        </group>
                    </group>
                    <group>
                        <group string="Weekly Off Days">
                            <field name="weekly_off_day_1" />
                            <field name="weekly_off_day_2" />
                        </group>
                        <group string="Salary Summary">
                            <div class="oe_title">
                                <label for="agreement_salary" string="Agreed Salary" style="font-weight: bold; font-size: 1.2em; color: #2c3e50;"/>
                                <h2 style="color: #e74c3c;">
                                    <field name="agreement_salary" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </h2>
                            </div>
                        </group>
                    </group>
                    <group string="Fixed Extra Allowances">
                        <p class="text-muted" colspan="2">
                            أضف هنا أي بدلات إضافية يحصل عليها الموظف بشكل شهري ثابت (سيتم سحب القيمة الافتراضية تلقائياً عند اختيار النوع).
                        </p>
                        <field name="extra_allowances_ids" nolabel="1" colspan="2">
                            <list editable="bottom">
                                <field name="allowance_type_id"/>
                                <field name="calculation_type"/>
                                <field name="amount" sum="إجمالي البدلات"/>
                            </list>
                        </field>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
