<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_payroll_rule_system_tree" model="ir.ui.view">
        <field name="name">payroll.rule.system.tree</field>
        <field name="model">payroll.rule.system</field>
        <field name="arch" type="xml">
            <list string="Payroll Rule Systems">
                <field name="name"/>
                <field name="policy_type"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_payroll_rule_system_form" model="ir.ui.view">
        <field name="name">payroll.rule.system.form</field>
        <field name="model">payroll.rule.system</field>
        <field name="arch" type="xml">
            <form string="Payroll Rule System">
                <header>
                    <button name="action_confirm" string="Confirm Policy" type="object" class="btn-primary" invisible="state == 'confirmed'"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="مثلاً: نظام الساعات اليومية"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="policy_type"/>
                        </group>
                    </group>

                    <!-- AI Communication Box -->
                    <div style="background: #f0f4ff; border: 2px dashed #1a73e8; border-radius: 12px; padding: 16px; margin-bottom: 16px;">
                        <h3 style="margin: 0 0 8px 0; color: #1a73e8;">🤖 تواصل مع المحرك الذكي</h3>
                        <p style="margin: 0 0 8px 0; color: #555; font-size: 13px;">
                            اكتب هنا أي تعليمات أو تصحيحات تريد إبلاغها للمحرك (مثلاً: "عمود القيمة هو صافي الراتب"، أو "نظام هذا الشيت يعتمد على اليوم وليس الساعة").
                            ثم ارفع الملف مرة أخرى وسيأخذ المحرك تعليماتك بعين الاعتبار.
                        </p>
                        <field name="user_instructions" placeholder="اكتب تعليماتك هنا للمحرك الذكي..." style="min-height: 80px;"/>
                    </div>

                    <notebook>
                        <page string="📊 تحليل السياسة (AI Report)" name="policy">
                            <field name="policy_narrative" widget="html" options="{'style-inline': true}"/>
                        </page>
                        <page string="⚙️ القواعد والمعادلات" name="rules">
                            <field name="rule_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="equation"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
