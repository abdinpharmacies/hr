<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_daily_hours_attendance_tree" model="ir.ui.view">
        <field name="name">daily.hours.attendance.tree</field>
        <field name="model">daily.hours.attendance</field>
        <field name="arch" type="xml">
            <list string="Attendance Records" editable="bottom" decoration-warning="attendance_status == 'forget_checkout'">
                <header>
                    <button name="%(action_attendance_import)d" string="Import (.xlsx)" type="action" class="btn-primary"/>
                </header>
                <field name="employee_id"/>
                <field name="date"/>
                <field name="branch_name" readonly="1"/>
                <field name="attendance_status" widget="badge" decoration-warning="attendance_status == 'forget_checkout'" decoration-success="attendance_status == 'normal'"/>
                <field name="check_in_time"/>
                <field name="check_out_time"/>
                <field name="working_hours"/>
                <field name="extra_hours"/>
                <field name="delay_hours"/>
                <field name="absence_days"/>
            </list>
        </field>
    </record>

    <record id="view_daily_hours_attendance_form" model="ir.ui.view">
        <field name="name">daily.hours.attendance.form</field>
        <field name="model">daily.hours.attendance</field>
        <field name="arch" type="xml">
            <form string="Attendance Record">
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="check_in_time"/>
                            <field name="check_out_time"/>
                        </group>
                    </group>
                    <group>
                        <group string="Calculated Hours">
                            <field name="working_hours"/>
                            <field name="extra_hours"/>
                            <field name="extra_minutes"/>
                            <field name="delay_hours"/>
                            <field name="shortage_minutes"/>
                        </group>
                        <group string="Absence and Permissions">
                            <field name="absence_days"/>
                            <field name="authorized_shift_change"/>
                            <field name="manual_shift_start" invisible="authorized_shift_change == False" widget="float_time"/>
                            <field name="authorized_two_hour_permission"/>
                            <field name="authorized_overtime"/>
                        </group>
                    </group>
                    <group>
                        <group string="Violations">
                            <field name="is_unauthorized_shift"/>
                            <field name="is_late_arrival"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_daily_hours_attendance_calendar" model="ir.ui.view">
        <field name="name">daily.hours.attendance.calendar</field>
        <field name="model">daily.hours.attendance</field>
        <field name="arch" type="xml">
            <calendar string="Attendance Calendar" date_start="check_in_time" date_stop="check_out_time" color="employee_id">
                <field name="employee_id"/>
            </calendar>
        </field>
    </record>

</odoo>
