<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_daily_hours_payslip_tree" model="ir.ui.view">
        <field name="name">daily.hours.payslip.tree</field>
        <field name="model">daily.hours.payslip</field>
        <field name="arch" type="xml">
            <list string="Payslips">
                <field name="employee_id"/>
                <field name="period_id"/>
                <field name="agreement_salary" optional="show"/>
                <field name="attendance_percentage" optional="hide"/>
                <field name="total_earnings"/>
                <field name="total_deductions"/>
                <field name="net_salary"/>
            </list>
        </field>
    </record>

    <record id="view_daily_hours_payslip_form" model="ir.ui.view">
        <field name="name">daily.hours.payslip.form</field>
        <field name="model">daily.hours.payslip</field>
        <field name="arch" type="xml">
            <form string="Payslip">
                <header>
                    <button name="action_prepare_attendances" string="Prepare Records" type="object" class="btn-secondary"/>
                    <button name="generate_payslip" string="Calculate Payroll" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="period_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Daily Attendance (Interactive)">
                            <field name="attendance_ids" mode="list">
                                <list editable="bottom" string="Record" decoration-danger="absence_days > 0" decoration-warning="is_late_arrival or is_unauthorized_shift" decoration-success="extra_minutes > 0">
                                    <field name="date" readonly="1"/>
                                    <field name="day_name" readonly="1"/>
                                    <field name="check_in_time"/>
                                    <field name="check_out_time"/>
                                    <field name="working_hours" sum="1"/>
                                    <field name="shortage_minutes" sum="1"/>
                                    <field name="extra_minutes" sum="1"/>
                                    <field name="absence_days" sum="1"/>
                                    <field name="is_late_arrival" readonly="1"/>
                                    <field name="is_unauthorized_shift" readonly="1"/>
                                    <field name="authorized_shift_change" widget="boolean"/>
                                    <field name="manual_shift_start" invisible="authorized_shift_change == False" widget="float_time"/>
                                    <field name="authorized_two_hour_permission" widget="boolean"/>
                                    <field name="authorized_overtime" widget="boolean"/>
                                </list>
                            </field>
                        </page>
<page string="Account Summary">
                            <group>
                                <group string="Earnings">
                                    <field name="attendance_percentage" decoration-bf="1"/>
                                    <field name="agreement_salary" decoration-warning="1" style="font-weight: bold;"/>
                                    <separator string="Salary and Allowances" />
                                    <field name="salary_basic"/>
                                    <field name="allowances_basic_four"/>
                                    <separator string="Extra Allowances"/>
                                    <field name="extra_allowances_fixed"/>
                                    <field name="extra_allowances_prorated"/>
                                    <field name="extra_allowances_custom"/>
                                    <field name="extra_allowances"/>
                                    <separator string="Overtime and Bonuses"/>
                                    <field name="earning_grace_period_overtime"/>
                                    <field name="earning_authorized_overtime"/>
                                    <field name="earning_two_hour_permission"/>
                                    <field name="earning_manual_bonus"/>
                                    <field name="total_earnings"/>
                                </group>
                                <group string="Deductions">
                                    <field name="penalty_late_arrival"/>
                                    <field name="penalty_unauthorized_shift"/>
                                    <field name="penalty_shortage_hours"/>
                                    <field name="penalty_forget_fingerprint"/>
                                    <field name="total_deductions" style="font-weight: bold;"/>
                                </group>
                            </group>
                            <group>
                                <group>
                                    <field name="net_salary" style="font-size: 1.5em; color: green; font-weight: bold;"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
