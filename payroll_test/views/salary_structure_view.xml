<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_daily_hours_salary_structure_tree" model="ir.ui.view">
        <field name="name">daily.hours.salary.structure.tree</field>
        <field name="model">daily.hours.salary.structure</field>
        <field name="arch" type="xml">
            <list string="Salary Structures">
                <field name="employee_id"/>
                <field name="period_id"/>
                <field name="basic_salary"/>
                <field name="total_basic_allowances"/>
                <field name="extra_allowances"/>
                <field name="day_total"/>
                <field name="hour_total"/>
            </list>
        </field>
    </record>

    <record id="view_daily_hours_salary_structure_form" model="ir.ui.view">
        <field name="name">daily.hours.salary.structure.form</field>
        <field name="model">daily.hours.salary.structure</field>
        <field name="arch" type="xml">
            <form string="Salary Structure">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="period_id"/>
                        </group>
                        <group>
                            <field name="basic_salary"/>
                            <field name="working_days_in_period"/>
                            <field name="attendance_percentage" widget="percentage"/>
                            <field name="agreement_salary" decoration-warning="1" style="font-weight: bold;"/>
                        </group>
                    </group>
                    <notebook>
<page string="Basic Allowances">
                            <group>
                                <field name="allowance_nature_of_work"/>
                                <field name="allowance_performance"/>
                                <field name="allowance_cost_of_living"/>
                                <field name="allowance_dedication"/>
                                <field name="total_basic_allowances"/>
                            </group>
                        </page>
                        <page string="Extra Allowances">
                            <group>
                                <field name="extra_allowances_fixed"/>
                                <field name="extra_allowances_prorated"/>
                                <field name="extra_allowances_custom"/>
                                <field name="extra_allowances"/>
                            </group>
                        </page>
                        <page string="Penalties (Fingerprint)">
                            <group>
                                <field name="forget_fingerprint_count"/>
                                <field name="forget_fingerprint_penalty" widget="monetary" decoration-danger="forget_fingerprint_penalty > 0"/>
                            </group>
                        </page>
                        <page string="Day and Hour Value">
                            <group>
                                <group string="Day Value">
                                    <field name="day_basic"/>
                                    <field name="day_allowances"/>
                                    <field name="day_total"/>
                                </group>
                                <group string="Hour Value">
                                    <field name="hour_basic"/>
                                    <field name="hour_allowances"/>
                                    <field name="hour_total"/>
                                </group>
                            </group>
                        </page>
                        <page string="البدلات الإضافية">
                            <group>
                                <field name="extra_allowances_fixed"/>
                                <field name="extra_allowances_prorated"/>
                                <field name="extra_allowances_custom"/>
                                <field name="extra_allowances" class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                        <page string="الجزاءات (نسيان البصمة)">
                            <group>
                                <field name="forget_fingerprint_count"/>
                                <field name="forget_fingerprint_penalty" widget="monetary" decoration-danger="forget_fingerprint_penalty > 0"/>
                            </group>
                        </page>
                        <page string="قيمة اليوم والساعة">
                            <group>
                                <group string="قيمة اليوم">
                                    <field name="day_basic"/>
                                    <field name="day_allowances"/>
                                    <field name="day_total" class="oe_subtotal_footer_separator"/>
                                </group>
                                <group string="قيمة الساعة">
                                    <field name="hour_basic"/>
                                    <field name="hour_allowances"/>
                                    <field name="hour_total" class="oe_subtotal_footer_separator"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
