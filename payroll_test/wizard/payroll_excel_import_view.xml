<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_payroll_excel_import_wizard_form" model="ir.ui.view">
        <field name="name">payroll.excel.import.wizard.form</field>
        <field name="model">payroll.excel.import.wizard</field>
        <field name="arch" type="xml">
            <form string="رفع ملف إكسل">
                <sheet>
                    <group>
                        <field name="system_id"/>
                        <field name="file" filename="file_name"/>
                    </group>
                    <footer>
                        <button name="action_import" string="استيراد" type="object" class="btn-primary"/>
                        <button string="إلغاء" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
