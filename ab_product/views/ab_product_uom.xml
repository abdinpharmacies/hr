<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ab_product_uom_category_view_tree" model="ir.ui.view">
            <field name="name">ab_product_uom_category_view_tree</field>
            <field name="model">ab_product_uom_category</field>
            <field name="arch" type="xml">
                <list string="UoM Categories" editable="bottom">
                    <field name="name"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="ab_product_uom_category_view_form" model="ir.ui.view">
            <field name="name">ab_product_uom_category_view_form</field>
            <field name="model">ab_product_uom_category</field>
            <field name="arch" type="xml">
                <form string="UoM Category">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                        <notebook>
                            <page name="UoMs" string="UoMs">
                                <field name="uom_ids" nolabel="1">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="uom_type"/>
                                        <field name="factor"/>
                                        <field name="rounding"/>
                                        <field name="active" widget="boolean_toggle"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="ab_product_uom_view_tree" model="ir.ui.view">
            <field name="name">ab_product_uom_view_tree</field>
            <field name="model">ab_product_uom</field>
            <field name="arch" type="xml">
                <list string="UoMs" editable="bottom">
                    <field name="name"/>
                    <field name="category_id"/>
                    <field name="uom_type"/>
                    <field name="factor"/>
                    <field name="rounding"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="ab_product_uom_view_form" model="ir.ui.view">
            <field name="name">ab_product_uom_view_form</field>
            <field name="model">ab_product_uom</field>
            <field name="arch" type="xml">
                <form string="UoM">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="category_id"/>
                            <field name="uom_type"/>
                            <field name="factor"/>
                            <field name="rounding"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
