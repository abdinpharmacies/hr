            <field name="model">ab.sales.dashboard.reconciliation.job</field>
            <field name="arch" type="xml">
                <list string="Reconciliation Jobs" decoration-danger="state == 'failed'" decoration-warning="state == 'partial'" decoration-success="state == 'done'">
                    <field name="name"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="state"/>
                    <field name="total_branch_days"/>
                    <field name="missing_branch_days"/>
                    <field name="processed_branch_days"/>
                    <field name="chunk_count"/>
                    <field name="completed_chunk_count"/>
                    <field name="failed_chunk_count"/>
                    <field name="started_at"/>
                    <field name="completed_at"/>
                    <field name="created_by"/>
                </list>
            </field>
        </record>

        <record id="view_ab_sales_dashboard_reconciliation_job_form" model="ir.ui.view">
            <field name="name">ab.sales.dashboard.reconciliation.job.form</field>
            <field name="model">ab.sales.dashboard.reconciliation.job</field>
            <field name="arch" type="xml">
                <form string="Reconciliation Job">
                    <header>
                        <button name="action_analyze_coverage" type="object" string="Analyze Coverage" class="btn-primary" invisible="state == 'running'"/>
                        <button name="action_start_reconciliation" type="object" string="Start Reconciliation" class="btn-primary" invisible="state not in ('ready', 'partial', 'failed')"/>
                        <button name="action_retry_failed_chunks" type="object" string="Retry Failed" class="btn-secondary" invisible="state not in ('partial', 'failed')"/>
                        <button name="action_cancel" type="object" string="Cancel" class="btn-secondary" invisible="state in ('done', 'cancelled')"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,analyzing,ready,running,partial,done,failed,cancelled"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" readonly="state != 'draft'"/>
                                <field name="date_from" readonly="state != 'draft'"/>
                                <field name="date_to" readonly="state != 'draft'"/>
                                <field name="store_ids" widget="many2many_tags" readonly="state != 'draft'"/>
                                <field name="store_filter_key" readonly="1"/>
                            </group>
                            <group>
                                <field name="created_by" readonly="1"/>
                                <field name="started_at" readonly="1"/>
                                <field name="completed_at" readonly="1"/>
                                <field name="last_processed_date" readonly="1"/>
                            </group>
                        </group>
                        <group string="Progress">
                            <group>
                                <field name="total_branch_days" readonly="1"/>
                                <field name="covered_branch_days" readonly="1"/>
                                <field name="missing_branch_days" readonly="1"/>
                                <field name="processed_branch_days" readonly="1"/>
                                <field name="failed_branch_days" readonly="1"/>
                            </group>
                            <group>
                                <field name="chunk_count" readonly="1"/>
                                <field name="completed_chunk_count" readonly="1"/>
                                <field name="failed_chunk_count" readonly="1"/>
                            </group>
                        </group>
                        <group string="Last Error" invisible="not last_error">
                            <field name="last_error" readonly="1" nolabel="1"/>
                        </group>
                        <notebook>
                            <page string="Chunks">
                                <field name="chunk_ids" readonly="1">
                                    <list string="Chunks" create="0" edit="0" delete="0" decoration-danger="state == 'failed'" decoration-success="state == 'done'">
                                        <field name="sequence"/>
                                        <field name="date_from"/>
                                        <field name="date_to"/>
                                        <field name="store_filter_key"/>
                                        <field name="branch_day_count"/>
                                        <field name="state"/>
                                        <field name="attempt_count"/>
                                        <field name="source_duration_ms"/>
                                        <field name="persistence_duration_ms"/>
                                        <field name="error_message"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

