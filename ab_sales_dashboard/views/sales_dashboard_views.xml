<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_ab_sales_dashboard_snapshot_list" model="ir.ui.view">
            <field name="name">ab.sales.dashboard.snapshot.list</field>
            <field name="model">ab.sales.dashboard.snapshot</field>
            <field name="arch" type="xml">
                <list string="Sales Dashboard Reports">
                    <field name="refresh_date"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="store_filter_label"/>
                    <field name="total_sales"/>
                    <field name="invoice_count"/>
                </list>
            </field>
        </record>

        <record id="view_ab_sales_dashboard_snapshot_form" model="ir.ui.view">
            <field name="name">ab.sales.dashboard.snapshot.form</field>
            <field name="model">ab.sales.dashboard.snapshot</field>
            <field name="arch" type="xml">
                <form string="Sales Dashboard Report" create="0" edit="0">
                    <header>
                        <button name="action_refresh" type="object" string="Refresh Report" class="btn-primary"/>
                        <button name="action_archive_report" type="object" string="Archive Report" class="btn-secondary" groups="ab_sales_dashboard.group_ab_sales_dashboard_manager"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="refresh_date"/>
                                <field name="store_filter_label"/>
                            </group>
                            <group>
                                <field name="date_from"/>
                                <field name="date_to"/>
                                <field name="store_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                        <group string="KPIs">
                            <field name="total_sales"/>
                            <field name="avg_daily_sales"/>
                            <field name="prev_avg_daily_sales"/>
                            <field name="avg_daily_growth_pct"/>
                            <field name="invoice_count"/>
                            <field name="bearing_pct"/>
                            <field name="total_units_sold"/>
                            <field name="unique_products_sold"/>
                            <field name="total_product_sales"/>
                            <field name="avg_products_per_invoice"/>
                            <field name="stores_with_sales"/>
                            <field name="avg_products_sold_per_store"/>
                        </group>
                        <notebook>
                            <page string="Collection">
                                <field name="collection_line_ids">
                                    <list>
                                        <field name="category"/>
                                        <field name="invoice_count"/>
                                        <field name="total_sales"/>
                                        <field name="pct_of_total"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Users">
                                <field name="user_line_ids">
                                    <list>
                                        <field name="employee_name"/>
                                        <field name="invoice_count"/>
                                        <field name="total_sales"/>
                                        <field name="pct_of_total"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Items">
                                <field name="item_line_ids">
                                    <list>
                                        <field name="eplus_item_code"/>
                                        <field name="item_name"/>
                                        <field name="sale_times"/>
                                        <field name="sold_qty"/>
                                        <field name="total_sales"/>
                                        <field name="current_balance"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Invoices">
                                <field name="invoice_line_ids">
                                    <list>
                                        <field name="invoice_no"/>
                                        <field name="invoice_date"/>
                                        <field name="customer_name"/>
                                        <field name="invoice_total"/>
                                        <field name="item_count"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_ab_sales_dashboard_report_archive_list" model="ir.ui.view">
            <field name="name">ab.sales.dashboard.report.archive.list</field>
            <field name="model">ab.sales.dashboard.report.archive</field>
            <field name="arch" type="xml">
                <list string="Archived Sales Reports" create="0" edit="0" delete="0">
                    <field name="archive_number"/>
                    <field name="name"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="store_filter_label"/>
                    <field name="archived_at"/>
                    <field name="archived_by"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="view_ab_sales_dashboard_report_archive_form" model="ir.ui.view">
            <field name="name">ab.sales.dashboard.report.archive.form</field>
            <field name="model">ab.sales.dashboard.report.archive</field>
            <field name="arch" type="xml">
                <form string="Archived Sales Report" create="0" edit="0" delete="0">
                    <header>
                        <button name="action_cancel" type="object" string="Cancel Archive" class="btn-secondary" invisible="state == 'cancelled'"/>
                        <field name="state" widget="statusbar" statusbar_visible="archived,cancelled"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="archive_number"/>
                                <field name="name"/>
                                <field name="snapshot_id"/>
                                <field name="archived_at"/>
                                <field name="archived_by"/>
                            </group>
                            <group>
                                <field name="date_from"/>
                                <field name="date_to"/>
                                <field name="store_filter_label"/>
                                <field name="store_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                        <group string="Integrity">
                            <field name="payload_hash"/>
                            <field name="payload_size_bytes"/>
                            <field name="source_snapshot_write_date"/>
                            <field name="payload_json" invisible="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

