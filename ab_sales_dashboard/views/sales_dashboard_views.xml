        <record id="view_ab_sales_dashboard_fact_decision_form" model="ir.ui.view">
            <field name="name">ab.sales.dashboard.fact.decision.form</field>
            <field name="model">ab.sales.dashboard.fact.decision</field>
            <field name="arch" type="xml">
                <form string="Fact-Grain Decision" create="0" edit="0" delete="0">
                    <sheet>
                        <group>
                            <field name="measurement_period"/>
                            <field name="long_range_report_count"/>
                        </group>
                        <group string="Employee Reporting">
                            <field name="employee_unsupported_count"/>
                            <field name="employee_gap_percentage"/>
                        </group>
                        <group string="Customer Reporting">
                            <field name="customer_unsupported_count"/>
                            <field name="customer_gap_percentage"/>
                        </group>
                        <group string="Product Reporting">
                            <field name="product_unsupported_count"/>
                            <field name="product_gap_percentage"/>
                            <field name="item_coverage_complete_percentage"/>
                        </group>
                        <group string="Performance">
                            <field name="average_duration_ms"/>
                            <field name="average_result_size_bytes"/>
                        </group>
                        <group string="Recommendation">
                            <field name="recommendation_code"/>
                            <field name="recommendation_reason" nolabel="1"/>
                        </group>
                    </sheet>
                    <footer>
