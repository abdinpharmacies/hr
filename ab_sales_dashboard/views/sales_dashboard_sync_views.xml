<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_ab_sales_dashboard_sync_state_search" model="ir.ui.view">
            <field name="name">ab_sales_dashboard_sync_state.search</field>
            <field name="model">ab_sales_dashboard_sync_state</field>
            <field name="arch" type="xml">
                <search string="Sales Dashboard Sync">
                    <field name="sync_date"/>
                    <field name="store_filter_label"/>
                    <filter name="pending" string="Pending" domain="[('state', '=', 'pending')]"/>
                    <filter name="running" string="Running" domain="[('state', '=', 'running')]"/>
                    <filter name="failed" string="Failed" domain="[('state', '=', 'failed')]"/>
                    <filter name="done" string="Done" domain="[('state', '=', 'done')]"/>
                    <filter name="group_state" string="Status" domain="[]" context="{'group_by': 'state'}"/>
                    <filter name="group_store" string="Store Scope" domain="[]" context="{'group_by': 'store_filter_label'}"/>
                </search>
            </field>
        </record>

        <record id="view_ab_sales_dashboard_sync_state_list" model="ir.ui.view">
            <field name="name">ab_sales_dashboard_sync_state.list</field>
            <field name="model">ab_sales_dashboard_sync_state</field>
            <field name="arch" type="xml">
                <list string="Sales Dashboard Sync" create="0" edit="0" delete="0">
                    <field name="sync_date"/>
                    <field name="store_filter_label"/>
                    <field name="state"/>
                    <field name="rows_synced"/>
                    <field name="started_at"/>
                    <field name="finished_at"/>
                </list>
            </field>
        </record>

        <record id="view_ab_sales_dashboard_sync_state_form" model="ir.ui.view">
            <field name="name">ab_sales_dashboard_sync_state.form</field>
            <field name="model">ab_sales_dashboard_sync_state</field>
            <field name="arch" type="xml">
                <form string="Sales Dashboard Sync" create="0" edit="0" delete="0">
                    <sheet>
                        <group>
                            <group>
                                <field name="sync_date"/>
                                <field name="store_filter_label"/>
                                <field name="store_filter_key"/>
                                <field name="store_id"/>
                            </group>
                            <group>
                                <field name="state"/>
                                <field name="rows_synced"/>
                                <field name="started_at"/>
                                <field name="finished_at"/>
                            </group>
                        </group>
                        <group>
                            <field name="error_message"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_ab_sales_dashboard_sync_state" model="ir.actions.act_window">
            <field name="name">Sales Dashboard Sync</field>
            <field name="res_model">ab_sales_dashboard_sync_state</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_ab_sales_dashboard_sync_state_search"/>
        </record>

        <record id="view_ab_sales_dashboard_sync_wizard_form" model="ir.ui.view">
            <field name="name">ab_sales_dashboard_sync_wizard.form</field>
            <field name="model">ab_sales_dashboard_sync_wizard</field>
            <field name="arch" type="xml">
                <form string="Sync Sales Dashboard Data">
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="store_id"/>
                        <field name="force_resync"/>
                    </group>
                    <footer>
                        <button name="action_sync_dashboard_data"
                                type="object"
                                string="Sync"
                                class="btn-primary"/>
                        <button string="Cancel"
                                special="cancel"
                                class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_ab_sales_dashboard_sync_wizard" model="ir.actions.act_window">
            <field name="name">Sync Sales Dashboard Data</field>
            <field name="res_model">ab_sales_dashboard_sync_wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem id="menu_ab_sales_dashboard_sync_state"
                  name="Dashboard Sync"
                  parent="menu_ab_sales_dashboard_root"
                  action="action_ab_sales_dashboard_sync_state"
                  sequence="31"
                  groups="ab_sales_dashboard.group_ab_sales_dashboard_manager"/>

        <menuitem id="menu_ab_sales_dashboard_sync_wizard"
                  name="Sync Report Data"
                  parent="menu_ab_sales_dashboard_root"
                  action="action_ab_sales_dashboard_sync_wizard"
                  sequence="32"
                  groups="ab_sales_dashboard.group_ab_sales_dashboard_manager"/>
    </data>
</odoo>
