<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="module_category_ab_sales_dashboard" model="ir.module.category">
            <field name="name">Sales Dashboard</field>
            <field name="sequence" eval="20"/>
        </record>

        <record id="privilege_ab_sales_dashboard" model="res.groups.privilege">
            <field name="name">Sales Dashboard</field>
            <field name="category_id" ref="module_category_ab_sales_dashboard"/>
            <field name="sequence">10</field>
        </record>

        <record id="group_ab_sales_dashboard_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="privilege_ab_sales_dashboard"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_ab_sales_dashboard_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="privilege_ab_sales_dashboard"/>
            <field name="implied_ids" eval="[(4, ref('group_ab_sales_dashboard_user'))]"/>
        </record>

        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('ab_sales_dashboard.group_ab_sales_dashboard_manager'))]"/>
        </record>
    </data>
</odoo>
