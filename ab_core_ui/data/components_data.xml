            <field name="category_id" ref="cat_dialogs"/>
            <field name="sequence">10</field>
            <field name="description">Standard confirmation dialog with cancel and confirm actions.</field>
            <field name="keywords">confirm, approve, yes, no, cancel, dialog</field>
            <field name="tags">dialog, confirm, action</field>
            <field name="template_ref">core_ui.dialog.confirm</field>
            <field name="version">1.0.0</field>
            <field name="status">stable</field>
            <field name="author">Core UI</field>
            <field name="dependencies">core_ui</field>
            <field name="when_to_use">Use when asking users to confirm a critical action before proceeding.</field>
            <field name="when_not_to_use">Do not use for simple, reversible actions. A toast notification may be more appropriate.</field>
            <field name="accessibility_notes">Ensure focus is trapped within the dialog. Support Escape key to dismiss.</field>
        </record>

