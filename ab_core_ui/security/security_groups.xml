<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="module_category_core_ui" model="ir.module.category">
            <field name="name">Core UI</field>
            <field name="description">Core UI Design System</field>
        </record>

        <record id="privilege_core_ui_access" model="res.groups.privilege">
            <field name="name">Access</field>
            <field name="category_id" ref="module_category_core_ui"/>
        </record>

        <record id="group_core_ui_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="privilege_core_ui_access"/>
        </record>

        <record id="group_core_ui_developer" model="res.groups">
            <field name="name">Developer</field>
            <field name="privilege_id" ref="privilege_core_ui_access"/>
            <field name="implied_ids" eval="[(4, ref('group_core_ui_user'))]"/>
        </record>

        <record id="group_core_ui_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="privilege_core_ui_access"/>
            <field name="implied_ids" eval="[(4, ref('group_core_ui_developer'))]"/>
        </record>

    </data>
</odoo>
