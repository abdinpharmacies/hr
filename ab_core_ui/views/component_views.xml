<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="core_ui_component_tree_view" model="ir.ui.view">
        <field name="name">core_ui.component.tree</field>
        <field name="model">core_ui.component</field>
        <field name="arch" type="xml">
            <list>
                <field name="component_id"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="status" widget="badge" decoration-success="status == 'stable'"
                    decoration-warning="status == 'beta'"
                    decoration-danger="status == 'deprecated'"/>
                <field name="version"/>
                <field name="usage_count"/>
                <field name="is_favorite"/>
            </list>
        </field>
    </record>

    <record id="core_ui_component_form_view" model="ir.ui.view">
        <field name="name">core_ui.component.form</field>
        <field name="model">core_ui.component</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="component_id" class="mb16"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="category_id"/>
                            <field name="sequence"/>
                            <field name="status"/>
                            <field name="version"/>
                            <field name="author"/>
                        </group>
                        <group>
                            <field name="tags"/>
                            <field name="keywords"/>
                            <field name="is_favorite"/>
                            <field name="usage_count"/>
                            <field name="template_ref"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" nolabel="1"/>
                            <group>
                                <field name="when_to_use"/>
                                <field name="when_not_to_use"/>
                            </group>
                            <field name="accessibility_notes"/>
                        </page>
                        <page string="Code Examples">
                            <field name="xml_example" nolabel="1"/>
                            <field name="owl_example" nolabel="1"/>
                            <field name="js_example" nolabel="1"/>
                        </page>
                        <page string="Technical">
                            <field name="dependencies"/>
                            <field name="slots"/>
                            <field name="props_doc"/>
                            <field name="states_doc"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="core_ui_component_search_view" model="ir.ui.view">
        <field name="name">core_ui.component.search</field>
        <field name="model">core_ui.component</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="component_id"/>
                <field name="description"/>
                <field name="tags"/>
                <field name="keywords"/>
                <field name="category_id"/>
                <filter name="favorites" string="Favorites"
                    domain="[('is_favorite', '=', True)]"/>
                <separator/>
                <filter name="stable" string="Stable"
                    domain="[('status', '=', 'stable')]"/>
                <filter name="beta" string="Beta"
                    domain="[('status', '=', 'beta')]"/>
                <group name="group_by">
                    <filter name="group_category" string="Category"
                        context="{'group_by': 'category_id'}"/>
                    <filter name="group_status" string="Status"
                        context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="core_ui_component_action" model="ir.actions.act_window">
        <field name="name">Components</field>
        <field name="res_model">core_ui.component</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="core_ui_component_search_view"/>
        <field name="help" type="html">
            <p>Browse and manage Core UI components.</p>
        </field>
    </record>

</odoo>
