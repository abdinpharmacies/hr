<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="core_ui_pattern_tree_view" model="ir.ui.view">
        <field name="name">core_ui.pattern.tree</field>
        <field name="model">core_ui.pattern</field>
        <field name="arch" type="xml">
            <list>
                <field name="pattern_id"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="component_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="core_ui_pattern_form_view" model="ir.ui.view">
        <field name="name">core_ui.pattern.form</field>
        <field name="model">core_ui.pattern</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="pattern_id"/>
                        <field name="name"/>
                        <field name="category_id"/>
                        <field name="sequence"/>
                    </group>
                    <field name="description" nolabel="1"/>
                    <field name="steps" nolabel="1"/>
                    <field name="component_ids" widget="many2many_tags"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="core_ui_pattern_action" model="ir.actions.act_window">
        <field name="name">Patterns</field>
        <field name="res_model">core_ui.pattern</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
