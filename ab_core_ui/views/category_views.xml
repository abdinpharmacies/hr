<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="core_ui_category_tree_view" model="ir.ui.view">
        <field name="name">core_ui.category.tree</field>
        <field name="model">core_ui.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="parent_id"/>
                <field name="component_count"/>
            </list>
        </field>
    </record>

    <record id="core_ui_category_form_view" model="ir.ui.view">
        <field name="name">core_ui.category.form</field>
        <field name="model">core_ui.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="parent_id"/>
                        <field name="sequence"/>
                        <field name="icon"/>
                    </group>
                    <field name="description" nolabel="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="core_ui_category_action" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">core_ui.category</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
