<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ab_message_wiz" model="ir.ui.view">
            <field name="name">ab_message_wiz</field>
            <field name="model">ab_message_wiz</field>
            <field name="arch" type="xml">
                <form string="Message">
                    <field name="name"/>
                    <field name="text"/>
                    <field name="html"/>
                    <field name="mode" invisible="1"/>

                    <footer>
                        <button string="OK" type="object" class="btn-primary" name="fn_method"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"
                                invisible="mode == False"/>
                    </footer>


                </form>
            </field>
        </record>

    </data>
</odoo>