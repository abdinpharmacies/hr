<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="cat_ab_manpower_hour_need" model="ir.module.category">
            <field name="name">Manpower Need Per Hour</field>
            <field name="sequence" eval="1"/>
        </record>

        <record id="privilege_ab_manpower_need_per_hour" model="res.groups.privilege">
            <field name="name">Manpower Need</field>
            <field name="category_id" ref="cat_ab_manpower_hour_need"/>
            <field name="sequence">35</field>
        </record>

        <record id="group_ab_manpower_need" model="res.groups">
            <field name="name">Manpower Need Per Hour</field>
            <field name="privilege_id" ref="privilege_ab_manpower_need_per_hour"/>
            <field name="implied_ids" eval="[(4, ref('ab_hr.group_ab_hr_manager'))]"/>
        </record>


    </data>
</odoo>