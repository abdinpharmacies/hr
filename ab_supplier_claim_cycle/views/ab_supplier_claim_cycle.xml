<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="invoice_view_tree" model="ir.ui.view">
            <field name="name">invoice_view_tree</field>
            <field name="model">ab_supplier_claim_cycle</field>
            <field name="arch" type="xml">
                <list string="invoice_tree">
                    <field name="supplier_id"/>
                    <field name="num_of_invoice"/>
                    <field name="create_date" string="Received Date"/>
                    <field name="status"/>
                    <field name="amount_of_check"/>
                    <field name="write_date" string="Last Update Date"/>
                    <field name="user_id"/>
                    <field name="area"/>


                    <!--                    <field name="write_date"/>-->
                </list>
            </field>
        </record>

        <record id="invoice_view_form" model="ir.ui.view">
            <field name="name">invoice_view_form</field>
            <field name="model">ab_supplier_claim_cycle</field>
            <field name="arch" type="xml">
                <form string="invoice_form">

                    <header>
                        <button name="btn_status" type="object" string="Inventory" class="btn-success mr-1 ml-5"
                                context="{'action':'inventory'}"
                        />
                        <button name="btn_status" type="object" string="Purchase" class="btn-success mr-1"
                                context="{'action':'purchase'}"
                        />

                        <button name="btn_status" type="object" string="Suppliers" class="btn-success mr-1"
                                context="{'action':'suppliers'}"
                        />
                        <button name="btn_status" type="object" string="Bank acc" class="btn-success mr-2"
                                context="{'action':'bank_acc'}"
                        />
                        <button name="btn_status" type="object" string="Sign check" class="btn-warning mr-1"
                                context="{'action':'sign_check'}"
                        />
                        <button name="btn_status" type="object" string="Closed" class="btn-danger mr-1"
                                context="{'action':'closed'}"
                                confirm="After closed you can't edit again"
                        />
                    </header>

                    <sheet>
                        <group>
                            <field name="supplier_id" readonly="status == 'closed'"/>
                            <field name="num_of_invoice" readonly="status == 'closed'"/>
                            <field name="status" readonly="1"/>
                            <field name="amount_of_check"/>
                            <field name="area"/>
                            <field name="type_of_invoice"/>
                            <!--                            <field name="attachment" filename="attachment_name"/>-->

                        </group>
                    </sheet>

                    <chatter/>
                </form>
            </field>
        </record>


        <record id="invoice_action" model="ir.actions.act_window">
            <field name="name">invoice</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">ab_supplier_claim_cycle</field>
            <field name="view_mode">list,form</field>
        </record>


        <menuitem id="invoice_menu"
                  name="Claim Cycle"
                  parent="supplier_claim_cycle_sub_menu"
                  action="invoice_action"
                  sequence="100"/>

    </data>
</odoo>
