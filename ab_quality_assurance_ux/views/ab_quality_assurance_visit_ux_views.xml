<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Improved List View -->
    <record id="ab_quality_assurance_visit_view_list_inherit" model="ir.ui.view">
        <field name="name">ab_quality_assurance_visit.list.inherit</field>
        <field name="model">ab_quality_assurance_visit</field>
        <field name="inherit_id" ref="ab_quality_assurance.ab_quality_assurance_visit_view_list"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="decoration-muted">state == 'draft'</attribute>
                <attribute name="decoration-info">state == 'submitted'</attribute>
                <attribute name="sample">1</attribute>
                <attribute name="expand">1</attribute>
            </xpath>
            <xpath expr="//field[@name='visit_date']" position="after">
                <field name="employee_id" widget="many2one_avatar"/>
            </xpath>
            <xpath expr="//field[@name='total_percentage']" position="attributes">
                <attribute name="widget">progressbar</attribute>
            </xpath>
            <xpath expr="//field[@name='state']" position="attributes">
                <attribute name="widget">badge</attribute>
                <attribute name="decoration-success">state == 'submitted'</attribute>
                <attribute name="decoration-info">state == 'draft'</attribute>
            </xpath>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="ab_quality_assurance_visit_view_kanban" model="ir.ui.view">
        <field name="name">ab_quality_assurance_visit.kanban</field>
        <field name="model">ab_quality_assurance_visit</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" sample="1" quick_create="false">
                <field name="name"/>
                <field name="department_id"/>
                <field name="employee_id"/>
                <field name="visit_date"/>
                <field name="total_percentage"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click shadow-sm border-0 mb-2">
                            <div class="o_kanban_record_top mb-2">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title text-primary fs-5">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <field name="state" widget="label_selection" options="{'classes': {'draft': 'info', 'submitted': 'success'}}"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <div class="d-flex align-items-center mb-1 text-muted">
                                    <i class="fa fa-building me-2" title="Department"/>
                                    <field name="department_id"/>
                                </div>
                                <div class="d-flex align-items-center mb-3 text-muted">
                                    <i class="fa fa-calendar me-2" title="Date"/>
                                    <field name="visit_date"/>
                                </div>
                                <div class="progress_container px-1">
                                    <div class="d-flex justify-content-between mb-1">
                                        <small class="fw-bold">Completion</small>
                                        <small class="fw-bold text-primary"><field name="total_percentage"/>%</small>
                                    </div>
                                    <field name="total_percentage" widget="progressbar" options="{'current_value': 'total_percentage', 'max_value': 100}" nolabel="1"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom mt-3 border-top pt-2">
                                <div class="oe_kanban_bottom_left">
                                    <field name="employee_id" widget="many2one_avatar"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="ab_quality_assurance.ab_quality_assurance_visit_action" model="ir.actions.act_window">
        <field name="view_mode">kanban,list,form</field>
    </record>

    <!-- Improved Form View -->
    <record id="ab_quality_assurance_visit_view_form_inherit" model="ir.ui.view">
        <field name="name">ab_quality_assurance_visit.form.inherit</field>
        <field name="model">ab_quality_assurance_visit</field>
        <field name="inherit_id" ref="ab_quality_assurance.ab_quality_assurance_visit_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_export_pdf']" position="attributes">
                <attribute name="icon">fa-file-pdf-o</attribute>
                <attribute name="class">btn-outline-danger</attribute>
            </xpath>
            <xpath expr="//button[@name='action_export_xlsx']" position="attributes">
                <attribute name="icon">fa-file-excel-o</attribute>
                <attribute name="class">btn-outline-success</attribute>
            </xpath>
            <xpath expr="//button[@name='action_submit_visit']" position="attributes">
                <attribute name="icon">fa-send-o</attribute>
                <attribute name="confirm">Are you sure you want to submit this visit? This will lock all scores.</attribute>
            </xpath>

            <xpath expr="//div[hasclass('o_qa_visit_summary_card')]" position="replace">
                <div class="o_qa_ux_dashboard_grid">
                    <div class="o_qa_ux_card">
                        <div class="o_qa_ux_card_icon bg-primary-light"><i class="fa fa-building"/></div>
                        <div class="o_qa_ux_card_content">
                            <label for="department_id" string="Target Unit"/>
                            <div class="fw-bold fs-5"><field name="department_id" readonly="state == 'submitted'" domain="[('name', '=like', 'فرع%')]"/></div>
                            <div class="text-muted small"><field name="department_manager_id"/></div>
                        </div>
                    </div>
                    <div class="o_qa_ux_card">
                        <div class="o_qa_ux_card_icon bg-info-light"><i class="fa fa-calendar"/></div>
                        <div class="o_qa_ux_card_content">
                            <label for="visit_date"/>
                            <div class="fw-bold fs-5"><field name="visit_date" readonly="state == 'submitted'"/></div>
                            <div class="text-muted small">Performer: <field name="employee_id" readonly="state == 'submitted'"/></div>
                        </div>
                    </div>
                    <div class="o_qa_ux_card">
                        <div class="o_qa_ux_card_icon bg-success-light"><i class="fa fa-trophy"/></div>
                        <div class="o_qa_ux_card_content">
                            <label for="earned_total_score" string="Performance"/>
                            <div class="fw-bold fs-5 text-success">
                                <field name="earned_total_score"/> / <field name="max_total_score"/>
                            </div>
                            <div class="mt-1">
                                <field name="total_percentage" widget="progressbar" options="{'editable': false}"/>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>

            <xpath expr="//field[@name='visit_section_ids']" position="attributes">
                <attribute name="class">o_qa_ux_section_main_list</attribute>
            </xpath>
            
            <xpath expr="//field[@name='visit_section_ids']/list" position="attributes">
                <attribute name="decoration-success">percentage &gt;= 90</attribute>
                <attribute name="decoration-danger">percentage &lt; 50</attribute>
            </xpath>
            
            <xpath expr="//field[@name='visit_section_ids']/list/field[@name='percentage']" position="attributes">
                <attribute name="widget">progressbar</attribute>
            </xpath>

            <!-- SECTION FORM IMPROVEMENTS (The popup/nested form) -->
            <xpath expr="//field[@name='visit_section_ids']/form//div[hasclass('o_qa_visit_summary_card')]" position="replace">
                <div class="o_qa_ux_section_header">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="m-0 text-primary"><field name="name" readonly="1"/></h2>
                        <div class="o_qa_ux_section_stats d-flex gap-4">
                            <div class="text-center">
                                <div class="text-muted small fw-bold">Earned</div>
                                <div class="fs-4 fw-bold text-success"><field name="earned_score"/></div>
                            </div>
                            <div class="text-center">
                                <div class="text-muted small fw-bold">Max</div>
                                <div class="fs-4 fw-bold text-muted"><field name="max_score"/></div>
                            </div>
                        </div>
                    </div>
                    <field name="percentage" widget="progressbar" class="mb-4"/>
                </div>
            </xpath>

            <xpath expr="//field[@name='visit_section_ids']/form//field[@name='visit_line_ids']/list" position="attributes">
                <attribute name="class">o_qa_ux_line_list</attribute>
            </xpath>

            <xpath expr="//field[@name='visit_section_ids']/form//field[@name='visit_line_ids']/list/field[@name='title']" position="attributes">
                <attribute name="class">fw-bold text-primary fs-6</attribute>
            </xpath>
            
            <xpath expr="//field[@name='visit_section_ids']/form//field[@name='visit_line_ids']/list/field[@name='percentage']" position="attributes">
                <attribute name="widget">progressbar</attribute>
            </xpath>
        </field>
    </record>

    <record id="ab_quality_assurance_visit_view_search_inherit" model="ir.ui.view">
        <field name="name">ab_quality_assurance_visit.search.inherit</field>
        <field name="model">ab_quality_assurance_visit</field>
        <field name="inherit_id" ref="ab_quality_assurance.ab_quality_assurance_visit_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='filter_draft']" position="before">
                <filter name="filter_my_visits" string="My Visits" domain="[('user_id', '=', uid)]"/>
                <separator/>
            </xpath>
        </field>
    </record>

    <!-- Dedicated Action for Drafts -->
    <record id="action_ab_quality_assurance_visit_drafts" model="ir.actions.act_window">
        <field name="name">My Draft Visits</field>
        <field name="res_model">ab_quality_assurance_visit</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('state', '=', 'draft'), ('user_id', '=', uid)]</field>
        <field name="context">{'default_state': 'draft'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No draft visits found.
            </p>
            <p>
                Visits you start but don't submit yet will appear here automatically.
            </p>
        </field>
    </record>

</odoo>
