<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="rule_ab_pharmacy_delivery_branch_user" model="ir.rule">
            <field name="name">Pharmacy Delivery Branch User Visibility</field>
            <field name="model_id" ref="model_ab_pharmacy_delivery_branch"/>
            <field name="groups" eval="[(4, ref('ab_orders_management.group_ab_pharmacy_delivery_user'))]"/>
            <field name="domain_force">[('user_ids', 'in', [user.id])]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

