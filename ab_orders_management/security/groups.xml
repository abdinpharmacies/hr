<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="category_ab_orders_management" model="ir.module.category">
            <field name="name">Pharmacy Delivery Management</field>
            <field name="sequence" eval="30"/>
        </record>

        <record id="privilege_ab_orders_management" model="res.groups.privilege">
            <field name="name">Pharmacy Delivery Management</field>
            <field name="category_id" ref="category_ab_orders_management"/>
            <field name="sequence" eval="30"/>
        </record>

        <record id="group_ab_pharmacy_delivery_user" model="res.groups">
            <field name="name">Pharmacy Delivery User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="privilege_id" ref="privilege_ab_orders_management"/>
        </record>

        <record id="group_ab_pharmacy_delivery_manager" model="res.groups">
            <field name="name">Pharmacy Delivery Manager</field>
            <field name="implied_ids" eval="[(4, ref('ab_orders_management.group_ab_pharmacy_delivery_user'))]"/>
            <field name="privilege_id" ref="privilege_ab_orders_management"/>
        </record>

        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('ab_orders_management.group_ab_pharmacy_delivery_manager'))]"/>
        </record>

        <record id="base.group_user" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('ab_orders_management.group_ab_pharmacy_delivery_user'))]"/>
        </record>
    </data>
</odoo>
