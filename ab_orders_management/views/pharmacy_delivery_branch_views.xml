<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_ab_pharmacy_delivery_branch_list" model="ir.ui.view">
            <field name="name">ab_pharmacy_delivery_branch.list</field>
            <field name="model">ab_pharmacy_delivery_branch</field>
            <field name="arch" type="xml">
                <list string="Pilots/Branches">
                    <field name="name"/>
                    <field name="hr_department_id"/>
                    <field name="pilot_count"/>
                    <field name="assignment_count"/>
                </list>
            </field>
        </record>

        <record id="view_ab_pharmacy_delivery_branch_form" model="ir.ui.view">
            <field name="name">ab_pharmacy_delivery_branch.form</field>
            <field name="model">ab_pharmacy_delivery_branch</field>
            <field name="arch" type="xml">
                <form string="Pilots/Branches">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="hr_department_id"/>
                            <field name="user_ids" widget="many2many_tags"/>
                        </group>
                        <notebook>
                            <page string="Pilots">
                                <field name="pilot_ids" context="{'default_branch_id': id, 'default_hr_department_id': hr_department_id}">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="pilot_code"/>
                                        <field name="hr_department_id"
                                               domain="['|', ('name', 'ilike', 'الاقصر'), ('parent_id.name', 'ilike', 'الاقصر')]"
                                               options="{'no_create': True, 'no_create_edit': True}"/>
                                        <field name="shift"/>
                                        <field name="sign_in_datetime"/>
                                        <field name="sign_in_order" readonly="1"/>
                                        <field name="daily_handle_count" readonly="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Branches">
                                <field name="related_branch_ids" readonly="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="hr_department_id"
                                               domain="['|', ('name', 'ilike', 'الاقصر'), ('parent_id.name', 'ilike', 'الاقصر')]"
                                               options="{'no_create': True, 'no_create_edit': True}"/>
                                        <field name="pilot_count"/>
                                        <field name="assignment_count"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Assignments">
                                <field name="assignment_ids">
                                    <list>
                                        <field name="order_number"/>
                                        <field name="pilot_id"/>
                                        <field name="transaction_type"/>
                                        <field name="status"/>
                                        <field name="start_datetime"/>
                                        <field name="end_datetime"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_ab_pharmacy_delivery_branch" model="ir.actions.act_window">
            <field name="name">Pilots/Branches</field>
            <field name="res_model">ab_pharmacy_delivery_branch</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
