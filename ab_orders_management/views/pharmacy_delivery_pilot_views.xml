<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_ab_pharmacy_delivery_pilot_list" model="ir.ui.view">
            <field name="name">ab_pharmacy_delivery_pilot.list</field>
            <field name="model">ab_pharmacy_delivery_pilot</field>
            <field name="arch" type="xml">
                <list string="Pilots">
                    <field name="name"/>
                    <field name="pilot_code"/>
                    <field name="hr_department_id"
                           domain="['|', ('name', 'ilike', 'الاقصر'), ('parent_id.name', 'ilike', 'الاقصر')]"
                           options="{'no_create': True, 'no_create_edit': True}"/>
                    <field name="sign_in_datetime"/>
                    <field name="sign_in_order"/>
                    <field name="daily_handle_count"/>
                </list>
            </field>
        </record>

        <record id="view_ab_pharmacy_delivery_pilot_form" model="ir.ui.view">
            <field name="name">ab_pharmacy_delivery_pilot.form</field>
            <field name="model">ab_pharmacy_delivery_pilot</field>
            <field name="arch" type="xml">
                <form string="Pilot">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="hr_employee_id"
                                       domain="[('job_id.name', 'ilike', 'مندوب توصيل'), '|', ('department_id.name', 'ilike', 'الاقصر'), ('parent_department_id.name', 'ilike', 'الاقصر')]"/>
                                <field name="pilot_code"/>
                                <field name="shift"/>
                                <field name="sign_in_datetime"/>
                                <field name="sign_in_order" readonly="1"/>
                                <field name="daily_handle_count" readonly="1"/>
                                <field name="hr_department_id"
                                       domain="['|', ('name', 'ilike', 'الاقصر'), ('parent_id.name', 'ilike', 'الاقصر')]"
                                       options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="hr_parent_department_id" readonly="1"/>
                                <field name="hr_job_id" readonly="1"/>
                                <field name="branch_id"/>
                                <field name="status"/>
                            </group>
                            <group>
                                <field name="delivery_assigned_count" readonly="1"/>
                                <field name="delivery_completed_count" readonly="1"/>
                                <field name="order_assigned_count" readonly="1"/>
                                <field name="order_completed_count" readonly="1"/>
                                <field name="handled_item_count" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <button name="action_open_status_wizard" type="object" string="Change Status" class="btn-primary"/>
                        </group>
                        <notebook>
                            <page string="Assignments">
                                <field name="assignment_ids">
                                    <list>
                                        <field name="order_number"/>
                                        <field name="transaction_type"/>
                                        <field name="branch_id"/>
                                        <field name="status"/>
                                        <field name="start_datetime"/>
                                        <field name="end_datetime"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_ab_pharmacy_delivery_pilot" model="ir.actions.act_window">
            <field name="name">Pilots</field>
            <field name="res_model">ab_pharmacy_delivery_pilot</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
