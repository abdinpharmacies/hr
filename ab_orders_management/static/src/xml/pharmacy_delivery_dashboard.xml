<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ab_orders_management.PharmacyDeliveryDashboard">
        <div class="o_ab_pharmacy_delivery_dashboard" t-att-class="state.sidebarOpen ? 'is-sidebar-open' : 'is-sidebar-collapsed'">
            <aside class="o_search_panel flex-grow-0 flex-shrink-0 h-100 pb-5 bg-view overflow-auto position-relative pe-1 ps-3 o_ab_pharmacy_delivery_sidebar" t-att-class="state.sidebarOpen ? 'is-open' : 'is-collapsed'">
                <div class="o_ab_pharmacy_delivery_sidebar_header">
                    <strong t-if="state.sidebarOpen"><t t-esc="sidebarTitle"/></strong>
                    <button type="button"
                            class="btn btn-sm btn-outline-secondary o_ab_pharmacy_delivery_sidebar_toggle"
                            t-on-click="toggleSidebar"
                            t-att-title="sidebarToggleTitle"
                            t-att-aria-label="sidebarToggleAriaLabel">
                        <i class="oi oi-fw oi-panel-right fa-flip-horizontal"/>
                    </button>
                </div>
                <t t-if="state.sidebarOpen">
                    <div class="p-3 border-bottom">
                        <select class="form-select form-select-sm mb-2" t-on-change="onBranchChange" t-att-value="state.selectedBranchId">
                            <option value="0"><t t-esc="allBranchesLabel"/></option>
                            <t t-foreach="state.payload.branches" t-as="branch" t-key="branch.id">
                                <option t-att-value="branch.id"><t t-esc="branch.name"/></option>
                            </t>
                        </select>
                        <button type="button" class="btn btn-primary btn-sm w-100" t-on-click="loadDashboard" t-att-disabled="state.loading">
                            <i class="oi oi-reload me-1"/><t t-esc="refreshLabel"/>
                        </button>
                    </div>
                    <div class="o_search_panel_section">
                        <div class="o_search_panel_section_header">
                            <span class="o_search_panel_category_title"><t t-esc="departmentsLabel"/></span>
                        </div>
                        <ul class="list-unstyled o_search_panel_category_value">
                            <li>
                                <button type="button"
                                        class="o_ab_pharmacy_delivery_department_filter"
                                        t-att-class="(state.selectedDepartmentId || 0) === 0 ? 'is-active' : ''"
                                        t-on-click="() => selectDepartment(0)">
                                    <span><t t-esc="allTargetDepartmentsLabel"/></span>
                                </button>
                            </li>
                            <t t-foreach="state.payload.departments" t-as="department" t-key="department.id">
                                <li>
                                    <button type="button"
                                            class="o_ab_pharmacy_delivery_department_filter"
                                            t-att-class="state.selectedDepartmentId === department.id ? 'is-active' : ''"
                                            t-on-click="() => selectDepartment(department.id)">
                                        <span t-esc="department.name"/>
                                        <span class="badge rounded-pill text-bg-light" t-esc="department.pilot_count || 0"/>
                                    </button>
                                </li>
                            </t>
                        </ul>
                    </div>
                </t>
            </aside>

            <div class="o_ab_pharmacy_delivery_content">
                <div class="o_ab_pharmacy_delivery_main p-3">
                    <section class="o_ab_pharmacy_delivery_queues">
                        <div class="o_ab_pharmacy_delivery_queue mb-4"
                             t-att-class="queueDropClass('free')"
                             t-on-dragover="(ev) => onQueueDragOver(ev, 'free')"
                             t-on-dragleave="(ev) => onQueueDragLeave(ev, 'free')"
                             t-on-drop="(ev) => onQueueDrop(ev, 'free')">
                            <div class="o_ab_pharmacy_delivery_queue_header mb-3">
                                <div class="d-flex align-items-center justify-content-between w-100">
                                    <h3 class="mb-0"><t t-esc="availablePilotsLabel"/></h3>
                                    <div class="d-flex align-items-center gap-2">
                                        <button type="button" class="btn btn-sm" t-att-class="state.sortByAttendance ? 'btn-success' : 'btn-outline-secondary'" t-on-click="toggleSortByAttendance" title="Sort by attendance">
                                            <i class="oi oi-clock"/> <span class="small"><t t-if="state.sortByAttendance">ON</t><t t-else="">OFF</t></span>
                                        </button>
                                        <button type="button" class="btn btn-sm" t-att-class="state.sortByDeliveries !== null ? 'btn-warning' : 'btn-outline-secondary'" t-on-click="toggleSortByDeliveries" title="Sort by deliveries">
                                            <i t-attf-class="{{ deliveriesIconClass }}"/>
                                        </button>
                                        <span class="badge bg-success"><t t-esc="activePilotsCount"/></span>
                                    </div>
                                </div>
                            </div>
                            <div class="o_ab_pharmacy_delivery_queue_cards">
                                <t t-if="visibleAvailablePilots.length">
                                    <t t-foreach="visibleAvailablePilots" t-as="pilot" t-key="pilot.id">
                                        <article class="o_ab_pharmacy_delivery_card mb-2 p-3 border rounded"
                                                 draggable="true"
                                                 t-on-dragstart="() => onPilotDragStart(pilot.id)"
                                                 t-on-dragend="onPilotDragEnd">
                                            <div class="d-flex align-items-center gap-2 mb-2">
                                                <span class="o_ab_pharmacy_delivery_status_dot" t-att-style="statusDotStyle(pilot.status)"></span>
                                                <strong t-esc="pilot.name"/>
                                            </div>
                                            <div class="text-muted small mb-2">
                                                <span t-esc="pilot.status_label"/> • <span t-esc="pilot.department_name"/>
                                                <span t-if="pilot.sign_in_order"> • #<t t-esc="pilot.sign_in_order"/></span>
                                            </div>
                                            <div class="text-muted small mb-2">
                                                <span><t t-esc="ordersLabel"/> <t t-esc="pilot.order_completed_count"/></span> •
                                                <span><t t-esc="deliveriesLabel"/> <t t-esc="pilot.delivery_completed_count"/></span> •
                                                <span><t t-esc="totalLabel"/> <t t-esc="pilot.daily_handle_count"/></span>
                                            </div>
                                            <button type="button" class="btn btn-sm btn-primary" t-on-click="() => openPilotWizard(pilot)">
                                                <t t-esc="changeStatusLabel"/>
                                            </button>
                                        </article>
                                    </t>
                                </t>
                                <t t-else="">
                                    <div class="o_ab_pharmacy_delivery_empty text-muted p-3 text-center">
                                        <t t-esc="noFreePilotsLabel"/>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <div class="o_ab_pharmacy_delivery_queue"
                             t-att-class="queueDropClass('in_delivery')"
                             t-on-dragover="(ev) => onQueueDragOver(ev, 'in_delivery')"
                             t-on-dragleave="(ev) => onQueueDragLeave(ev, 'in_delivery')"
                             t-on-drop="(ev) => onQueueDrop(ev, 'in_delivery')">
                            <div class="o_ab_pharmacy_delivery_queue_header mb-3">
                                <div class="d-flex align-items-center justify-content-between w-100">
                                    <h3 class="mb-0"><t t-esc="inDeliveryPilotsLabel"/></h3>
                                    <span class="badge bg-warning"><t t-esc="visibleInDeliveryPilots.length"/></span>
                                </div>
                            </div>
                            <div class="o_ab_pharmacy_delivery_queue_cards">
                                <t t-if="visibleInDeliveryPilots.length">
                                    <t t-foreach="visibleInDeliveryPilots" t-as="pilot" t-key="pilot.id">
                                        <article class="o_ab_pharmacy_delivery_card is-in-delivery mb-2 p-3 border border-warning rounded"
                                                 draggable="true"
                                                 t-on-dragstart="() => onPilotDragStart(pilot.id)"
                                                 t-on-dragend="onPilotDragEnd">
                                            <div class="d-flex align-items-center gap-2 mb-2">
                                                <span class="o_ab_pharmacy_delivery_status_dot" t-att-style="statusDotStyle(pilot.status)"></span>
                                                <strong t-esc="pilot.name"/>
                                            </div>
                                            <div class="text-muted small mb-2">
                                                <span t-esc="pilot.status_label"/> • <span t-esc="pilot.department_name"/>
                                                <span t-if="pilot.sign_in_order"> • #<t t-esc="pilot.sign_in_order"/></span>
                                            </div>
                                            <div class="o_ab_pharmacy_delivery_card_assignment mb-2" t-if="pilot.assignments and pilot.assignments.length">
                                                <t t-foreach="pilot.assignments" t-as="assignment" t-key="assignment.id">
                                                    <div class="o_ab_pharmacy_delivery_assignment_item small">
                                                        <div><strong><t t-esc="orderFieldLabel"/></strong> <t t-esc="assignment.order_number"/></div>
                                                        <div><strong><t t-esc="typeFieldLabel"/></strong> <t t-esc="assignment.transaction_type_label"/></div>
                                                        <div><strong><t t-esc="branchFieldLabel"/></strong> <t t-esc="assignment.branch_name"/></div>
                                                    </div>
                                                </t>
                                            </div>
                                            <div class="text-muted small mb-2">
                                                <span><t t-esc="ordersLabel"/> <t t-esc="pilot.order_completed_count"/></span> •
                                                <span><t t-esc="deliveriesLabel"/> <t t-esc="pilot.delivery_completed_count"/></span> •
                                                <span><t t-esc="totalLabel"/> <t t-esc="pilot.daily_handle_count"/></span>
                                            </div>
                                            <div class="o_ab_pharmacy_delivery_card_actions btn-group rounded-3" style="background:#e9ecef;padding:4px;">
                                                <button type="button" class="btn btn-sm btn-light border" t-on-click="() => openAddOrderWizard(pilot)" title="Add Order">
                                                    <i class="oi oi-plus text-success"/>
                                                </button>
                                                <button type="button" class="btn btn-sm btn-primary" t-on-click="() => openPilotWizard(pilot)">
                                                    <t t-esc="closeChangeStatusLabel"/>
                                                </button>
                                            </div>
                                        </article>
                                    </t>
                                </t>
                                <t t-else="">
                                    <div class="o_ab_pharmacy_delivery_empty text-muted p-3 text-center">
                                        <t t-esc="noDeliveryPilotsLabel"/>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </section>
                </div>
            </div>
            <t t-if="state.addOrderModalOpen">
                <div class="modal d-block" tabindex="-1">
                    <div class="modal-backdrop show"></div>
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title"><t t-esc="addOrderModalTitle"/></h5>
                                <button type="button" class="btn-close" t-on-click="closeAddOrderModal"></button>
                            </div>
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label class="form-label fw-bold"><t t-esc="addOrderPilotName"/></label>
                                    <div class="text-muted small" t-esc="addAnotherOrderLabel"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label"><t t-esc="addOrderOrderNumberLabel"/></label>
                                    <input type="text"
                                           class="form-control"
                                           t-att-class="state.addOrderErrors.order_number ? 'is-invalid' : ''"
                                           t-att-placeholder="addOrderOrderNumberPlaceholder"
                                           t-att-value="state.addOrderForm.order_number"
                                           t-on-input="(ev) => state.addOrderForm.order_number = ev.target.value"/>
                                    <div t-if="state.addOrderErrors.order_number" class="invalid-feedback d-block" t-esc="state.addOrderErrors.order_number"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label"><t t-esc="addOrderTypeLabel"/></label>
                                    <select class="form-select"
                                            t-att-value="state.addOrderForm.transaction_type"
                                            t-on-change="(ev) => state.addOrderForm.transaction_type = ev.target.value">
                                        <option value="delivery"><t t-esc="addOrderDeliveryTypeLabel"/></option>
                                        <option value="order"><t t-esc="addOrderClientTypeLabel"/></option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label"><t t-esc="addOrderBranchLabel"/></label>
                                    <select class="form-select"
                                            t-att-value="state.addOrderForm.branch_id"
                                            t-on-change="(ev) => state.addOrderForm.branch_id = parseInt(ev.target.value) || 0">
                                        <t t-foreach="state.payload.branches" t-as="branch" t-key="branch.id">
                                            <option t-att-value="branch.id" t-esc="branch.name"/>
                                        </t>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label"><t t-esc="addOrderNoteLabel"/></label>
                                    <textarea class="form-control"
                                             rows="2"
                                             t-att-placeholder="addOrderNotePlaceholder"
                                             t-on-input="(ev) => state.addOrderForm.note = ev.target.value"><t t-esc="state.addOrderForm.note"/></textarea>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" t-on-click="closeAddOrderModal" t-att-disabled="state.addOrderSubmitting">
                                    <t t-esc="addOrderCancelLabel"/>
                                </button>
                                <button type="button" class="btn btn-primary" t-on-click="submitAddOrder" t-att-disabled="state.addOrderSubmitting">
                                    <t t-esc="addOrderSubmitLabel"/>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>